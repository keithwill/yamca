@namespace Yamca.Web.Components

<MudMenu AnchorOrigin="@AnchorOrigin" TransformOrigin="@TransformOrigin" Dense="@Dense" Disabled="@Disabled">
    <ActivatorContent>
        <MudChip T="string" Size="@Size" Variant="@Variant"
                 Icon="@Icon"
                 Color="@Color"
                 Style="@Style"
                 OnClick="@(e => context.ToggleAsync(e))">
            @Label
        </MudChip>
    </ActivatorContent>
    <ChildContent>
        @ChildContent
    </ChildContent>
</MudMenu>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public string? Style { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Small;
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Dense { get; set; } = true;
    [Parameter] public Origin AnchorOrigin { get; set; } = Origin.BottomLeft;
    [Parameter] public Origin TransformOrigin { get; set; } = Origin.TopLeft;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
