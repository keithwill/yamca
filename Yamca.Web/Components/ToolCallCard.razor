@using System.Text.Json
@using Yamca.Agent.Tools
@using Yamca.Web.Components.Subagents
@using Yamca.Web.Services
@inject SubagentSessionRegistry Subagents
@inject IDialogService Dialogs

<div class="tool-call @(_expanded ? "expanded" : "")">
    <div class="tool-call-header" @onclick="Toggle">
        <MudIcon Icon="@StateIcon" Color="@StateColor" Size="Size.Small" />
        <span class="tool-call-action">@ActionLabel</span>
        @if (!string.IsNullOrEmpty(Summary))
        {
            <code class="tool-call-summary">@Summary</code>
        }
        <span class="tool-call-spacer"></span>
        @if (Item.State == ToolCallState.Pending)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" Style="width:14px;height:14px;" />
        }
        else if (Item.State != ToolCallState.Succeeded)
        {
            <span class="tool-call-state state-@Item.State.ToString().ToLowerInvariant()">@StateLabel</span>
        }
        @if (IsSubagentCall)
        {
            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="tool-call-chevron" />
        }
        else if (IsLoopCall)
        {
            <MudIcon Icon="@Icons.Material.Filled.Loop" Size="Size.Small" Class="tool-call-chevron" />
        }
        else
        {
            <MudIcon Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                     Size="Size.Small" Class="tool-call-chevron" />
        }
    </div>
    @if (IsLoopCall)
    {
        @* Loops are user-requested and expensive, and their click opens the session modal rather
           than an inline expand — so surface just the aggregate roll-up line (success / followup /
           failed counts) in the log by default. Per-item detail lives in the modal. *@
        @if (LoopSummaryLine is { } summary)
        {
            <div class="tool-call-body">
                <span class="tool-call-rollup">@summary</span>
            </div>
        }
    }
    else if (_expanded)
    {
        <div class="tool-call-body">
            @if (Change is { } change)
            {
                <DiffView OldText="@change.OldText" NewText="@change.NewText" FilePath="@change.Path" />
            }
            else if (!string.IsNullOrWhiteSpace(Item.ArgumentsJson))
            {
                <MudText Typo="Typo.caption">Arguments</MudText>
                <pre class="tool-call-pre">@PrettyArgs</pre>
            }
            @if (Item.Result is not null)
            {
                <MudText Typo="Typo.caption" Class="mt-2">Result</MudText>
                <pre class="tool-call-pre tool-call-pre-result">@Item.Result</pre>
            }
        </div>
    }
</div>

<style>
    .tool-call {
        border-radius: 4px;
        margin: 2px 0;
        font-size: 0.8rem;
    }
    .tool-call-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 2px 8px;
        cursor: pointer;
        min-height: 24px;
        user-select: none;
    }
    .tool-call-header:hover { background: var(--mud-palette-action-default-hover); }
    .tool-call-action { font-weight: 500; white-space: nowrap; }
    .tool-call-summary {
        color: var(--mud-palette-text-secondary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
        font-size: 0.78rem;
    }
    .tool-call-spacer { flex: 1; }
    .tool-call-chevron { opacity: 0.5; }
    .tool-call-state {
        font-size: 0.7rem;
        text-transform: uppercase;
        padding: 0 6px;
        border-radius: 2px;
    }
    .state-failed  { color: var(--mud-palette-error); }
    .state-denied  { color: var(--mud-palette-warning); }
    .tool-call-body { padding: 4px 8px 8px 8px; border-top: 1px solid var(--mud-palette-lines-default); }
    .tool-call-pre { overflow: auto; max-height: 200px; font-size: 0.75rem; margin: 2px 0; }
    .tool-call-pre-result { max-height: 300px; }
    .tool-call-rollup { font-size: 0.78rem; color: var(--mud-palette-text-secondary); }
</style>

@code {
    [Parameter, EditorRequired] public ToolCallItem Item { get; set; } = default!;

    private bool _expanded;

    // Surface file changes by default — the diff is the point. Other tool cards stay collapsed.
    protected override void OnInitialized() => _expanded = FileChangeArgs.IsDiffTool(Item.ToolName);

    // A tool card only changes when its execution state advances, its result arrives, its
    // (streamed) arguments grow, or the user toggles it open. Cards from earlier turns
    // short-circuit on every streamed token.
    private ToolCallState _lastState = (ToolCallState)(-1);
    private int _lastResultLen = -2;
    private int _lastArgsLen = -1;
    private bool _lastExpanded;

    protected override bool ShouldRender()
    {
        var resultLen = Item.Result?.Length ?? -1;
        var argsLen = Item.ArgumentsJson.Length;
        if (Item.State == _lastState && resultLen == _lastResultLen
            && argsLen == _lastArgsLen && _expanded == _lastExpanded)
            return false;
        _lastState = Item.State;
        _lastResultLen = resultLen;
        _lastArgsLen = argsLen;
        _lastExpanded = _expanded;
        return true;
    }

    private bool IsSubagentCall => Item.ToolName == SubagentRunTool.ToolName;
    private bool IsLoopCall => Item.ToolName == LoopTool.ToolName;

    // The roll-up's first line is the aggregate ("Loop over N items ...: A success, B needs_followup,
    // C failed."); the rest is per-item detail that belongs in the modal, not the log.
    private string? LoopSummaryLine => Item.Result?
        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .FirstOrDefault();

    private async Task OpenSubagentSession()
    {
        var parameters = new DialogParameters { ["InitialCallId"] = Item.CallId };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await Dialogs.ShowAsync<SubagentSessionsDialog>("Subagent sessions", parameters, options);
    }

    // A loop fans out to N child runs that all share this loop call's id, so scope the modal's
    // list to just this loop's children (GroupCallId) rather than the whole chat.
    private async Task OpenLoopSessions()
    {
        var parameters = new DialogParameters { ["GroupCallId"] = Item.CallId };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await Dialogs.ShowAsync<SubagentSessionsDialog>("Loop sessions", parameters, options);
    }

    // Subagent and loop calls open the rich session modal instead of expanding the raw tool JSON.
    private async Task Toggle()
    {
        if (IsSubagentCall)
        {
            await OpenSubagentSession();
            return;
        }
        if (IsLoopCall)
        {
            await OpenLoopSessions();
            return;
        }
        _expanded = !_expanded;
    }

    // A file-mutating call reduced to a before/after pair, or null for other tools / partial
    // (still-streaming) arguments — in which case the body falls back to raw arguments.
    private FileChange? Change => FileChangeArgs.Parse(Item.ToolName, Item.ArgumentsJson);

    private string ActionLabel => Item.ToolName switch
    {
        "read_file"       => "Read",
        "write_file"      => "Write",
        "edit_file"       => "Edit",
        "delete_file"     => "Delete",
        "list_directory"  => "List",
        "execute_command" => "Run",
        "loop"            => "Loop",
        _ => Item.ToolName,
    };

    private string Summary
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Item.ArgumentsJson)) return "";
            try
            {
                using var doc = JsonDocument.Parse(Item.ArgumentsJson);
                var root = doc.RootElement;

                // A loop reads best as "<agent> · N items" rather than a single path/command arg.
                if (Item.ToolName == "loop")
                {
                    if (root.TryGetProperty("agent", out var agentProp)
                        && agentProp.ValueKind == JsonValueKind.String)
                    {
                        var agent = agentProp.GetString() ?? "";
                        var count = root.TryGetProperty("items", out var items)
                            && items.ValueKind == JsonValueKind.Array ? items.GetArrayLength() : 0;
                        return count > 0 ? $"{agent} · {count} item{(count == 1 ? "" : "s")}" : agent;
                    }
                    return "";
                }

                var argName = Item.ToolName switch
                {
                    "execute_command" => "command",
                    _ => "path",
                };
                if (root.TryGetProperty(argName, out var prop) && prop.ValueKind == JsonValueKind.String)
                {
                    var s = prop.GetString() ?? "";
                    return s.Replace('\n', ' ').Replace('\r', ' ');
                }
            }
            catch { }
            return "";
        }
    }

    private string PrettyArgs
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Item.ArgumentsJson)) return "";
            try
            {
                using var doc = JsonDocument.Parse(Item.ArgumentsJson);
                return JsonSerializer.Serialize(
                    doc.RootElement,
                    new JsonSerializerOptions { WriteIndented = true });
            }
            catch { return Item.ArgumentsJson; }
        }
    }

    private string StateLabel => Item.State switch
    {
        ToolCallState.Pending   => "running",
        ToolCallState.Succeeded => "ok",
        ToolCallState.Failed    => "error",
        ToolCallState.Denied    => "denied",
        _ => Item.State.ToString(),
    };

    private string StateIcon => Item.State switch
    {
        ToolCallState.Pending   => Icons.Material.Filled.HourglassEmpty,
        ToolCallState.Succeeded => Icons.Material.Filled.CheckCircle,
        ToolCallState.Failed    => Icons.Material.Filled.Error,
        ToolCallState.Denied    => Icons.Material.Filled.Block,
        _ => Icons.Material.Filled.Help,
    };

    private Color StateColor => Item.State switch
    {
        ToolCallState.Pending   => Color.Info,
        ToolCallState.Succeeded => Color.Success,
        ToolCallState.Failed    => Color.Error,
        ToolCallState.Denied    => Color.Warning,
        _ => Color.Default,
    };
}
