@namespace Yamca.Web.Components.Board
@using Yamca.Agent.Board

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_title" T="string"
                      Label="Card title"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true"
                      HelperText="A short summary of the idea." />

        <div class="d-flex align-center mt-2" style="gap: 6px;">
            <ChipDropdown Label="@(_priority switch { CardPriority.High => "↑ High", CardPriority.Low => "↓ Low", _ => "Normal" })"
                          Icon="@Icons.Material.Filled.Flag"
                          Color="@(_priority == CardPriority.High ? Color.Warning : Color.Default)"
                          Style="@(_priority == CardPriority.Low ? "opacity:0.6;" : "")">
                <MudMenuItem OnClick="@(() => SetPriority(CardPriority.High))">↑ High</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Normal))">Normal</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Low))">↓ Low</MudMenuItem>
            </ChipDropdown>
        </div>

        <MudTextField @bind-Value="_body" T="string"
                      Label="Details / plan (optional)"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Lines="8" Class="mt-3"
                      HelperText="Markdown. Add a '- [ ]' checklist for subtasks if you like." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Create" Disabled="@string.IsNullOrWhiteSpace(_title)">
            Create card
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    private string _title = "";
    private string _body = "";
    private CardPriority _priority = CardPriority.Normal;

    public sealed record Result(string Title, string Body, CardPriority Priority);

    private void SetPriority(CardPriority priority) => _priority = priority;

    private void Cancel() => Dialog.Cancel();

    private void Create()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;
        Dialog.Close(DialogResult.Ok(new Result(_title.Trim(), _body ?? "", _priority)));
    }
}
