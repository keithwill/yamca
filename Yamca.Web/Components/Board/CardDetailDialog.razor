@namespace Yamca.Web.Components.Board
@using Yamca.Agent.Board
@using Yamca.Agent.Settings
@using Yamca.Web.Services
@inject GitService Git
@inject IDialogService Dialogs

<MudDialog>
    <TitleContent>
        <div class="d-flex flex-column" style="gap: 2px; width: 100%;">
            <div class="d-flex align-center">
                <MudText Typo="Typo.h6">@Card.Title</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Class="ml-auto" OnClick="Close" />
            </div>
            <div class="d-flex align-center" style="gap: 6px;">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">#@Card.Id</MudChip>
                <ChipDropdown Label="@(_priority switch { CardPriority.High => "↑ High", CardPriority.Low => "↓ Low", _ => "Normal" })"
                              Icon="@Icons.Material.Filled.Flag"
                              Color="@(_priority == CardPriority.High ? Color.Warning : Color.Default)"
                              Style="@(_priority == CardPriority.Low ? "opacity:0.6;" : "")">
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.High))">↑ High</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Normal))">Normal</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Low))">↓ Low</MudMenuItem>
                </ChipDropdown>
                @if (IsBranchBound)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.AccountTree">@Card.Branch</MudChip>
                }
                else if (HasBranchAttribute)
                {
                    <MudTooltip Text="Branch doesn't exist or isn't loaded into a worktree">
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.AccountTree" Style="opacity:0.5;">@Card.Branch</MudChip>
                    </MudTooltip>
                }
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_editingBody)
        {
            <MudTextField @bind-Value="_title" T="string"
                          Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense"
                          Immediate="true" Class="mb-2" />
            <MudTextField @bind-Value="_body" T="string"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Lines="16" Immediate="true" AutoFocus="true"
                          HelperText="Plain markdown — switch back to preview by saving or cancelling."
                          Class="yamca-body-editor" />
            <div class="d-flex mt-2" style="gap: 8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@_busy" OnClick="SaveBody">Save</MudButton>
                <MudButton Variant="Variant.Text" Disabled="@_busy" OnClick="CancelEditBody">Cancel</MudButton>
            </div>
        }
        else
        {
            <div class="yamca-markdown">
                @((MarkupString)MarkdownRenderer.ToHtml(string.IsNullOrWhiteSpace(Card.Body) ? "_(empty card)_" : Card.Body))
            </div>
        }

        @if (IsWorkColumn && CanRunStep && !IsBranchBound)
        {
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2" Class="mb-1">Branch</MudText>
            <MudAutocomplete T="string" @bind-Value="_branch"
                             Label="Branch for this card"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             SearchFunc="SearchBranches"
                             CoerceText="true" CoerceValue="true" Clearable="true"
                             MaxItems="null"
                             HelperText="Pick an existing branch or type a new one. Validated with git check-ref-format." />
            @if (BranchExists)
            {
                <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-1">
                    Work will continue on the existing branch <code>@_branch?.Trim()</code>.
                </MudText>
            }
        }

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (!_editingBody)
        {
            <MudTooltip Text="Edit Card">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Disabled="@_busy"
                               OnClick="BeginEditBody" />
            </MudTooltip>
        }
        @if (MoveTargets.Count > 0)
        {
            <MudTooltip Text="Move to column">
                <MudMenu Icon="@Icons.Material.Filled.ViewColumn"
                         Variant="Variant.Text" Disabled="@_busy">
                    @foreach (var col in MoveTargets)
                    {
                        <MudMenuItem OnClick="@(() => Move(col.DirectoryName))">@col.DisplayName</MudMenuItem>
                    }
                </MudMenu>
            </MudTooltip>
        }
        <MudTooltip Text="Delete Card">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Disabled="@_busy"
                           OnClick="DeleteCard" />
        </MudTooltip>
        @if (IsBranchBound)
        {
            <MudTooltip Text="Merge branch">
                <MudIconButton Icon="@Icons.Material.Filled.Merge"
                               Color="Color.Success"
                               Disabled="@_busy"
                               OnClick="Merge" />
            </MudTooltip>
        }
        @if (IsWorkColumn && CanRunStep)
        {
            @if (Endpoints.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Warning" Class="mr-2">
                    No endpoints configured — add one on the Endpoints page.
                </MudText>
            }
            else if (Endpoints.Count > 1)
            {
                <MudTooltip Text="Endpoint">
                <ChipDropdown Label="@(EndpointLabel(_endpointId))" Icon="@Icons.Material.Filled.Cloud">
                    @foreach (var ep in Endpoints)
                    {
                        <MudMenuItem OnClick="@(() => _endpointId = ep.Id)">
                            @(string.IsNullOrWhiteSpace(ep.Name) ? ep.DisplayLabel : ep.Name)@(ep.Id == DefaultEndpointId ? " (default)" : "")
                        </MudMenuItem>
                    }
                </ChipDropdown>
                </MudTooltip>
            }
            @if (IsBranchBound)
            {
                <MudTooltip Text="@($"Open chat on {Card.Branch}")">
                    <MudIconButton Icon="@Icons.Material.Filled.Forum"
                                   Disabled="@_busy"
                                   OnClick="OpenChat" />
                </MudTooltip>
            }
            <MudTooltip Text="@ColumnDisplayName">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@(_busy || Endpoints.Count == 0)"
                               OnClick="RunStep" />
            </MudTooltip>
        }
        else if (CanPromote)
        {
            <MudTooltip Text="@($"Move to \"{NextColumnDisplayName}\"")">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@_busy"
                               OnClick="Promote" />
            </MudTooltip>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter, EditorRequired] public BoardCard Card { get; set; } = default!;
    [Parameter, EditorRequired] public string WorkspaceRoot { get; set; } = default!;
    [Parameter] public string ColumnDisplayName { get; set; } = "";

    /// <summary>True when the card's column is a work step (has an <c>instructions.md</c>): the
    /// dialog offers a chat-backed step run. When false the column is a resting column and the
    /// dialog offers a plain promote to the next column instead (no chat).</summary>
    [Parameter] public bool IsWorkColumn { get; set; }

    /// <summary>Display name of the next column, used to label the promote action on a resting
    /// column. Null when the card is already in the last column (nothing to promote to).</summary>
    [Parameter] public string? NextColumnDisplayName { get; set; }

    [Parameter] public bool CanRunStep { get; set; }
    [Parameter] public IReadOnlyList<EndpointSettings> Endpoints { get; set; } = Array.Empty<EndpointSettings>();
    [Parameter] public Guid DefaultEndpointId { get; set; }
    [Parameter] public IReadOnlyList<string> ExistingBranches { get; set; } = Array.Empty<string>();
    [Parameter] public string PresumptiveBranch { get; set; } = "";

    /// <summary>Whether the card's <c>branch:</c> attribute points at a code branch that currently
    /// has a live worktree. False when the card has no branch, or has one in intent only (never
    /// started, merged, or deleted). When true the dialog offers merge / open-chat against that
    /// worktree; otherwise it offers promote / run a fresh branch. The board itself lives on its own
    /// worktree, so this only governs the code-branch affordances, not where the card is read from.</summary>
    [Parameter] public bool BranchWorktreeLive { get; set; }

    /// <summary>All board columns (in order), used to populate the "Move to…" picker. The card's
    /// current column is excluded at render time.</summary>
    [Parameter] public IReadOnlyList<ColumnOption> Columns { get; set; } = Array.Empty<ColumnOption>();

    /// <summary>Directory name of the column the card is currently in, so the picker can omit it.</summary>
    [Parameter] public string CurrentColumnDirectory { get; set; } = "";

    /// <summary>A move target offered by the "Move to…" picker.</summary>
    public sealed record ColumnOption(string DirectoryName, string DisplayName);

    /// <summary>What the dialog hands back to the page when the user runs a step. The page
    /// re-checks branch/worktree existence at run time, so the chosen branch is all it needs.</summary>
    public sealed record Result(Guid EndpointId, string Branch);

    /// <summary>Handed back when the user promotes a card out of a resting column. The page moves
    /// the card to the next column on disk; there is no chat run, branch, or endpoint involved.</summary>
    public sealed record Promotion;

    /// <summary>Handed back when the user wants to merge a branch-bound card's branch back into the
    /// base branch. The page resolves the branch's worktree and opens the shared merge dialog.</summary>
    public sealed record MergeRequest;

    /// <summary>Handed back when the user wants an interactive chat session on the card's branch
    /// worktree (e.g. to resolve a merge conflict or do follow-up work). The page opens/creates the
    /// worktree and navigates to a chat bound to it.</summary>
    public sealed record OpenChatRequest;

    /// <summary>Handed back when the user picks a column from the "Move to…" menu. The page relocates
    /// the card to <paramref name="ToColumnDirectory"/> — on the root board for an unbound card, or in
    /// the branch's worktree for a live-bound one — and commits the move.</summary>
    public sealed record MoveRequest(string ToColumnDirectory);

    /// <summary>Handed back when the user confirms deletion of this card. The page deletes the card
    /// file from the board worktree and commits the removal.</summary>
    public sealed record DeleteRequest;

    /// <summary>Handed back when the user changed the priority and clicked Close. The page writes
    /// the updated <c>priority:</c> frontmatter field and commits it to the board branch.</summary>
    public sealed record PriorityUpdate(CardPriority Priority);

    /// <summary>Handed back when the user edits the title and/or markdown body and clicks Save. The
    /// page writes the new title (frontmatter) and body (frontmatter otherwise preserved) and commits
    /// them to the board branch.</summary>
    public sealed record BodyUpdate(string Title, string Body);

    private bool _busy;
    private string? _error;
    private string? _branch;
    private Guid _endpointId;
    private CardPriority _priority;
    private bool _editingBody;
    private string _body = "";
    private string _title = "";

    // The card names an intended branch in its frontmatter…
    private bool HasBranchAttribute => !string.IsNullOrWhiteSpace(Card.Branch);

    // …but the binding is only *live* when that branch also has a worktree right now. A card with a
    // branch attribute whose worktree is gone (never started, merged, or deleted) effectively lives
    // on the parent board, so we treat it as unbound: promote / run-fresh, not merge/open-chat.
    private bool IsBranchBound => HasBranchAttribute && BranchWorktreeLive;

    // A resting column promotes (rather than runs) — but only an unbound card: a branch-bound card
    // lives and moves inside its worktree board, which a plain root-board file move would not touch.
    private bool CanPromote => !IsWorkColumn && !IsBranchBound && NextColumnDisplayName is not null;

    // Every column except the one the card is already in is a valid move target (forward or back).
    private IReadOnlyList<ColumnOption> MoveTargets =>
        Columns.Where(c => !string.Equals(c.DirectoryName, CurrentColumnDirectory, StringComparison.Ordinal)).ToList();

    private bool BranchExists =>
        !string.IsNullOrWhiteSpace(_branch) &&
        ExistingBranches.Any(b => string.Equals(b, _branch!.Trim(), StringComparison.Ordinal));

    protected override void OnInitialized()
    {
        // Default the (editable) branch field to the card's existing intended branch when it has one
        // but isn't live — so reworking it re-runs on the same branch unless the user changes it —
        // and otherwise to the presumptive name derived from the card id/title.
        _branch = HasBranchAttribute ? Card.Branch : PresumptiveBranch;
        _endpointId = DefaultEndpointId;
        _priority = Card.Priority;
    }

    private string EndpointLabel(Guid id)
    {
        var ep = Endpoints.FirstOrDefault(e => e.Id == id);
        if (ep is null) return "Endpoint";
        var name = string.IsNullOrWhiteSpace(ep.Name) ? ep.DisplayLabel : ep.Name;
        return id == DefaultEndpointId ? $"{name} (default)" : name;
    }

    private Task<IEnumerable<string>> SearchBranches(string? value, CancellationToken ct)
    {
        IEnumerable<string> matches = string.IsNullOrWhiteSpace(value)
            ? ExistingBranches
            : ExistingBranches.Where(b => b.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(matches);
    }

    private async Task RunStep()
    {
        _error = null;

        // A bound card always reuses its branch; an unbound card uses the (editable) field.
        var branch = IsBranchBound ? Card.Branch! : _branch?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(branch))
        {
            _error = "A branch name is required to run a step.";
            return;
        }

        var exists = ExistingBranches.Any(b => string.Equals(b, branch, StringComparison.Ordinal));

        // Only new branches need ref-format validation; existing names are already valid.
        if (!exists && !IsBranchBound)
        {
            _busy = true;
            try
            {
                if (!await Git.CheckRefFormatAsync(branch, CancellationToken.None))
                {
                    _error = $"\"{branch}\" is not a valid git branch name.";
                    return;
                }
            }
            finally
            {
                _busy = false;
            }
        }

        Dialog.Close(DialogResult.Ok(new Result(_endpointId, branch)));
    }

    private void Promote() => Dialog.Close(DialogResult.Ok(new Promotion()));

    private void Move(string toColumnDirectory) => Dialog.Close(DialogResult.Ok(new MoveRequest(toColumnDirectory)));

    private void Merge() => Dialog.Close(DialogResult.Ok(new MergeRequest()));

    private void OpenChat() => Dialog.Close(DialogResult.Ok(new OpenChatRequest()));

    private async Task DeleteCard()
    {
        var parameters = new DialogParameters
        {
            ["Message"] = $"Delete card #{Card.Id} \"{Card.Title}\"?",
            ["YesText"] = "Delete",
            ["CancelText"] = "Cancel",
        };
        var dialog = await Dialogs.ShowAsync<MudMessageBox>("Delete card", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not true) return;
        Dialog.Close(DialogResult.Ok(new DeleteRequest()));
    }

    private void SetPriority(CardPriority priority)
    {
        if (priority != Card.Priority)
            Dialog.Close(DialogResult.Ok(new PriorityUpdate(priority)));
    }

    private void BeginEditBody()
    {
        _body = (Card.Body ?? string.Empty).Trim();
        _title = Card.Title;
        _editingBody = true;
    }

    private void CancelEditBody() => _editingBody = false;

    // Mirrors SetPriority: a no-op edit just drops back to preview, a real change closes the dialog
    // so the page can run the shared busy/commit/refresh workflow.
    private void SaveBody()
    {
        var trimmedBody = (_body ?? string.Empty).Trim();
        var trimmedTitle = (_title ?? string.Empty).Trim();
        var bodyChanged = !string.Equals(trimmedBody, (Card.Body ?? string.Empty).Trim(), StringComparison.Ordinal);
        // An empty title would slug to nothing and leave the card unlabelled, so keep the old one.
        var titleChanged = trimmedTitle.Length > 0
                           && !string.Equals(trimmedTitle, Card.Title.Trim(), StringComparison.Ordinal);
        if (!bodyChanged && !titleChanged)
        {
            _editingBody = false;
            return;
        }
        Dialog.Close(DialogResult.Ok(new BodyUpdate(titleChanged ? trimmedTitle : Card.Title, trimmedBody)));
    }

    private void Close() => Dialog.Cancel();
}
