@namespace Yamca.Web.Components.Board
@using Yamca.Agent.Board
@using Yamca.Agent.Settings
@using Yamca.Web.Services
@inject GitService Git
@inject IDialogService Dialogs
@inject BoardStore BoardStore

<MudDialog>
    <TitleContent>
        <div class="d-flex flex-column" style="gap: 2px; width: 100%;">
            <div class="d-flex align-center">
                <MudText Typo="Typo.h6">@Card.Title</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Class="ml-auto" OnClick="Close" />
            </div>
            <div class="d-flex align-center" style="gap: 6px;">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">#@Card.Id</MudChip>
                <ChipDropdown Label="@(_priority switch { CardPriority.High => "↑ High", CardPriority.Low => "↓ Low", _ => "Normal" })"
                              Icon="@Icons.Material.Filled.Flag"
                              Color="@(_priority == CardPriority.High ? Color.Warning : Color.Default)"
                              Style="@(_priority == CardPriority.Low ? "opacity:0.6;" : "")">
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.High))">↑ High</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Normal))">Normal</MudMenuItem>
                    <MudMenuItem OnClick="@(() => SetPriority(CardPriority.Low))">↓ Low</MudMenuItem>
                </ChipDropdown>
                @if (IsBranchBound)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.AccountTree">@Card.Branch</MudChip>
                }
                else if (HasBranchAttribute)
                {
                    <MudTooltip Text="Branch doesn't exist or isn't loaded into a worktree">
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.AccountTree" Style="opacity:0.5;">@Card.Branch</MudChip>
                    </MudTooltip>
                }
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="false" Border="false" ApplyEffectsToContainer="true"
                 ActivePanelIndexChanged="OnTabChanged" Class="mb-1">
            <MudTabPanel Text="Details">
                @if (_editingBody)
                {
                    <MudTextField @bind-Value="_title" T="string"
                                  Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Immediate="true" Class="mb-2" />
                    <MudTextField @bind-Value="_body" T="string"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Lines="16" Immediate="true" AutoFocus="true"
                                  HelperText="Plain markdown — switch back to preview by saving or cancelling."
                                  Class="yamca-body-editor" />
                    <div class="d-flex mt-2" style="gap: 8px;">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="@_busy" OnClick="SaveBody">Save</MudButton>
                        <MudButton Variant="Variant.Text" Disabled="@_busy" OnClick="CancelEditBody">Cancel</MudButton>
                    </div>
                }
                else
                {
                    <div class="yamca-markdown">
                        @((MarkupString)MarkdownRenderer.ToHtml(string.IsNullOrWhiteSpace(Card.Body) ? "_(empty card)_" : Card.Body))
                    </div>
                }

                @* The card's tasks — its child checklist, kept off the body. Unlike the other edits in
                   this dialog (priority/body/branch close and hand a result back to the page), task
                   changes persist straight through BoardStore and update the list in place so the modal
                   stays open; the page's refresh on close repaints the kanban progress badge. *@
                <MudDivider Class="my-2" />
                <div class="d-flex align-center mb-1" style="gap: 6px;">
                    <MudText Typo="Typo.subtitle2">Tasks</MudText>
                    @if (_tasks.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Default">@_tasks.Count(t => t.Done)/@_tasks.Count</MudText>
                    }
                </div>
                @foreach (var task in _tasks)
                {
                    var t = task;
                    <div class="d-flex align-center" style="gap: 4px;">
                        <MudCheckBox T="bool" Value="t.Done" Dense="true" Color="Color.Primary"
                                     Disabled="@_busy" ValueChanged="@((bool v) => ToggleTask(t, v))" />
                        @if (_editingTaskId == t.Id)
                        {
                            <MudTextField @bind-Value="_taskEditText" T="string" Variant="Variant.Text"
                                          Margin="Margin.Dense" Immediate="true" AutoFocus="true"
                                          Class="flex-grow-1" OnKeyDown="@(e => OnTaskEditKey(e, t))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary"
                                           Disabled="@_busy" OnClick="@(() => SaveTaskEdit(t))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Disabled="@_busy" OnClick="CancelTaskEdit" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="flex-grow-1"
                                     Style="@(t.Done ? "text-decoration: line-through; opacity: 0.6;" : "")">@t.Text</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Disabled="@_busy" OnClick="@(() => BeginEditTask(t))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           Disabled="@_busy" OnClick="@(() => RemoveTask(t))" />
                        }
                    </div>
                }
                <div class="d-flex align-center mt-1" style="gap: 4px;">
                    <MudTextField @bind-Value="_newTaskText" T="string" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Placeholder="Add a task…" Immediate="true"
                                  Class="flex-grow-1" OnKeyDown="OnNewTaskKey" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                                   Disabled="@(_busy || string.IsNullOrWhiteSpace(_newTaskText))" OnClick="AddTask" />
                </div>

                @* The branch is editable on any card that isn't already bound to a live worktree —
                   including cards in resting columns — so its branch can be decided up front. A
                   change is persisted on close; the worktree itself is only created on first run/chat. *@
                @if (!IsBranchBound)
                {
                    <MudDivider Class="my-2" />
                    <MudAutocomplete T="string" @bind-Value="_branch"
                                     Label="Branch"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     SearchFunc="SearchBranches"
                                     CoerceText="true" CoerceValue="true" Clearable="true"
                                     MaxItems="null"
                                     HelperText="Pick an existing branch or type a new one. Validated with git check-ref-format." />
                    @if (BranchExists)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-1">
                            Work will continue on the existing branch <code>@_branch?.Trim()</code>.
                        </MudText>
                    }
                }

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_error</MudAlert>
                }
            </MudTabPanel>

            @* Artifacts are the card's named step outputs (plan, analysis, notes, logs) — kept off the
               body so the body stays the original ask. Read-only here; the agent writes them via
               board_set_artifact. The tab only appears when the card has at least one. *@
            @if (HasArtifacts)
            {
                <MudTabPanel Text="@($"Artifacts ({Card.Artifacts.Count})")">
                    @foreach (var artifact in Card.Artifacts)
                    {
                        <div class="mb-4">
                            <div class="d-flex align-center" style="gap: 6px;">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Icon="@Icons.Material.Filled.Description">@artifact.Kind</MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Default">
                                    updated @artifact.UpdatedAt.ToLocalTime().ToString("g")
                                </MudText>
                            </div>
                            <div class="yamca-markdown mt-1">
                                @((MarkupString)MarkdownRenderer.ToHtml(
                                    string.IsNullOrWhiteSpace(artifact.Content) ? "_(empty artifact)_" : artifact.Content))
                            </div>
                        </div>
                    }
                </MudTabPanel>
            }

            @if (HasWorktree)
            {
                <MudTabPanel Text="Changes">
                    @* Mount the view only once the tab is first opened so opening the dialog stays
                       cheap when the diff is never viewed. *@
                    @if (_changesTabOpened)
                    {
                        <WorktreeChangesView WorktreePath="@(WorktreePath!)" BaseBranch="@BaseBranch"
                                             BranchLabel="@Card.Branch" />
                    }
                </MudTabPanel>
            }
        </MudTabs>
    </DialogContent>
    <DialogActions>
        @if (!_editingBody)
        {
            <MudTooltip Text="Edit Card">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Disabled="@_busy"
                               OnClick="BeginEditBody" />
            </MudTooltip>
        }
        @if (MoveTargets.Count > 0)
        {
            <MudTooltip Text="Move to column">
                <MudMenu Icon="@Icons.Material.Filled.ViewColumn"
                         Variant="Variant.Text" Disabled="@_busy">
                    @foreach (var col in MoveTargets)
                    {
                        <MudMenuItem OnClick="@(() => Move(col.Id))">@col.DisplayName</MudMenuItem>
                    }
                </MudMenu>
            </MudTooltip>
        }
        <MudTooltip Text="Delete Card">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Disabled="@_busy"
                           OnClick="DeleteCard" />
        </MudTooltip>
        @if (IsBranchBound)
        {
            <MudTooltip Text="Merge branch">
                <MudIconButton Icon="@Icons.Material.Filled.Merge"
                               Color="Color.Success"
                               Disabled="@_busy"
                               OnClick="Merge" />
            </MudTooltip>
        }
        @* Open chat is offered for any card with a branch (not just branch-bound ones with a live
           worktree): the page creates the branch/worktree on demand when none exists yet. It only
           needs a free chat slot, so it stands apart from the work-column step affordances below. *@
        @if (HasBranchAttribute)
        {
            <MudTooltip Text="@($"Open chat on {Card.Branch}")">
                <MudIconButton Icon="@Icons.Material.Filled.Forum"
                               Disabled="@_busy"
                               OnClick="OpenChat" />
            </MudTooltip>
        }
        @if (IsWorkColumn)
        {
            @if (Endpoints.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Warning" Class="mr-2">
                    No endpoints configured — add one on the Endpoints page.
                </MudText>
            }
            else if (Endpoints.Count > 1)
            {
                <MudTooltip Text="Endpoint">
                <ChipDropdown Label="@(EndpointLabel(_endpointId))" Icon="@Icons.Material.Filled.Cloud">
                    @foreach (var ep in Endpoints)
                    {
                        <MudMenuItem OnClick="@(() => _endpointId = ep.Id)">
                            @(string.IsNullOrWhiteSpace(ep.Name) ? ep.DisplayLabel : ep.Name)@(ep.Id == DefaultEndpointId ? " (default)" : "")
                        </MudMenuItem>
                    }
                </ChipDropdown>
                </MudTooltip>
            }
            <MudTooltip Text="@ColumnDisplayName">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@(_busy || Endpoints.Count == 0)"
                               OnClick="RunStep" />
            </MudTooltip>
        }
        else if (CanPromote)
        {
            <MudTooltip Text="@($"Move to \"{NextColumnDisplayName}\"")">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@_busy"
                               OnClick="Promote" />
            </MudTooltip>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter, EditorRequired] public BoardCard Card { get; set; } = default!;
    [Parameter] public string ColumnDisplayName { get; set; } = "";

    /// <summary>True when the card's column is a work step (has step instructions): the
    /// dialog offers a chat-backed step run. When false the column is a resting column and the
    /// dialog offers a plain promote to the next column instead (no chat).</summary>
    [Parameter] public bool IsWorkColumn { get; set; }

    /// <summary>Display name of the next column, used to label the promote action on a resting
    /// column. Null when the card is already in the last column (nothing to promote to).</summary>
    [Parameter] public string? NextColumnDisplayName { get; set; }

    [Parameter] public IReadOnlyList<EndpointSettings> Endpoints { get; set; } = Array.Empty<EndpointSettings>();
    [Parameter] public Guid DefaultEndpointId { get; set; }
    [Parameter] public IReadOnlyList<string> ExistingBranches { get; set; } = Array.Empty<string>();
    [Parameter] public string PresumptiveBranch { get; set; } = "";

    /// <summary>Filesystem path of the card branch's live code worktree, or null when the card has no
    /// live worktree (unbound, or its branch was never started / since merged / deleted). When set,
    /// the dialog offers a Changes tab diffing the worktree against where the branch forked from
    /// <see cref="BaseBranch"/>.</summary>
    [Parameter] public string? WorktreePath { get; set; }

    /// <summary>The base branch the worktree forked from, used to resolve the merge base for the
    /// Changes tab's diff. Only meaningful when <see cref="WorktreePath"/> is set.</summary>
    [Parameter] public string BaseBranch { get; set; } = "";

    /// <summary>Whether the card's <c>branch:</c> attribute points at a code branch that currently
    /// has a live worktree. False when the card has no branch, or has one in intent only (never
    /// started, merged, or deleted). When true the dialog offers merge / open-chat against that
    /// worktree; otherwise it offers promote / run a fresh branch. The board itself lives on its own
    /// worktree, so this only governs the code-branch affordances, not where the card is read from.</summary>
    [Parameter] public bool BranchWorktreeLive { get; set; }

    /// <summary>All board columns (in order), used to populate the "Move to…" picker. The card's
    /// current column is excluded at render time.</summary>
    [Parameter] public IReadOnlyList<ColumnOption> Columns { get; set; } = Array.Empty<ColumnOption>();

    /// <summary>Id of the column the card is currently in, so the picker can omit it.</summary>
    [Parameter] public string CurrentColumnId { get; set; } = "";

    /// <summary>A move target offered by the "Move to…" picker.</summary>
    public sealed record ColumnOption(string Id, string DisplayName);

    /// <summary>What the dialog hands back to the page when the user runs a step. The page
    /// re-checks branch/worktree existence at run time, so the chosen branch is all it needs.</summary>
    public sealed record Result(Guid EndpointId, string Branch);

    /// <summary>Handed back when the user promotes a card out of a resting column. The page moves
    /// the card to the next column; there is no chat run, branch, or endpoint involved.</summary>
    public sealed record Promotion;

    /// <summary>Handed back when the user wants to merge a branch-bound card's branch back into the
    /// base branch. The page resolves the branch's worktree and opens the shared merge dialog.</summary>
    public sealed record MergeRequest;

    /// <summary>Handed back when the user wants an interactive chat session on the card's branch
    /// worktree (e.g. to resolve a merge conflict or do follow-up work). The page opens/creates the
    /// worktree and navigates to a chat bound to it.</summary>
    public sealed record OpenChatRequest;

    /// <summary>Handed back when the user picks a column from the "Move to…" menu. The page moves
    /// the card to <paramref name="ToColumnId"/>.</summary>
    public sealed record MoveRequest(string ToColumnId);

    /// <summary>Handed back when the user confirms deletion of this card. The page deletes the card
    /// file from the board.</summary>
    public sealed record DeleteRequest;

    /// <summary>Handed back when the user changed the priority and clicked Close. The page saves
    /// the updated priority on the card.</summary>
    public sealed record PriorityUpdate(CardPriority Priority);

    /// <summary>Handed back when the user edits the title and/or markdown body and clicks Save. The
    /// page saves the new title and body (the card's prose description). Tasks are edited separately,
    /// in place, and are not part of this result.</summary>
    public sealed record BodyUpdate(string Title, string Body);

    /// <summary>Handed back when the user changed the branch field (on a card that isn't bound to a
    /// live worktree) and closed the dialog. The page saves the card's branch; no
    /// worktree is created — that still waits for the first run/chat on the card.</summary>
    public sealed record BranchUpdate(string Branch);

    private bool _busy;
    private string? _error;
    private string? _branch;
    private Guid _endpointId;
    private CardPriority _priority;
    private bool _editingBody;
    private string _body = "";
    private string _title = "";

    // The card's task checklist, managed in place (persisted straight through BoardStore) so the modal
    // stays open across edits. Seeded from the card at open; reloaded from the store after each change.
    private List<TaskItem> _tasks = new();
    private int? _editingTaskId;
    private string _taskEditText = "";
    private string _newTaskText = "";

    // Changes tab: the embedded view loads lazily the first time the tab is opened, so opening the
    // dialog stays cheap when the diff is never viewed.
    private bool HasWorktree => !string.IsNullOrEmpty(WorktreePath);
    private bool _changesTabOpened;

    // The Artifacts tab sits between Details (0) and Changes, and only renders when the card has
    // artifacts — so the Changes tab's index shifts by one when it is present.
    private bool HasArtifacts => Card.Artifacts.Count > 0;
    private int ChangesTabIndex => HasArtifacts ? 2 : 1;

    // The card names an intended branch…
    private bool HasBranchAttribute => !string.IsNullOrWhiteSpace(Card.Branch);

    // …but the binding is only *live* when that branch also has a worktree right now. A card with a
    // branch attribute whose worktree is gone (never started, merged, or deleted) effectively lives
    // on the parent board, so we treat it as unbound: promote / run-fresh, not merge/open-chat.
    private bool IsBranchBound => HasBranchAttribute && BranchWorktreeLive;

    // A resting column promotes (rather than runs) — but only an unbound card: a branch-bound card
    // lives and moves inside its worktree board, which a plain root-board file move would not touch.
    private bool CanPromote => !IsWorkColumn && !IsBranchBound && NextColumnDisplayName is not null;

    // Every column except the one the card is already in is a valid move target (forward or back).
    private IReadOnlyList<ColumnOption> MoveTargets =>
        Columns.Where(c => !string.Equals(c.Id, CurrentColumnId, StringComparison.Ordinal)).ToList();

    private bool BranchExists =>
        !string.IsNullOrWhiteSpace(_branch) &&
        ExistingBranches.Any(b => string.Equals(b, _branch!.Trim(), StringComparison.Ordinal));

    protected override void OnInitialized()
    {
        // Default the (editable) branch field to the card's existing intended branch when it has one
        // but isn't live — so reworking it re-runs on the same branch unless the user changes it —
        // and otherwise to the presumptive name derived from the card id/title.
        _branch = HasBranchAttribute ? Card.Branch : PresumptiveBranch;
        _endpointId = DefaultEndpointId;
        _priority = Card.Priority;
        _tasks = Card.Tasks.ToList();
    }

    // Task edits persist immediately and keep the modal open, so after each one we re-read the card's
    // tasks from the store — this also picks up the one-time id normalization a legacy card gets on its
    // first mutation, keeping the displayed ids in step with what's persisted.
    private async Task ReloadTasksAsync()
    {
        var snapshot = await BoardStore.ReadAsync(CancellationToken.None);
        _tasks = snapshot.FindCard(Card.Id)?.Tasks.ToList() ?? _tasks;
    }

    private async Task ToggleTask(TaskItem task, bool done)
    {
        _busy = true;
        try { await BoardStore.SetTaskDoneAsync(Card.Id, task.Id, done, CancellationToken.None); await ReloadTasksAsync(); }
        finally { _busy = false; }
    }

    private void BeginEditTask(TaskItem task)
    {
        _editingTaskId = task.Id;
        _taskEditText = task.Text;
    }

    private void CancelTaskEdit()
    {
        _editingTaskId = null;
        _taskEditText = "";
    }

    private async Task SaveTaskEdit(TaskItem task)
    {
        var text = (_taskEditText ?? string.Empty).Trim();
        if (text.Length == 0 || string.Equals(text, task.Text, StringComparison.Ordinal))
        {
            CancelTaskEdit();
            return;
        }
        _busy = true;
        try { await BoardStore.UpdateTaskTextAsync(Card.Id, task.Id, text, CancellationToken.None); await ReloadTasksAsync(); }
        finally { _busy = false; }
        CancelTaskEdit();
    }

    private async Task RemoveTask(TaskItem task)
    {
        _busy = true;
        try { await BoardStore.RemoveTaskAsync(Card.Id, task.Id, CancellationToken.None); await ReloadTasksAsync(); }
        finally { _busy = false; }
        if (_editingTaskId == task.Id) CancelTaskEdit();
    }

    private async Task AddTask()
    {
        var text = (_newTaskText ?? string.Empty).Trim();
        if (text.Length == 0) return;
        _busy = true;
        try { await BoardStore.AddTasksAsync(Card.Id, new[] { text }, CancellationToken.None); await ReloadTasksAsync(); }
        finally { _busy = false; }
        _newTaskText = "";
    }

    private async Task OnNewTaskKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddTask();
    }

    private async Task OnTaskEditKey(KeyboardEventArgs e, TaskItem task)
    {
        if (e.Key == "Enter") await SaveTaskEdit(task);
        else if (e.Key == "Escape") CancelTaskEdit();
    }

    // Mount the Changes view the first time its tab is opened; the view loads its own data on init.
    // Its index depends on whether the Artifacts tab is present (see ChangesTabIndex).
    private void OnTabChanged(int index)
    {
        if (index == ChangesTabIndex && HasWorktree) _changesTabOpened = true;
    }

    private string EndpointLabel(Guid id)
    {
        var ep = Endpoints.FirstOrDefault(e => e.Id == id);
        if (ep is null) return "Endpoint";
        var name = string.IsNullOrWhiteSpace(ep.Name) ? ep.DisplayLabel : ep.Name;
        return id == DefaultEndpointId ? $"{name} (default)" : name;
    }

    private Task<IEnumerable<string>> SearchBranches(string? value, CancellationToken ct)
    {
        IEnumerable<string> matches = string.IsNullOrWhiteSpace(value)
            ? ExistingBranches
            : ExistingBranches.Where(b => b.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(matches);
    }

    private async Task RunStep()
    {
        _error = null;

        // A bound card always reuses its branch; an unbound card uses the (editable) field.
        var branch = IsBranchBound ? Card.Branch! : _branch?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(branch))
        {
            _error = "A branch name is required to run a step.";
            return;
        }

        var exists = ExistingBranches.Any(b => string.Equals(b, branch, StringComparison.Ordinal));

        // Only new branches need ref-format validation; existing names are already valid.
        if (!exists && !IsBranchBound)
        {
            _busy = true;
            try
            {
                if (!await Git.CheckRefFormatAsync(branch, CancellationToken.None))
                {
                    _error = $"\"{branch}\" is not a valid git branch name.";
                    return;
                }
            }
            finally
            {
                _busy = false;
            }
        }

        Dialog.Close(DialogResult.Ok(new Result(_endpointId, branch)));
    }

    private void Promote() => Dialog.Close(DialogResult.Ok(new Promotion()));

    private void Move(string toColumnId) => Dialog.Close(DialogResult.Ok(new MoveRequest(toColumnId)));

    private void Merge() => Dialog.Close(DialogResult.Ok(new MergeRequest()));

    private void OpenChat() => Dialog.Close(DialogResult.Ok(new OpenChatRequest()));

    private async Task DeleteCard()
    {
        var parameters = new DialogParameters
        {
            ["Message"] = $"Delete card #{Card.Id} \"{Card.Title}\"?",
            ["YesText"] = "Delete",
            ["CancelText"] = "Cancel",
        };
        var dialog = await Dialogs.ShowAsync<MudMessageBox>("Delete card", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not true) return;
        Dialog.Close(DialogResult.Ok(new DeleteRequest()));
    }

    private void SetPriority(CardPriority priority)
    {
        if (priority != Card.Priority)
            Dialog.Close(DialogResult.Ok(new PriorityUpdate(priority)));
    }

    private void BeginEditBody()
    {
        _body = (Card.Body ?? string.Empty).Trim();
        _title = Card.Title;
        _editingBody = true;
    }

    private void CancelEditBody() => _editingBody = false;

    // Mirrors SetPriority: a no-op edit just drops back to preview, a real change closes the dialog
    // so the page can run the shared busy/commit/refresh workflow.
    private void SaveBody()
    {
        var trimmedBody = (_body ?? string.Empty).Trim();
        var trimmedTitle = (_title ?? string.Empty).Trim();
        var bodyChanged = !string.Equals(trimmedBody, (Card.Body ?? string.Empty).Trim(), StringComparison.Ordinal);
        // An empty title would slug to nothing and leave the card unlabelled, so keep the old one.
        var titleChanged = trimmedTitle.Length > 0
                           && !string.Equals(trimmedTitle, Card.Title.Trim(), StringComparison.Ordinal);
        if (!bodyChanged && !titleChanged)
        {
            _editingBody = false;
            return;
        }
        Dialog.Close(DialogResult.Ok(new BodyUpdate(titleChanged ? trimmedTitle : Card.Title, trimmedBody)));
    }

    // Closing the dialog persists an edited branch on an unbound card (the field has no explicit
    // Save, mirroring how priority commits on close). A new name is ref-format validated first; an
    // unchanged or blank branch just cancels. Bound cards never reach the editable field, so their
    // close is always a plain cancel.
    private async Task Close()
    {
        if (!IsBranchBound)
        {
            var newBranch = _branch?.Trim() ?? "";
            var current = Card.Branch?.Trim() ?? "";
            if (newBranch.Length > 0 && !string.Equals(newBranch, current, StringComparison.Ordinal))
            {
                var exists = ExistingBranches.Any(b => string.Equals(b, newBranch, StringComparison.Ordinal));
                if (!exists)
                {
                    _busy = true;
                    try
                    {
                        if (!await Git.CheckRefFormatAsync(newBranch, CancellationToken.None))
                        {
                            _error = $"\"{newBranch}\" is not a valid git branch name.";
                            return;
                        }
                    }
                    finally
                    {
                        _busy = false;
                    }
                }
                Dialog.Close(DialogResult.Ok(new BranchUpdate(newBranch)));
                return;
            }
        }
        Dialog.Cancel();
    }
}
