<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">
            All @Slots.Count chat slots are in use. Pick one to close so the saved chat can
            open in its place. The closed chat's history is kept and stays in Recent Chats.
        </MudText>
        <MudList T="int" SelectedValue="_selected" SelectedValueChanged="@(v => _selected = v)" Dense="true">
            @foreach (var slot in Slots)
            {
                <MudListItem T="int" Value="@slot.Id" Icon="@Icons.Material.Filled.Chat">
                    @slot.Label
                </MudListItem>
            }
        </MudList>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirm"
                   Disabled="@(_selected == 0)">
            Close & replace
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>One choice per open chat slot.</summary>
    public sealed record SlotChoice(int Id, string Label);

    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter, EditorRequired] public IReadOnlyList<SlotChoice> Slots { get; set; } = Array.Empty<SlotChoice>();

    // Slot ids start at 1, so 0 is a safe "nothing picked" sentinel.
    private int _selected;

    protected override void OnInitialized()
    {
        if (Slots.Count > 0) _selected = Slots[0].Id;
    }

    private void Cancel() => Dialog.Cancel();

    private void Confirm() => Dialog.Close(DialogResult.Ok(_selected));
}
