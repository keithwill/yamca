    private Task OnCloseClicked() => OnClose.InvokeAsync();

    // The X fully unloads the chat (vs. the minus, which only hides this pane). Mirrors the
    // direct Manager.Close used by the merge/delete handlers; the grid reflows on its own.
    private void OnCloseChatClicked() => Manager.Close(Chat.Id);

    // Seed the draft with the current custom name only — an empty box for a still-derived title
    // invites the user to type their own rather than editing a generated summary they didn't write.
    private void BeginTitleEdit()
    {
        if (Chat.IsReadOnly) return;
        _titleDraft = Chat.CustomTitle ?? "";
        _editingTitle = true;
        _focusTitleInput = true;
    }

    // Commit is idempotent: Enter, the check button, and blur (genuine click-away) all land here,
    // and the guard makes the redundant calls no-ops. Rename() trims, treats empty as "clear the
    // override", and skips work when nothing changed.
    private void CommitTitleEdit()
    {
        if (!_editingTitle) return;
        _editingTitle = false;
        Chat.Rename(_titleDraft);
    }

    private void CancelTitleEdit() => _editingTitle = false;

    private void OnTitleEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") CommitTitleEdit();
        else if (e.Key == "Escape") CancelTitleEdit();
    }

    private string ContextBadgeText()
    {
        var used = Chat.CurrentContextTokens.ToString("N0");
        return Chat.MaxContextTokens is int max
            ? $"{used} / {max:N0} tokens"
            : $"~{used} tokens";
    }

    private string ContextBadgeTooltip()
    {
        if (Chat.MaxContextTokens is int max)
        {
            var pct = max > 0 ? (Chat.CurrentContextTokens * 100.0 / max).ToString("0.0") : "0";
            var src = Chat.MaxContextSource ?? "server";
            return $"{pct}% of context used. Max from {src}.";
        }
        return "Estimated context size (chars / 4). Backend did not report a max.";
    }

    private async Task SafeInvokeAsync(string identifier, params object?[] args)
    {
        try
        {
            await JS.InvokeVoidAsync(identifier, args);
        }
        catch (JSDisconnectedException) { /* circuit gone */ }
        catch (TaskCanceledException)   { /* tab closing */ }
    }

    public void Dispose()
    {
        if (_subscribed is not null) _subscribed.Changed -= OnChanged;
        Subagents.Changed -= OnSubagentsChanged;
        _selfRef?.Dispose();
    }
}
