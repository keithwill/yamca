    // The runner stamps each subagent run with the launching chat's id (ChatViewModel.Id via
    // AgentLoopOptions.OwnerId); match that here so this tile only sees its own runs.
    private string SubagentOwnerId => Chat.Id.ToString();

    private async Task OpenSubagentSessions()
    {
        var parameters = new DialogParameters { ["OwnerId"] = SubagentOwnerId };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await Dialogs.ShowAsync<SubagentSessionsDialog>("Subagent sessions", parameters, options);
