    private static string FormatDiagnostics(IReadOnlyList<DiagnosticEntry> entries)
    {
        var sb = new StringBuilder();
        foreach (var e in entries)
        {
            sb.Append('[').Append(e.Seq.ToString("D4")).Append("] ")
              .Append(e.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")).Append("  ")
              .Append(e.Category.ToString().ToUpperInvariant().PadRight(7)).Append("  ")
              .AppendLine(e.Message);
        }
        return sb.ToString();
    }

    private string FormatDiagnostics() => FormatDiagnostics(_diagEntries);

    private async Task CopyDiagnostics()
    {
        if (_diagEntries.Count == 0) return;
        await SafeInvokeAsync("yamcaChat.copyText", FormatDiagnostics());
        Snackbar.Add("Diagnostic log copied to clipboard.", Severity.Normal);
    }

