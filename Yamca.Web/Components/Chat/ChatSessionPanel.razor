@implements IDisposable
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.Text
@using Yamca.Agent.Chat
@using Yamca.Agent.Settings
@using Yamca.Agent.Workspace
@using Yamca.Web.Components.Branching
@using Yamca.Web.Components.Subagents
@using WorkspaceImpl = Yamca.Agent.Workspace.Workspace

<div class="yamca-page">
    @if (ShowHeader)
    {
        <div class="yamca-tile-header">
            <span class="yamca-tile-title" title="@TileTitle">@TileTitle</span>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="OnCloseClicked"
                           aria-label="Close chat" />
        </div>
    }

    @if (Chat.IsReadOnly)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="ma-2">
            This chat's worktree no longer exists — viewing history only.
        </MudAlert>
    }

    <div class="yamca-input-dock">
        <div class="@ComposerClass" @ref="_composer">
            @if (Chat.YoloMode)
            {
                <div class="yamca-yolo-banner">
                    <MudIcon Icon="@Icons.Material.Filled.Whatshot" Size="Size.Small" />
                    <span>YOLO mode on — permission checks are skipped for this session.</span>
                </div>
            }
            <MudTextField @bind-Value="_prompt" T="string" Placeholder="Enter a prompt..."
                          Lines="3" Variant="Variant.Text" Immediate="true"
                          Class="yamca-composer-input"
                          OnKeyDown="OnKeyDown" Disabled="@(Chat.IsBusy || Chat.IsReadOnly)" />
            <div class="yamca-composer-toolbar">
                <div class="yamca-composer-left">
                    <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                                   FilesChanged="OnFilesChanged" MaximumFileCount="20"
                                   Accept="@AttachAccept">
                        <CustomContent Context="fileUpload">
                            <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@(Chat.IsBusy || Chat.IsReadOnly)"
                                           OnClick="@(() => fileUpload.OpenFilePickerAsync())"
                                           aria-label="Attach file" />
                        </CustomContent>
                        <SelectedTemplate></SelectedTemplate>
                    </MudFileUpload>
                    @if (Session.Endpoints.Items.Count > 1)
                    {
                        <MudTooltip Text="@EndpointButtonTooltip()">
                            <span>
                                <MudIconButton Icon="@Icons.Material.Filled.Cloud"
                                               Color="Color.Default" Variant="Variant.Text"
                                               Size="Size.Small"
                                               Disabled="@(Chat.IsBusy || Chat.IsEndpointLocked || Chat.IsReadOnly)"
                                               OnClick="OnEndpointPickerClicked"
                                               aria-label="Select endpoint" />
                            </span>
                        </MudTooltip>
                    }
                    <MudTooltip Text="@BranchTooltip">
                        <span>
                            <MudIconButton Icon="@Icons.Material.Filled.CallSplit"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@(Chat.IsBusy || Chat.IsGitRepository != true || Chat.IsReadOnly)"
                                           OnClick="OnBranchClicked"
                                           aria-label="Branch Code" />
                        </span>
                    </MudTooltip>
                    <MudTooltip Text="Compact context now…">
                        <span>
                            <MudIconButton Icon="@Icons.Material.Filled.UnfoldLess"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@(Chat.IsBusy || Chat.Turns.Count == 0 || Chat.IsReadOnly)"
                                           OnClick="OpenCompactDialog"
                                           aria-label="Compact context" />
                        </span>
                    </MudTooltip>
                    <MudTooltip Text="Diagnostic log — endpoint &amp; session events">
                        <span>
                            <MudIconButton Icon="@Icons.Material.Filled.BugReport"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           OnClick="OpenDiagnosticsDialog"
                                           aria-label="Diagnostic log" />
                        </span>
                    </MudTooltip>
                    <MudTooltip Text="View raw context — exact request sent to the LLM">
                        <span>
                            <MudIconButton Icon="@Icons.Material.Filled.DataObject"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           OnClick="OpenContextDialog"
                                           aria-label="View raw context" />
                        </span>
                    </MudTooltip>
                    <MudTooltip Text="Subagent sessions — watch delegated tasks">
                        <span>
                            <MudIconButton Icon="@Icons.Material.Filled.AccountTree"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@(!Subagents.HasAnyFor(SubagentOwnerId))"
                                           OnClick="OpenSubagentSessions"
                                           aria-label="Subagent sessions" />
                        </span>
                    </MudTooltip>
                    <MudTooltip Text="YOLO Mode - Permission checks are skipped">
                        <span>
                            <MudToggleIconButton Toggled="Chat.YoloMode"
                                                 ToggledChanged="@((bool _) => Chat.ToggleYoloMode())"
                                                 Icon="@Icons.Material.Filled.Whatshot"
                                                 ToggledIcon="@Icons.Material.Filled.Whatshot"
                                                 Color="Color.Default"
                                                 ToggledColor="Color.Warning"
                                                 Variant="Variant.Text"
                                                 Size="Size.Small"
                                                 Disabled="@Chat.IsReadOnly"
                                                 aria-label="Toggle YOLO mode" />
                        </span>
                    </MudTooltip>
                    @if (Chat.WorktreeInfo is not null)
                    {
                        <MudTooltip Text="Merge branch">
                            <MudIconButton Icon="@Icons.Material.Filled.Merge"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@IsBranchOpBusy()"
                                           OnClick="OnMergeClicked"
                                           aria-label="Merge branch" />
                        </MudTooltip>
                        <MudTooltip Text="Delete branch & worktree">
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                           Color="Color.Default" Variant="Variant.Text"
                                           Size="Size.Small"
                                           Disabled="@IsBranchOpBusy()"
                                           OnClick="OnDeleteBranchClicked"
                                           aria-label="Delete branch and worktree" />
                        </MudTooltip>
                        @if (_diffStat is { IsEmpty: false } stat)
                        {
                            <MudTooltip Text="@($"{DiffStatTooltip(stat)} — click to view")">
                                <button type="button" class="yamca-diffstat-badge"
                                        aria-label="@($"{DiffStatTooltip(stat)} — click to view")"
                                        @onclick="OpenChangesDialog">
                                    <span class="yamca-diffstat-files">@stat.FilesChanged @(stat.FilesChanged == 1 ? "file" : "files")</span>
                                    <span class="yamca-diffstat-add">+@stat.Insertions</span>
                                    <span class="yamca-diffstat-del">−@stat.Deletions</span>
                                    @if (stat.UncommittedFiles > 0)
                                    {
                                        <span class="yamca-diffstat-dot">·</span>
                                        <span class="yamca-diffstat-uncommitted">@stat.UncommittedFiles uncommitted</span>
                                    }
                                </button>
                            </MudTooltip>
                        }
                    }
                    @foreach (var att in _attachments)
                    {
                        @if (att.IsImage)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     OnClose="@(() => RemoveAttachment(att))"
                                     title="@att.FileName">
                                <img src="@att.DataUrl" alt="@att.FileName" class="yamca-attach-thumb" />
                                @att.FileName
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.InsertDriveFile"
                                     OnClose="@(() => RemoveAttachment(att))"
                                     title="@($"{att.FileName} — {att.Text!.Length:N0} chars")">
                                @att.FileName
                            </MudChip>
                        }
                    }
                </div>
                <div class="yamca-composer-right">
                    @if (Chat.CurrentContextTokens > 0)
                    {
                        <div class="yamca-context-badge" title="@ContextBadgeTooltip()">
                            @ContextBadgeText()
                        </div>
                    }
                    @if (Chat.IsBusy)
                    {
                        <MudIconButton Variant="Variant.Filled" Color="Color.Error"
                                       Size="Size.Small"
                                       Icon="@Icons.Material.Filled.Stop"
                                       OnClick="OnCancel"
                                       aria-label="@(Chat.IsCompacting ? "Cancel compaction" : "Stop")" />
                    }
                    else
                    {
                        <MudIconButton Variant="Variant.Filled" Color="Color.Default"
                                       Size="Size.Small"
                                       Icon="@Icons.Material.Filled.PlayArrow"
                                       OnClick="OnSend"
                                       Disabled="@(Chat.IsReadOnly || (string.IsNullOrWhiteSpace(_prompt) && _attachments.Count == 0))"
                                       aria-label="Send" />
                    }
                </div>
            </div>
            @if (_attachError is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Error" Class="px-1">@_attachError</MudText>
            }
        </div>
    </div>

    <MudDialog @bind-Visible="_compactDialogOpen"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>Compact context now</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="mb-3">
                Summarize earlier turns into the system message and keep only the most recent N user turns verbatim. The summary replaces the original messages in what is sent to the model — your visible chat log is unchanged.
            </MudText>
            <MudNumericField T="int" @bind-Value="_compactKeepTurns"
                             Label="Keep recent turns"
                             Min="1" Max="50" Step="1"
                             Variant="Variant.Outlined" Margin="Margin.Dense" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _compactDialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmCompactNow">
                Compact
            </MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_summaryDialogOpen"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>Compaction summary</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary)">
                Model-generated summary of the turns above this divider. This text replaced the original messages in the conversation history that is sent to the model on subsequent turns.
            </MudText>
            <pre style="white-space: pre-wrap; word-break: break-word; font-family: var(--mud-typography-body2-family); margin: 0; max-height: 60vh; overflow: auto;">@Chat.LastCompactionSummary</pre>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _summaryDialogOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_diagDialogOpen"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
        <TitleContent>
            <div class="d-flex align-center" style="gap: 6px; width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.BugReport" Size="Size.Small" />
                <MudText Typo="Typo.h6">Diagnostic log</MudText>
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                    @_diagEntries.Count @(_diagEntries.Count == 1 ? "entry" : "entries")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                               Class="ml-auto" OnClick="CopyDiagnostics"
                               Disabled="@(_diagEntries.Count == 0)" aria-label="Copy diagnostics" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _diagDialogOpen = false)" aria-label="Close" />
            </div>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary)">
                Most recent endpoint round-trips, tool calls, and session events for this chat
                (newest last). In-memory only — cleared when the chat is reset.
            </MudText>
            @if (_diagEntries.Count == 0)
            {
                <MudText Typo="Typo.body2">No diagnostics recorded yet — send a message to populate the log.</MudText>
            }
            else
            {
                <pre style="white-space: pre-wrap; word-break: break-word; font-family: var(--mud-typography-body2-family); font-size: 0.8rem; margin: 0; max-height: 60vh; overflow: auto;">@FormatDiagnostics()</pre>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _diagDialogOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_ctxDialogOpen"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
        <TitleContent>
            <div class="d-flex align-center" style="gap: 6px; width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" />
                <MudText Typo="Typo.h6">Raw context</MudText>
                @if (_ctxPreview is not null)
                {
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                        @_ctxPreview.Messages.Count @(_ctxPreview.Messages.Count == 1 ? "message" : "messages"),
                        @_ctxPreview.Tools.Count @(_ctxPreview.Tools.Count == 1 ? "tool" : "tools")
                    </MudText>
                }
                <MudSwitch T="bool" @bind-Value="_ctxShowLabels" Class="ml-auto mr-2"
                           Size="Size.Small" Color="Color.Primary" Label="Labels"
                           Disabled="@(_ctxPreview is null || _ctxRawView)" />
                <MudToggleGroup T="bool" @bind-Value="_ctxRawView"
                                Size="Size.Small" Color="Color.Primary" CheckMark="false"
                                Disabled="@(_ctxPreview is null)">
                    <MudToggleItem Value="false" Text="Structured" />
                    <MudToggleItem Value="true" Text="Raw JSON" />
                </MudToggleGroup>
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                               OnClick="CopyContext"
                               Disabled="@(_ctxPreview is null)" aria-label="Copy context" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _ctxDialogOpen = false)" aria-label="Close" />
            </div>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary)">
                The exact request that would be sent to the endpoint on the next turn. In the
                structured view, <em>Labels</em> annotates the parts with their yamca concepts (the
                <code>system</code> message's component sections, the tools list) — these are never
                sent to the model; turn it off to see just the message stream the model receives.
                In-memory snapshot — taken when this dialog was opened.
            </MudText>
            @if (_ctxPreview is null)
            {
                <MudText Typo="Typo.body2">No session yet — send a message to populate the context.</MudText>
            }
            else
            {
                <pre style="white-space: pre-wrap; word-break: break-word; font-family: var(--mud-typography-body2-family); font-size: 0.8rem; margin: 0; max-height: 60vh; overflow: auto;">@(_ctxRawView ? FormatRaw(_ctxPreview) : FormatStructured(_ctxPreview, _ctxShowLabels))</pre>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _ctxDialogOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <div class="yamca-scroll" @ref="_scrollContainer">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
            @for (var i = 0; i < Chat.Turns.Count; i++)
            {
                if (Chat.CompactionBoundaryUiTurnIndex is int boundary && i == boundary && boundary > 0)
                {
                    <div class="d-flex align-center my-3" style="gap: 8px;">
                        <span style="flex: 1 1 0; border-top: 1px solid var(--mud-palette-divider);"></span>
                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                   Disabled="@(string.IsNullOrEmpty(Chat.LastCompactionSummary))"
                                   StartIcon="@Icons.Material.Filled.UnfoldMore"
                                   OnClick="OpenCompactionSummary"
                                   Style="flex-shrink: 0;">
                            Chat summarized
                        </MudButton>
                        <span style="flex: 1 1 0; border-top: 1px solid var(--mud-palette-divider);"></span>
                    </div>
                }
                <ChatTurnView Turn="Chat.Turns[i]" OnContinue="OnContinue" />
            }

            @foreach (var approval in Chat.Approvals.ToList())
            {
                <ApprovalPrompt Approval="approval"
                                OnResolve="@(d => Chat.ResolveApproval(approval, d.Approved, d.Persistence))"
                                OnRegisterAndAllow="@(desc => Chat.RegisterAndAllow(approval, desc))" />
            }

            @if (Chat.Error is not null && (Chat.Turns.Count == 0 || Chat.Turns[^1].Error is null))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@Chat.Error</MudAlert>
            }

            <div @ref="_scrollAnchor"></div>
        </MudContainer>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ChatSessionManager Manager { get; set; } = default!;
    [Inject] private GitService Git { get; set; } = default!;
    [Inject] private IDialogService Dialogs { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISessionSettings Session { get; set; } = default!;
    [Inject] private SessionSettings SessionConcrete { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private SubagentSessionRegistry Subagents { get; set; } = default!;

    [Parameter, EditorRequired] public ChatViewModel Chat { get; set; } = default!;
    [Parameter] public bool ShowHeader { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private ChatViewModel? _subscribed;
    private string _prompt = "";
    private ElementReference _scrollAnchor;
    private ElementReference _scrollContainer;
    private ElementReference _composer;
    private DotNetObjectReference<ChatSessionPanel>? _selfRef;
    private readonly List<Attachment> _attachments = new();
    private string? _attachError;
    private bool _wasCompacting;
    private bool _pendingAutoSend;
    private Snackbar? _compactingSnackbar;
    private bool _summaryDialogOpen;
    private bool _compactDialogOpen;
    private int _compactKeepTurns = 4;
    private bool _diagDialogOpen;
    private IReadOnlyList<DiagnosticEntry> _diagEntries = Array.Empty<DiagnosticEntry>();
    private bool _ctxDialogOpen;
    private bool _ctxRawView;
    private bool _ctxShowLabels = true;
    private ChatRequestPreview? _ctxPreview;

    // Worktree change badge: refreshed on bind and whenever an agent turn finishes (which is when
    // the on-disk worktree may have changed). _wasRunningForDiff tracks the run transition; the
    // _diffStatLoading guard collapses overlapping refreshes.
    private WorktreeDiffStat? _diffStat;
    private bool _wasRunningForDiff;
    private bool _diffStatLoading;

    // Cap text attachments so a huge file can't bloat the prompt/context. Images are
    // not capped here — yamca runs on localhost (no transport budget to defend), and
    // the model endpoint rejects images it can't handle (surfaced as a chat error).
    private const long MaxAttachmentBytes = 2 * 1024 * 1024; // 2 MB per text file
    private const string AttachAccept =
        ".txt,.md,.markdown,.json,.xml,.yml,.yaml,.csv,.tsv,.log," +
        ".cs,.csproj,.razor,.cshtml,.html,.htm,.css,.scss,.js,.ts,.tsx,.jsx," +
        ".py,.go,.rs,.java,.kt,.rb,.php,.sh,.ps1,.psm1,.sql,.toml,.ini,.cfg,.conf," +
        ".png,.jpg,.jpeg,.gif,.webp";

    // A text attachment sets Text; an image attachment sets Image. Image attachments are
    // sent to the model as image data (data URI), text attachments are inlined into the prompt.
    private sealed record Attachment(string FileName, string? Text, ChatImage? Image)
    {
        public bool IsImage => Image is not null;
        public string DataUrl => Image is null ? "" : $"data:{Image.MimeType};base64,{Image.Base64Data}";
    }

    private string ComposerClass => Chat.YoloMode ? "yamca-composer yamca-composer-yolo" : "yamca-composer";

    private string TileTitle
    {
        get
        {
            if (Chat.WorktreeInfo is { } wt)
                return Chat.Turns.Count > 0 ? $"{Chat.Title} · {wt.Branch}" : wt.Branch;
            if (Chat.Turns.Count > 0) return Chat.Title;
            var slot = Manager.Sessions.ToList().FindIndex(s => s.Id == Chat.Id);
            return slot >= 0 ? $"Chat {slot + 1}" : "Chat";
        }
    }

    private string BranchTooltip => Chat.IsGitRepository switch
    {
        true => "Branch Code",
        false => "Not a git repository",
        _ => "Branch Code",
    };

    private bool IsBranchOpBusy()
    {
        if (Chat.IsReadOnly) return true;
        if (Chat.IsRunning) return true;
        if (Chat.WorktreeInfo is { } wt)
        {
            var baseSession = Manager.Sessions.FirstOrDefault(
                s => string.Equals(s.Workspace.RootPath, wt.BasePath, StringComparison.OrdinalIgnoreCase));
            if (baseSession is not null && baseSession.IsRunning) return true;
        }
        return false;
    }

    protected override void OnInitialized()
    {
        // The subagent registry is per-circuit (shared across chat tiles); refresh the toolbar
        // badge whenever a run starts, streams, or finishes.
        Subagents.Changed += OnSubagentsChanged;
    }

    private void OnSubagentsChanged() => InvokeAsync(StateHasChanged);

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_subscribed, Chat)) return;

        // Switched to a different ChatViewModel — rewire change subscription and
        // clear per-panel composer state so it doesn't leak across sessions.
        if (_subscribed is not null) _subscribed.Changed -= OnChanged;
        Chat.Changed += OnChanged;
        _subscribed = Chat;
        _prompt = "";
        _attachments.Clear();
        _attachError = null;
        _diffStat = null;
        _wasRunningForDiff = Chat.IsRunning;
        _ = RefreshDiffStatAsync();

        // Consume a one-shot seed prompt (e.g. from a board step launch) into the composer.
        // A board step also flags AutoSendDraft so the prompt is sent on first render rather than
        // left for review. Only for a fresh, unsent session.
        if (!string.IsNullOrEmpty(Chat.DraftPrompt) && Chat.Turns.Count == 0)
        {
            _prompt = Chat.DraftPrompt;
            Chat.DraftPrompt = null;
            _pendingAutoSend = Chat.AutoSendDraft;
            Chat.AutoSendDraft = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await SafeInvokeAsync("yamcaChat.init", _scrollContainer);
        await SafeInvokeAsync("yamcaChat.scrollIfSticky", _scrollAnchor);

        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await SafeInvokeAsync("yamcaChat.initPaste", _composer, _selfRef);
            await SafeInvokeAsync("yamcaChat.initDrop", _composer, _selfRef, AttachAccept);
        }

        // Auto-send a seeded board-step prompt now that the session is bound and rendered.
        if (_pendingAutoSend)
        {
            _pendingAutoSend = false;
            if (!string.IsNullOrWhiteSpace(_prompt) && !Chat.IsRunning)
                await OnSend();
        }

        if (Chat.IsGitRepository is null)
        {
            try
            {
                var isRepo = await Git.IsGitRepoAsync(Chat.Workspace.RootPath, CancellationToken.None);
                Chat.IsGitRepository = isRepo;
                StateHasChanged();
            }
            catch { Chat.IsGitRepository = false; }
        }
    }

    private string EndpointButtonTooltip()
    {
        if (Chat.LockedEndpoint is { } locked) return $"Endpoint: {locked.DisplayLabel} (locked)";
        var ep = Chat.SelectedEndpointId is Guid id
            ? Session.Endpoints.FindById(id)
            : null;
        ep ??= Session.Endpoints.Default;
        return $"Endpoint: {ep.DisplayLabel}";
    }

    private async Task OnEndpointPickerClicked()
    {
        var parameters = new DialogParameters
        {
            ["Endpoints"] = Session.Endpoints.Items,
            ["DefaultId"] = Session.Endpoints.DefaultId,
            ["InitiallySelectedId"] = Chat.SelectedEndpointId ?? Session.Endpoints.DefaultId,
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<EndpointPickerDialog>("Select endpoint", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not Guid id) return;
        Chat.SelectEndpoint(id);
    }

    private async Task OnBranchClicked()
    {
        var parameters = new DialogParameters { ["BaseWorkspace"] = Chat.Workspace };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<BranchCreateDialog>("Branch Code", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not WorktreeInfo info) return;

        try
        {
            var workspace = new WorkspaceImpl(info.WorktreePath);
            var vm = Manager.CreateForWorktree(workspace, info);
            Nav.NavigateTo($"chat/{vm.Id}");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"yamca: could not open worktree session: {ex.Message}");
        }
    }

    private async Task OnMergeClicked()
    {
        if (Chat.WorktreeInfo is not { } info) return;
        var parameters = new DialogParameters { ["Info"] = info };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<BranchMergeDialog>("Merge branch", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        if (result.Data is BranchMergeDialog.MergeOutcome outcome && outcome.CleanupRequested)
        {
            // Worktree is gone — close this session.
            Manager.Close(Chat.Id);
            Nav.NavigateTo("/");
        }
    }

    private async Task OnDeleteBranchClicked()
    {
        if (Chat.WorktreeInfo is not { } info) return;
        var parameters = new DialogParameters { ["Info"] = info };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<BranchDeleteDialog>("Delete branch", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        Manager.Close(Chat.Id);
        Nav.NavigateTo("/");
    }

    private void OnChanged()
    {
        DetectCompactionTransition();
        DetectRunCompletionForDiff();
        InvokeAsync(StateHasChanged);
    }

    // A turn just finished (running → idle): the worktree may have new edits, so refresh the badge.
    private void DetectRunCompletionForDiff()
    {
        var isNow = Chat.IsRunning;
        if (isNow == _wasRunningForDiff) return;
        _wasRunningForDiff = isNow;
        if (!isNow) _ = RefreshDiffStatAsync();
    }

    // Recompute the worktree change badge. No-op for sessions not bound to a worktree. Overlapping
    // calls collapse via _diffStatLoading; failures clear the badge rather than surfacing an error.
    private async Task RefreshDiffStatAsync()
    {
        if (Chat.WorktreeInfo is not { } wt) { _diffStat = null; return; }
        if (_diffStatLoading) return;
        _diffStatLoading = true;
        try
        {
            var stat = await Git.GetWorktreeDiffStatAsync(wt.WorktreePath, wt.BaseBranch, CancellationToken.None);
            _diffStat = stat;
            await InvokeAsync(StateHasChanged);
        }
        catch { _diffStat = null; }
        finally { _diffStatLoading = false; }
    }

    // Open the standalone changes browser for this session's worktree. This is the only place to
    // review a worktree's diffs when the branch was opened without a board card (no card detail tab).
    private async Task OpenChangesDialog()
    {
        if (Chat.WorktreeInfo is not { } wt) return;
        var parameters = new DialogParameters
        {
            ["WorktreePath"] = wt.WorktreePath,
            ["BaseBranch"] = wt.BaseBranch,
            ["Branch"] = wt.Branch,
        };
        await Dialogs.ShowAsync<WorktreeChangesDialog>("Changes", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static string DiffStatTooltip(WorktreeDiffStat stat)
    {
        var files = $"{stat.FilesChanged} {(stat.FilesChanged == 1 ? "file" : "files")} changed since branch point";
        var lines = $"+{stat.Insertions} / −{stat.Deletions} lines";
        var pending = stat.UncommittedFiles > 0
            ? $", {stat.UncommittedFiles} with uncommitted changes"
            : ", all committed";
        return $"{files} · {lines}{pending}";
    }

    private void DetectCompactionTransition()
    {
        var isNow = Chat.IsCompacting;
        if (isNow == _wasCompacting) return;

        if (isNow)
        {
            _compactingSnackbar = Snackbar.Add(
                "Compacting context…",
                Severity.Info,
                config => config.RequireInteraction = true);
        }
        else
        {
            if (_compactingSnackbar is not null)
            {
                Snackbar.Remove(_compactingSnackbar);
                _compactingSnackbar = null;
            }

            if (Chat.CompactionError is { } err)
                Snackbar.Add($"Compaction failed: {err}", Severity.Warning);
            else
                Snackbar.Add("Earlier turns summarized.", Severity.Normal);
        }
        _wasCompacting = isNow;
    }

    private async Task OnSend()
    {
        if (Chat.IsRunning) return;
        if (string.IsNullOrWhiteSpace(_prompt) && _attachments.Count == 0) return;

        var p = ComposePrompt(_prompt, _attachments);
        var images = _attachments.Where(a => a.IsImage).Select(a => a.Image!).ToList();
        _prompt = "";
        _attachments.Clear();
        _attachError = null;
        await Chat.SendAsync(p, images);
    }

    // Only text attachments are inlined into the prompt; image attachments are sent
    // separately as image data (see OnSend).
    private static string ComposePrompt(string userText, IReadOnlyList<Attachment> attachments)
    {
        var textAttachments = attachments.Where(a => !a.IsImage).ToList();
        if (textAttachments.Count == 0) return userText;
        var sb = new StringBuilder();
        foreach (var a in textAttachments)
        {
            sb.Append("Attached file: ").AppendLine(a.FileName);
            sb.AppendLine("```");
            sb.AppendLine(a.Text);
            sb.AppendLine("```");
            sb.AppendLine();
        }
        sb.Append(userText);
        return sb.ToString();
    }

    private async Task OnFilesChanged(IReadOnlyList<IBrowserFile>? files)
    {
        if (files is null) return;
        _attachError = null;
        foreach (var file in files)
        {
            var isImage = IsImageFile(file);
            if (!isImage && file.Size > MaxAttachmentBytes)
            {
                _attachError = $"\"{file.Name}\" is larger than {MaxAttachmentBytes / 1024} KB and was skipped.";
                continue;
            }
            try
            {
                if (isImage)
                {
                    using var stream = file.OpenReadStream(long.MaxValue);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    var base64 = Convert.ToBase64String(ms.ToArray());
                    var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
                    _attachments.Add(new Attachment(file.Name, Text: null, Image: new ChatImage(mime, base64)));
                }
                else
                {
                    using var stream = file.OpenReadStream(MaxAttachmentBytes);
                    using var reader = new StreamReader(stream);
                    var text = await reader.ReadToEndAsync();
                    _attachments.Add(new Attachment(file.Name, text, Image: null));
                }
            }
            catch (Exception ex)
            {
                _attachError = $"Could not read \"{file.Name}\": {ex.Message}";
            }
        }
        StateHasChanged();
    }

    // Invoked from JS when an image is pasted into the composer. Funnels the pasted
    // image into the same attachment path as the file picker (see OnFilesChanged).
    [JSInvokable]
    public Task OnImagePasted(string mimeType, string base64)
    {
        var mime = string.IsNullOrWhiteSpace(mimeType) ? "image/png" : mimeType;
        var subtype = mime.Contains('/') ? mime[(mime.IndexOf('/') + 1)..] : "png";
        var name = $"pasted-{DateTime.Now:yyyyMMdd-HHmmss}.{subtype}";
        return AddImageAttachmentAsync(name, mimeType, base64);
    }

    // Invoked from JS when an image file is dropped onto the composer. Keeps the
    // original file name (paste has none, so it synthesizes one — see OnImagePasted).
    [JSInvokable]
    public Task OnImageDropped(string fileName, string mimeType, string base64)
        => AddImageAttachmentAsync(fileName, mimeType, base64);

    // Invoked from JS when a (non-image) file is dropped onto the composer. JS has
    // already read the text; mirror OnFilesChanged's size cap here.
    [JSInvokable]
    public async Task OnTextFileDropped(string fileName, string text)
    {
        if (Chat.IsBusy || Chat.IsReadOnly) return;
        if (Encoding.UTF8.GetByteCount(text) > MaxAttachmentBytes)
        {
            _attachError = $"\"{fileName}\" is larger than {MaxAttachmentBytes / 1024} KB and was skipped.";
            await InvokeAsync(StateHasChanged);
            return;
        }
        _attachments.Add(new Attachment(fileName, text, Image: null));
        _attachError = null;
        await InvokeAsync(StateHasChanged);
    }

    // Invoked from JS when a dropped file's type isn't in the accept list (the OS file
    // manager can't pre-filter a drag the way the file picker does).
    [JSInvokable]
    public async Task OnFileDropRejected(string fileName)
    {
        if (Chat.IsBusy || Chat.IsReadOnly) return;
        _attachError = $"\"{fileName}\" isn't a supported attachment type and was skipped.";
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddImageAttachmentAsync(string fileName, string mimeType, string base64)
    {
        if (Chat.IsBusy || Chat.IsReadOnly) return;
        if (string.IsNullOrEmpty(base64)) return;

        var mime = string.IsNullOrWhiteSpace(mimeType) ? "image/png" : mimeType;
        _attachments.Add(new Attachment(fileName, Text: null, Image: new ChatImage(mime, base64)));
        _attachError = null;
        await InvokeAsync(StateHasChanged);
    }

    private static readonly string[] ImageExtensions = { ".png", ".jpg", ".jpeg", ".gif", ".webp" };

    private static bool IsImageFile(IBrowserFile file)
    {
        if (file.ContentType is { Length: > 0 } ct &&
            ct.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            return true;
        var ext = Path.GetExtension(file.Name);
        return ImageExtensions.Contains(ext, StringComparer.OrdinalIgnoreCase);
    }

    private void RemoveAttachment(Attachment a)
    {
        _attachments.Remove(a);
        StateHasChanged();
    }

