@page "/commands"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Commands — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading settings&hellip;</MudText>
}
else
{
    <SettingsSection Title="Registered Commands" Tier="_tier" TierChanged="OnTierChanged">
        <Description>
            One-line CLI commands with no file in the repo (e.g. <code>npm install</code>, <code>dotnet build</code>).
            The LLM runs them exactly as written via <code>execute_script</code> &mdash; no arguments are appended.
            Give one an optional <em>name</em> to let the LLM reference it by that handle and to use as the
            default process name when it is launched in the background.
            Check <em>Background</em> for a watcher or dev server: running it then launches a long-lived
            process (managed on the Processes page) instead of running to completion.
            @if (_tier == SettingsTier.Project)
            {
                <text> Stored on disk in <code>@Keys.ProjectFile</code>.</text>
            }
            else { <text> Stored on disk in <code>@Keys.UserFile</code>.</text> }
        </Description>
        <Actions>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Terminal"
                       OnClick="OpenAddDialog">
                Add command
            </MudButton>
        </Actions>
        <ChildContent>
        @{ var inlineRows = CurrentInlineRows; }
        @if (inlineRows.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled); display:block;" Class="mb-1">No registered commands.</MudText>
        }
        else
        {
            <MudTable Items="inlineRows" Hover="true" Dense="true" Class="mud-table-bordered">
                <HeaderContent>
                    <MudTh Style="width: 160px;">Name</MudTh>
                    <MudTh>Command</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh Style="width: 110px;">Background</MudTh>
                    <MudTh Style="width: 110px;">Hide Success</MudTh>
                    <MudTh Style="width: 120px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @if (!string.IsNullOrWhiteSpace(context.Name))
                        {
                            <MudText Typo="Typo.body2"><b>@context.Name</b></MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-disabled)">(unnamed)</MudText>
                        }
                    </MudTd>
                    <MudTd><code>@context.Command</code></MudTd>
                    <MudTd>
                        @if (string.IsNullOrWhiteSpace(context.Description))
                        {
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">(none)</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.Description</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.Background)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.SuppressOutputOnSuccess)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                        }
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="Edit command">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditDialog(context))"
                                           aria-label="Edit command" />
                        </MudTooltip>
                        <MudTooltip Text="Remove command">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           OnClick="@(() => RemoveRow(context))"
                                           aria-label="Remove command" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        </ChildContent>
    </SettingsSection>

    <MudDialog @bind-Visible="_dialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@(_editRow is null ? "Add command" : "Edit command")</TitleContent>
        <DialogContent>
            <MudTextField T="string" @bind-Value="_formName"
                          Label="Name (optional)"
                          HelperText="Lets the LLM reference the command by this handle; also the default process name when run in the background."
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Placeholder="install" />
            <MudTextField T="string" @bind-Value="_formCommand"
                          Label="Command" Required="true"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Placeholder="npm install" />
            <MudTextField T="string" @bind-Value="_formDescription"
                          Label="Description (optional)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
            <MudCheckBox T="bool" Value="_formBackground"
                         ValueChanged="OnFormBackgroundChanged"
                         Label="Background"
                         Dense="true" Size="Size.Small" />
            <MudText Typo="Typo.caption" Class="mb-2" Component="@("div")"
                     Style="color:var(--mud-palette-text-secondary)">
                Launch this command as a long-lived process (a watcher or dev server) when it is run,
                instead of running it to completion. Managed via the Processes page and the
                <code>get_process_output</code> / <code>list_processes</code> / <code>stop_process</code> tools.
            </MudText>
            <MudCheckBox T="bool" @bind-Value="_formSuppress"
                         Label="Hide Success"
                         Disabled="@_formBackground"
                         Dense="true" Size="Size.Small" />
            <MudText Typo="Typo.caption" Component="@("div")"
                     Style="color:var(--mud-palette-text-secondary)">
                On a successful (exit 0) run, return only the status to the LLM — withhold stdout/stderr
                to save context. Failures still return full output.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _dialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="@(string.IsNullOrWhiteSpace(_formCommand))"
                       OnClick="ConfirmDialog">
                @(_editRow is null ? "Add" : "Save")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private SettingsLocation Keys { get; set; } = default!;

    private bool _hydrated;
    private SettingsTier _tier = SettingsTier.User; // User shown by default

    private bool _dialogOpen;
    private InlineRow? _editRow; // null = add mode
    private string _formName = string.Empty;
    private string _formCommand = string.Empty;
    private string _formDescription = string.Empty;
    private bool _formBackground;
    private bool _formSuppress;

    private sealed class InlineRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Command { get; set; } = string.Empty;
        public string? Name { get; set; }
        public string? Description { get; set; }
        public bool SuppressOutputOnSuccess { get; set; }
        public bool Background { get; set; }
    }

    private readonly List<InlineRow> _projectInline = new();
    private readonly List<InlineRow> _userInline = new();

    private List<InlineRow> CurrentInlineRows => _tier == SettingsTier.Project ? _projectInline : _userInline;

    private void OnTierChanged(SettingsTier tier)
    {
        _tier = tier;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        SyncRowsFromSession();
        _hydrated = true;
        StateHasChanged();
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private void SyncRowsFromSession()
    {
        SyncInlineRows(Session.ProjectScripts, _projectInline);
        SyncInlineRows(Session.UserScripts, _userInline);
    }

    private static void SyncInlineRows(ScriptRegistry registry, List<InlineRow> inline)
    {
        inline.Clear();
        foreach (var i in registry.Inline)
            inline.Add(new InlineRow { Command = i.Command, Name = i.Name, Description = i.Description, SuppressOutputOnSuccess = i.SuppressOutputOnSuccess, Background = i.Background });
    }

    private void PersistCommands()
    {
        // The Scripts page owns Registered + Directories for this tier; carry them over
        // verbatim so saving commands here doesn't wipe them.
        var current = _tier == SettingsTier.Project ? Session.ProjectScripts : Session.UserScripts;
        var inline = CurrentInlineRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Command))
            .Select(r => new RegisteredInlineScript(r.Command.Trim(), NullIfBlank(r.Description), r.SuppressOutputOnSuccess && !r.Background, NullIfBlank(r.Name), r.Background))
            .ToList();
        Session.SetScripts(_tier, new ScriptRegistry(current.Registered, current.Directories, inline));
    }

    private void RemoveRow(InlineRow row)
    {
        CurrentInlineRows.Remove(row);
        PersistCommands();
    }

    private void OpenAddDialog()
    {
        _editRow = null;
        _formName = string.Empty;
        _formCommand = string.Empty;
        _formDescription = string.Empty;
        _formBackground = false;
        _formSuppress = false;
        _dialogOpen = true;
    }

    private void OpenEditDialog(InlineRow row)
    {
        _editRow = row;
        _formName = row.Name ?? string.Empty;
        _formCommand = row.Command;
        _formDescription = row.Description ?? string.Empty;
        _formBackground = row.Background;
        _formSuppress = row.SuppressOutputOnSuccess;
        _dialogOpen = true;
    }

    // "Hide Success" is meaningless for a long-lived process, so clear it when backgrounding.
    private void OnFormBackgroundChanged(bool value)
    {
        _formBackground = value;
        if (value) _formSuppress = false;
    }

    private void ConfirmDialog()
    {
        if (string.IsNullOrWhiteSpace(_formCommand)) return;

        var row = _editRow ?? new InlineRow();
        row.Name = NullIfBlank(_formName);
        row.Command = _formCommand.Trim();
        row.Description = NullIfBlank(_formDescription);
        row.Background = _formBackground;
        row.SuppressOutputOnSuccess = _formBackground ? false : _formSuppress;

        if (_editRow is null) CurrentInlineRows.Add(row);

        PersistCommands();
        _dialogOpen = false;
    }

    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s;

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
    }
}
