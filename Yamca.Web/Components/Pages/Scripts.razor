@page "/scripts"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Scripts — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading settings&hellip;</MudText>
}
else
{
    <SettingsSection Title="Registered scripts" HelpDoc="scripts" Tier="_tier" TierChanged="OnTierChanged">
        <Actions>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddDialog">
                Add script
            </MudButton>
        </Actions>
        <ChildContent>
        @{ var rows = CurrentRows; }
        @if (rows.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled); display:block;" Class="mb-1">No registered scripts.</MudText>
        }
        else
        {
            <MudTable Items="rows" Hover="true" Dense="true" Class="mud-table-bordered">
                <HeaderContent>
                    <MudTh Style="width: 120px;">Kind</MudTh>
                    <MudTh>Path</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh Style="width: 110px;">Hide Success</MudTh>
                    <MudTh Style="width: 120px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Typo="Typo.body2">@(context.Kind == ScriptKind.Directory ? "Directory" : "File")</MudText>
                    </MudTd>
                    <MudTd>
                        <div class="d-flex align-center" style="gap: 4px;">
                            <code>@context.Path</code>
                            @if (!RowPathExists(context))
                            {
                                <MudTooltip Text="@($"{(context.Kind == ScriptKind.Directory ? "Directory" : "File")} not found under the workspace.")">
                                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" Size="Size.Small" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                    <MudTd>
                        @if (string.IsNullOrWhiteSpace(context.Description))
                        {
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">(none)</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.Description</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.SuppressOutputOnSuccess)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                        }
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="Edit script">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditDialog(context))"
                                           aria-label="Edit script" />
                        </MudTooltip>
                        <MudTooltip Text="Remove script">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           OnClick="@(() => RemoveRow(context))"
                                           aria-label="Remove script" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        </ChildContent>
    </SettingsSection>

    <MudDialog @bind-Visible="_dialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>@(_editRow is null ? "Add script" : "Edit script")</TitleContent>
        <DialogContent>
            <MudToggleGroup T="ScriptKind" Value="_formKind" ValueChanged="OnFormKindChanged"
                            Color="Color.Primary" CheckMark="false" Class="mb-3">
                <MudToggleItem Value="ScriptKind.File" Text="File" />
                <MudToggleItem Value="ScriptKind.Directory" Text="Directory" />
            </MudToggleGroup>
            <MudTextField T="string" @bind-Value="_formPath"
                          Label="@(_formKind == ScriptKind.Directory ? "Directory path" : "File path")"
                          Required="true"
                          HelperText="Workspace-relative; absolute paths are not allowed."
                          Error="@(!string.IsNullOrWhiteSpace(_formPath) && !FormPathValid)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Placeholder="@(_formKind == ScriptKind.Directory ? ".scripts" : "build.ps1")" />
            <MudTextField T="string" @bind-Value="_formDescription"
                          Label="Description (optional)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
            <MudCheckBox T="bool" @bind-Value="_formSuppress"
                         Label="Hide Success"
                         Dense="true" Size="Size.Small" />
            <MudText Typo="Typo.caption" HtmlTag="div"
                     Style="color:var(--mud-palette-text-secondary)">
                @if (_formKind == ScriptKind.Directory)
                {
                    <text>Applies to every file run via this directory. On a successful (exit 0) run, return only the status to the LLM &mdash; withhold stdout/stderr to save context. Failures still return full output.</text>
                }
                else
                {
                    <text>On a successful (exit 0) run, return only the status to the LLM &mdash; withhold stdout/stderr to save context. Failures still return full output.</text>
                }
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _dialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="@(!FormPathValid)"
                       OnClick="ConfirmDialog">
                @(_editRow is null ? "Add" : "Save")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private SettingsLocation Keys { get; set; } = default!;
    [Inject] private IWorkspace Workspace { get; set; } = default!;

    private bool _hydrated;
    private SettingsTier _tier = SettingsTier.User; // User shown by default

    private bool _dialogOpen;
    private ScriptRow? _editRow; // null = add mode
    private ScriptKind _formKind = ScriptKind.File;
    private string _formPath = string.Empty;
    private string _formDescription = string.Empty;
    private bool _formSuppress;

    private enum ScriptKind { File, Directory }

    private sealed class ScriptRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public ScriptKind Kind { get; set; } = ScriptKind.File;
        public string Path { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool SuppressOutputOnSuccess { get; set; }
    }

    private readonly List<ScriptRow> _projectRows = new();
    private readonly List<ScriptRow> _userRows = new();

    private List<ScriptRow> CurrentRows => _tier == SettingsTier.Project ? _projectRows : _userRows;

    // True when the form path is a non-blank, workspace-relative (non-rooted) path.
    private bool FormPathValid =>
        !string.IsNullOrWhiteSpace(_formPath) && !Path.IsPathRooted(NormalizeScriptPath(_formPath));

    private void OnTierChanged(SettingsTier tier)
    {
        _tier = tier;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        SyncRowsFromSession();
        _hydrated = true;
        StateHasChanged();
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private void SyncRowsFromSession()
    {
        SyncScriptRows(Session.ProjectScripts, _projectRows);
        SyncScriptRows(Session.UserScripts, _userRows);
    }

    private static void SyncScriptRows(ScriptRegistry registry, List<ScriptRow> rows)
    {
        // Files first, then directories: a stable grouping for the single grid.
        rows.Clear();
        foreach (var e in registry.Registered)
            rows.Add(new ScriptRow { Kind = ScriptKind.File, Path = e.Path, Description = e.Description, SuppressOutputOnSuccess = e.SuppressOutputOnSuccess });
        foreach (var d in registry.Directories)
            rows.Add(new ScriptRow { Kind = ScriptKind.Directory, Path = d.Path, Description = d.Description, SuppressOutputOnSuccess = d.SuppressOutputOnSuccess });
    }

    private void PersistScripts()
    {
        var files = CurrentRows
            .Where(r => r.Kind == ScriptKind.File && !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScript(NormalizeScriptPath(r.Path), NullIfBlank(r.Description), r.SuppressOutputOnSuccess))
            .ToList();
        var dirs = CurrentRows
            .Where(r => r.Kind == ScriptKind.Directory && !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScriptDirectory(NormalizeScriptPath(r.Path), NullIfBlank(r.Description), r.SuppressOutputOnSuccess))
            .ToList();
        // Inline commands are owned by the Commands page; carry them over verbatim so
        // saving files/directories here doesn't wipe them.
        var current = _tier == SettingsTier.Project ? Session.ProjectScripts : Session.UserScripts;
        Session.SetScripts(_tier, new ScriptRegistry(files, dirs, current.Inline));
    }

    private void RemoveRow(ScriptRow row)
    {
        CurrentRows.Remove(row);
        PersistScripts();
    }

    private void OpenAddDialog()
    {
        _editRow = null;
        _formKind = ScriptKind.File;
        _formPath = string.Empty;
        _formDescription = string.Empty;
        _formSuppress = false;
        _dialogOpen = true;
    }

    private void OpenEditDialog(ScriptRow row)
    {
        _editRow = row;
        _formKind = row.Kind;
        _formPath = row.Path;
        _formDescription = row.Description ?? string.Empty;
        _formSuppress = row.SuppressOutputOnSuccess;
        _dialogOpen = true;
    }

    private void OnFormKindChanged(ScriptKind kind)
    {
        _formKind = kind;
    }

    private void ConfirmDialog()
    {
        if (!FormPathValid) return;

        var row = _editRow ?? new ScriptRow();
        row.Kind = _formKind;
        row.Path = NormalizeScriptPath(_formPath);
        row.Description = NullIfBlank(_formDescription);
        row.SuppressOutputOnSuccess = _formSuppress;

        if (_editRow is null) CurrentRows.Add(row);

        PersistScripts();
        _dialogOpen = false;
    }

    private bool RowPathExists(ScriptRow row)
    {
        if (string.IsNullOrWhiteSpace(row.Path)) return true;
        try
        {
            var resolved = Workspace.Resolve(row.Path);
            return row.Kind == ScriptKind.Directory ? Directory.Exists(resolved) : File.Exists(resolved);
        }
        catch { return false; }
    }

    private static string NormalizeScriptPath(string raw) => raw.Trim().Replace('\\', '/');
    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s;

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
    }
}
