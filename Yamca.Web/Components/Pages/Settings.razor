    private void SetPermission(string toolName, PermissionLevel? perm)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { Permission = perm };
        ApplyEntry(toolName, next);
    }

    private void SetRestrict(string toolName, bool? restrict)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { RestrictToWorkspace = restrict };
        ApplyEntry(toolName, next);
    }

    private void ApplyEntry(string toolName, ToolPermissionSettings entry)
    {
        // Drop the entry entirely if nothing is set, so the JSON stays clean.
        var collapsed = (entry.Permission is null && entry.RestrictToWorkspace is null) ? null : entry;
        Session.SetToolEntry(CurrentTier, toolName, collapsed);
    }

    private static Color PermColor(PermissionLevel level) => level switch
    {
        PermissionLevel.Allow => Color.Success,
        PermissionLevel.Deny  => Color.Error,
        _                     => Color.Warning,
    };

    private SettingsTier CurrentInstructionTier => _instrTierIndex == 0 ? SettingsTier.Project : SettingsTier.Global;

    private void SyncRowsFromSession()
    {
        _projectRows.Clear();
        foreach (var p in Session.ProjectInstructionFiles)
            _projectRows.Add(new InstructionRow { Path = p });
        _globalRows.Clear();
        foreach (var p in Session.GlobalInstructionFiles)
            _globalRows.Add(new InstructionRow { Path = p });

        SyncScriptRows(Session.ProjectScripts, _projectScriptFiles, _projectScriptDirs);
        SyncScriptRows(Session.GlobalScripts, _globalScriptFiles, _globalScriptDirs);
    }

    private static void SyncScriptRows(ScriptRegistry registry, List<ScriptRow> files, List<ScriptRow> dirs)
    {
        files.Clear();
        foreach (var e in registry.Registered)
            files.Add(new ScriptRow { Path = e.Path, Description = e.Description });
        dirs.Clear();
        foreach (var d in registry.Directories)
            dirs.Add(new ScriptRow { Path = d.Path, Description = d.Description });
    }

    private void PersistScripts()
    {
        var files = CurrentScriptFileRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScript(NormalizeScriptPath(r.Path), NullIfBlank(r.Description)))
            .ToList();
        var dirs = CurrentScriptDirectoryRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScriptDirectory(NormalizeScriptPath(r.Path), NullIfBlank(r.Description)))
            .ToList();
        Session.SetScripts(CurrentScriptTier, new ScriptRegistry(files, dirs));
    }

    private void AddScriptRow(bool isDirectory)
    {
        (isDirectory ? CurrentScriptDirectoryRows : CurrentScriptFileRows).Add(new ScriptRow());
        // Empty rows are filtered out on persist, so don't write yet — wait for the user to type a path.
    }

    private void RemoveScriptRow(ScriptRow row, bool isDirectory)
    {
        (isDirectory ? CurrentScriptDirectoryRows : CurrentScriptFileRows).Remove(row);
        PersistScripts();
    }

    private void OnScriptPathChanged(ScriptRow row, string value, bool isDirectory)
    {
        var normalized = NormalizeScriptPath(value ?? string.Empty);
        if (Path.IsPathRooted(normalized)) normalized = string.Empty;
        if (row.Path == normalized) return;
        row.Path = normalized;
        PersistScripts();
    }

    private void OnScriptDescriptionChanged(ScriptRow row, string value, bool isDirectory)
    {
        var trimmed = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (string.Equals(row.Description, trimmed, StringComparison.Ordinal)) return;
        row.Description = trimmed;
        PersistScripts();
    }

    private bool ScriptFileExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true;
        try { return File.Exists(Workspace.Resolve(relative)); }
        catch { return false; }
    }

    private bool ScriptDirectoryExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true;
        try { return Directory.Exists(Workspace.Resolve(relative)); }
        catch { return false; }
    }

    private static string NormalizeScriptPath(string raw) => raw.Trim().Replace('\\', '/');
    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s;

    private void PersistCurrentTier()
    {
        Session.SetInstructionFiles(CurrentInstructionTier, CurrentRows.Select(r => r.Path).ToList());
    }

    private void AddInstructionPath()
    {
        CurrentRows.Add(new InstructionRow());
        PersistCurrentTier();
    }

    private void RemoveRow(InstructionRow row)
    {
        CurrentRows.Remove(row);
        PersistCurrentTier();
    }

    private void OnRowPathChanged(InstructionRow row, string value)
    {
        var normalized = (value ?? string.Empty).Trim().Replace('\\', '/');
        if (Path.IsPathRooted(normalized)) normalized = string.Empty;
        if (row.Path == normalized) return;
        row.Path = normalized;
        PersistCurrentTier();
    }

    private void SetRowPath(InstructionRow row, string value)
    {
        row.Path = value ?? string.Empty;
        PersistCurrentTier();
    }

    private bool InstructionFileExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true; // empty rows show no warning
        try
        {
            var resolved = Workspace.Resolve(relative);
            return File.Exists(resolved);
        }
        catch
        {
            return false;
        }
    }

    private void OpenInstructionPicker(InstructionRow row)
    {
        _pickerRow = row;
        _pickerDir = string.Empty;
        _pickerListing = Browser.List(_pickerDir);
        _pickerOpen = true;
    }

    private void PickerNavigateUp()
    {
        var parent = WorkspaceBrowser.Parent(_pickerDir);
        if (parent is null) return;
        _pickerDir = parent;
        _pickerListing = Browser.List(_pickerDir);
    }

    private void PickerSelect(WorkspaceBrowser.Entry entry)
    {
        if (entry.IsDirectory)
        {
            _pickerDir = entry.RelativePath;
            _pickerListing = Browser.List(_pickerDir);
            return;
        }

        if (_pickerRow is not null)
            SetRowPath(_pickerRow, entry.RelativePath);

        _pickerOpen = false;
        _pickerRow = null;
    }

    private bool _exportDialogOpen;
    private bool _exportIncludeApiKey;

    private bool _importDialogOpen;
    private string? _importFileName;
    private string? _importJson;

    private const long MaxImportBytes = 256 * 1024;

    private void OpenExportDialog()
    {
        _exportIncludeApiKey = false;
        _exportDialogOpen = true;
    }

    private async Task DownloadExport()
    {
        var json = Session.ExportGlobal(_exportIncludeApiKey);
        var filename = $"yamca-settings-{DateTime.Now:yyyyMMdd-HHmm}.json";
        _exportDialogOpen = false;
        try
        {
            await JS.InvokeAsync<bool>("yamcaStorage.downloadText", filename, json, "application/json");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnImportFileChanged(IBrowserFile? file)
    {
        if (file is null) return;
        if (file.Size > MaxImportBytes)
        {
            Snackbar.Add($"File is too large (max {MaxImportBytes / 1024} KB).", Severity.Error);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxImportBytes);
            using var reader = new StreamReader(stream);
            _importJson = await reader.ReadToEndAsync();
            _importFileName = file.Name;
            _importDialogOpen = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
        }
    }

    private void CancelImport()
    {
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;
    }

    private void ConfirmImport()
    {
        if (_importJson is null) { _importDialogOpen = false; return; }

        var result = Session.ImportGlobal(_importJson);
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;

        if (result.Success)
        {
            SyncRowsFromSession();
            Snackbar.Add("Global settings imported.", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Import failed: {result.Error}", Severity.Error);
        }
    }

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
        McpRegistry.Changed -= OnMcpChanged;
    }
