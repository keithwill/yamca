@page "/settings"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Chat

<PageTitle>Settings — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading from localStorage&hellip;</MudText>
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Endpoint</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">
            OpenAI-compatible local server (llama.cpp, vllm, etc.). Stored in <code>@Keys.GlobalKey</code>.
        </MudText>
        <MudTextField Value="Session.Endpoint.BaseUrl"
                      ValueChanged="@((string v) => UpdateEndpoint(Session.Endpoint with { BaseUrl = v }))"
                      T="string" Label="Base URL" Variant="Variant.Outlined" Class="mb-2" />
        <MudTextField Value="Session.Endpoint.ApiKey"
                      ValueChanged="@((string v) => UpdateEndpoint(Session.Endpoint with { ApiKey = v }))"
                      T="string" Label="API key" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mb-2" />
        <div class="d-flex align-center" style="gap: 4px;">
            <MudTextField Value="Session.Endpoint.Model"
                          ValueChanged="OnModelChanged"
                          T="string" Label="Model" Variant="Variant.Outlined"
                          DebounceInterval="500"
                          Class="flex-grow-1" />
            <MudTooltip Text="Browse available models">
                <MudIconButton Icon="@Icons.Material.Filled.Search"
                               OnClick="OpenModelPicker"
                               aria-label="Browse available models" />
            </MudTooltip>

            @if (_modelValidating)
            {
                <MudTooltip Text="Checking model against endpoint…">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                </MudTooltip>
            }
            else if (_modelValid is true)
            {
                <MudTooltip Text="Model is available on the endpoint">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                </MudTooltip>
            }
            else if (_modelValid is false)
            {
                <MudTooltip Text="@(_modelValidationError ?? "Model not found on endpoint")">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                </MudTooltip>
            }
        </div>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            Optional for single-model hosts like llama.cpp (the server ignores this field and serves whatever it was launched with). Required for multi-model hosts (OpenAI, Ollama, OpenRouter, LM Studio). Click the search icon to list models the endpoint reports.
        </MudText>
    </MudPaper>

    <MudDialog @bind-Visible="_modelPickerOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Available models</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2">
                Fetched from <code>@Session.Endpoint.BaseUrl</code>/models.
            </MudText>
            @if (_modelsLoading)
            {
                <div class="d-flex align-center">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Class="ml-2">Loading…</MudText>
                </div>
            }
            else if (_modelsError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_modelsError</MudAlert>
            }
            else if (_models.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">The endpoint returned no models.</MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var id in _models)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.SmartToy" OnClick="@(() => SelectModel(id))">
                            <code>@id</code>
                        </MudListItem>
                    }
                </MudList>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _modelPickerOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">System prompt</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">
            The current workspace path is sent automatically as separate context — no need to mention it here.
        </MudText>
        <MudTextField Value="Session.SystemPrompt"
                      ValueChanged="@((string v) => UpdateSystemPrompt(v))"
                      T="string" Variant="Variant.Outlined" Lines="4" />
        <MudSwitch T="bool" Value="Session.MarkdownEnabled"
                   ValueChanged="@((bool v) => Session.SetMarkdownEnabled(v))"
                   Color="Color.Primary" Class="mt-3"
                   Label="Markdown rendering" />
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            A capability hint is appended to the system prompt either way: when on, the model is told its replies are rendered as Markdown; when off, it's told to reply in plain text.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">Tool permissions</MudText>
            <MudSpacer />
            <MudTabs @bind-ActivePanelIndex="_tierIndex" Rounded="true" Color="Color.Primary">
                <MudTabPanel Text="Project" />
                <MudTabPanel Text="Global" />
            </MudTabs>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Project overrides Global. Unset (<em>inherit</em>) falls through to Global, then to the tool's default.
            @if (_tierIndex == 0) { <text>Stored in <code>@Keys.ProjectKey</code>.</text> }
            else { <text>Stored in <code>@Keys.GlobalKey</code>.</text> }
        </MudText>

        <MudTable Items="Tools.Tools" Hover="true" Dense="true" Class="mud-table-bordered">
            <HeaderContent>
                <MudTh>Tool</MudTh>
                <MudTh>Permission</MudTh>
                <MudTh>Restrict to workspace</MudTh>
                <MudTh>Effective</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2"><b>@context.Name</b></MudText>
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                        @context.Description
                    </MudText>
                </MudTd>
                <MudTd>
                    @{
                        var entry = CurrentMap.Get(context.Name);
                        var selected = entry?.Permission;
                    }
                    <MudSelect T="PermissionLevel?" Value="selected"
                               ValueChanged="@((PermissionLevel? p) => SetPermission(context.Name, p))"
                               Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)null)">inherit</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Allow)">Allow</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Ask)">Ask</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Deny)">Deny</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd>
                    @if (context.SupportsWorkspaceRestriction)
                    {
                        var restrict = CurrentMap.Get(context.Name)?.RestrictToWorkspace;
                        <MudSelect T="bool?" Value="restrict"
                                   ValueChanged="@((bool? b) => SetRestrict(context.Name, b))"
                                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                            <MudSelectItem T="bool?" Value="@((bool?)null)">inherit</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)true)">On</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)false)">Off</MudSelectItem>
                        </MudSelect>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">n/a</MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@PermColor(Resolver.Resolve(context.Name))">
                        @Resolver.Resolve(context.Name)
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private IToolRegistry Tools { get; set; } = default!;
    [Inject] private IPermissionResolver Resolver { get; set; } = default!;
    [Inject] private WorkspaceKey Keys { get; set; } = default!;
    [Inject] private EndpointHealthService HealthService { get; set; } = default!;

    private bool _hydrated;
    private int _tierIndex; // 0 = Project, 1 = Global

    private bool _modelPickerOpen;
    private bool _modelsLoading;
    private string? _modelsError;
    private IReadOnlyList<string> _models = Array.Empty<string>();

    private bool _modelValidating;
    private bool? _modelValid;
    private string? _modelValidationError;
    private CancellationTokenSource? _validateCts;

    private SettingsTier CurrentTier => _tierIndex == 0 ? SettingsTier.Project : SettingsTier.Global;
    private ToolSettingsMap CurrentMap => CurrentTier == SettingsTier.Project ? Session.Project : Session.Global;

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        _hydrated = true;
        StateHasChanged();
        _ = ValidateModelAsync();
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private void UpdateEndpoint(EndpointSettings ep) => Session.SetEndpoint(ep);

    private void OnModelChanged(string value)
    {
        UpdateEndpoint(Session.Endpoint with { Model = value });
        _ = ValidateModelAsync();
    }

    private async Task ValidateModelAsync()
    {
        _validateCts?.Cancel();
        var cts = new CancellationTokenSource();
        _validateCts = cts;

        var endpoint = Session.Endpoint;
        if (string.IsNullOrWhiteSpace(endpoint.Model))
        {
            _modelValid = null;
            _modelValidating = false;
            _modelValidationError = null;
            StateHasChanged();
            return;
        }

        _modelValidating = true;
        _modelValid = null;
        _modelValidationError = null;
        StateHasChanged();

        var result = await HealthService.ListModelsAsync(endpoint, cts.Token);
        if (cts.IsCancellationRequested) return;

        _modelValidating = false;
        if (!result.Success)
        {
            _modelValid = false;
            _modelValidationError = result.ErrorMessage;
        }
        else
        {
            var match = result.Models.Any(id => string.Equals(id, endpoint.Model, StringComparison.OrdinalIgnoreCase));
            _modelValid = match;
            _modelValidationError = match ? null : $"\"{endpoint.Model}\" is not in the {result.Models.Count}-model list returned by the endpoint.";
        }
        StateHasChanged();
    }

    private async Task OpenModelPicker()
    {
        _modelPickerOpen = true;
        _modelsLoading = true;
        _modelsError = null;
        _models = Array.Empty<string>();
        StateHasChanged();

        var result = await HealthService.ListModelsAsync(Session.Endpoint);
        _modelsLoading = false;
        if (result.Success)
        {
            _models = result.Models;
        }
        else
        {
            _modelsError = result.ErrorMessage;
        }
        StateHasChanged();
    }

    private void SelectModel(string id)
    {
        UpdateEndpoint(Session.Endpoint with { Model = id });
        _modelPickerOpen = false;
        _modelValid = true;
        _modelValidationError = null;
    }

    private void UpdateSystemPrompt(string value) => Session.SetSystemPrompt(value);

    private void SetPermission(string toolName, PermissionLevel? perm)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { Permission = perm };
        ApplyEntry(toolName, next);
    }

    private void SetRestrict(string toolName, bool? restrict)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { RestrictToWorkspace = restrict };
        ApplyEntry(toolName, next);
    }

    private void ApplyEntry(string toolName, ToolPermissionSettings entry)
    {
        // Drop the entry entirely if nothing is set, so the JSON stays clean.
        var collapsed = (entry.Permission is null && entry.RestrictToWorkspace is null) ? null : entry;
        Session.SetToolEntry(CurrentTier, toolName, collapsed);
    }

    private static Color PermColor(PermissionLevel level) => level switch
    {
        PermissionLevel.Allow => Color.Success,
        PermissionLevel.Deny  => Color.Error,
        _                     => Color.Warning,
    };

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
    }
}
