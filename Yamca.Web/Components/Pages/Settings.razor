    private void ConfirmEndpointDialog()
    {
        if (string.IsNullOrWhiteSpace(_epFormBaseUrl)) return;

        var name = string.IsNullOrWhiteSpace(_epFormName) ? null : _epFormName.Trim();
        var baseUrl = _epFormBaseUrl.Trim();
        var apiKey = _epFormApiKey ?? string.Empty;
        var model = (_epFormModel ?? string.Empty).Trim();

        if (_endpointEditId is Guid id)
        {
            var existing = Session.Endpoints.FindById(id);
            if (existing is null) return;
            Session.UpdateEndpoint(existing with { Name = name, BaseUrl = baseUrl, ApiKey = apiKey, Model = model });
        }
        else
        {
            Session.AddEndpoint(new EndpointSettings(Guid.NewGuid(), name, baseUrl, apiKey, model));
        }
        _endpointDialogOpen = false;
    }

