@page "/settings"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Chat

<PageTitle>Settings — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading from localStorage&hellip;</MudText>
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Endpoint</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">
            OpenAI-compatible local server (llama.cpp, vllm, etc.). Stored in <code>@Keys.GlobalKey</code>.
        </MudText>
        <MudTextField Value="Session.Endpoint.BaseUrl"
                      ValueChanged="@((string v) => UpdateEndpoint(Session.Endpoint with { BaseUrl = v }))"
                      T="string" Label="Base URL" Variant="Variant.Outlined" Class="mb-2" />
        <MudTextField Value="Session.Endpoint.ApiKey"
                      ValueChanged="@((string v) => UpdateEndpoint(Session.Endpoint with { ApiKey = v }))"
                      T="string" Label="API key" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mb-2" />
        <div class="d-flex align-center" style="gap: 4px;">
            <MudTextField Value="Session.Endpoint.Model"
                          ValueChanged="OnModelChanged"
                          T="string" Label="Model" Variant="Variant.Outlined"
                          DebounceInterval="500"
                          Class="flex-grow-1" />
            <MudTooltip Text="Browse available models">
                <MudIconButton Icon="@Icons.Material.Filled.Search"
                               OnClick="OpenModelPicker"
                               aria-label="Browse available models" />
            </MudTooltip>

            @if (_modelValidating)
            {
                <MudTooltip Text="Checking model against endpoint…">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                </MudTooltip>
            }
            else if (_modelValid is true)
            {
                <MudTooltip Text="Model is available on the endpoint">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                </MudTooltip>
            }
            else if (_modelValid is false)
            {
                <MudTooltip Text="@(_modelValidationError ?? "Model not found on endpoint")">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                </MudTooltip>
            }
        </div>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            Optional for single-model hosts like llama.cpp (the server ignores this field and serves whatever it was launched with). Required for multi-model hosts (OpenAI, Ollama, OpenRouter, LM Studio). Click the search icon to list models the endpoint reports.
        </MudText>
    </MudPaper>

    <MudDialog @bind-Visible="_modelPickerOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Available models</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2">
                Fetched from <code>@Session.Endpoint.BaseUrl</code>/models.
            </MudText>
            @if (_modelsLoading)
            {
                <div class="d-flex align-center">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Class="ml-2">Loading…</MudText>
                </div>
            }
            else if (_modelsError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_modelsError</MudAlert>
            }
            else if (_models.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">The endpoint returned no models.</MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var id in _models)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.SmartToy" OnClick="@(() => SelectModel(id))">
                            <code>@id</code>
                        </MudListItem>
                    }
                </MudList>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _modelPickerOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Workspace</MudText>
        <MudText Typo="Typo.body2">Root: <code>@Workspace.RootPath</code></MudText>
        <MudText Typo="Typo.caption">
            localStorage key:
            <MudTooltip Text="@Keys.ProjectKey" Placement="Placement.Top">
                <code>@ShortKey(Keys.ProjectKey)</code>
            </MudTooltip>
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">System prompt</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">
            The current workspace path is sent automatically as separate context — no need to mention it here.
        </MudText>
        <MudTextField Value="Session.SystemPrompt"
                      ValueChanged="@((string v) => UpdateSystemPrompt(v))"
                      T="string" Variant="Variant.Outlined" Lines="4" />
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Chat</MudText>

        <MudSwitch T="bool" Value="Session.MarkdownEnabled"
                   ValueChanged="@((bool v) => Session.SetMarkdownEnabled(v))"
                   Color="Color.Primary"
                   Label="Markdown rendering" />
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            A capability hint is appended to the system prompt either way: when on, the model is told its replies are rendered as Markdown; when off, it's told to reply in plain text.
        </MudText>

        <MudSelect T="ReasoningDisplay" Value="Session.ReasoningDisplay"
                   ValueChanged="@((ReasoningDisplay v) => Session.SetReasoningDisplay(v))"
                   Label="Reasoning blocks"
                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                   Class="mt-3">
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Hidden">Hidden</MudSelectItem>
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Collapsed">Collapsed (default)</MudSelectItem>
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Expanded">Expanded</MudSelectItem>
        </MudSelect>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            How to display chain-of-thought emitted by reasoning models inside <code>&lt;think&gt;</code>, <code>&lt;thinking&gt;</code>, or <code>&lt;reasoning&gt;</code> tags (Qwen3, QwQ, DeepSeek-R1, etc.). Collapsed mode shows it live while streaming and auto-closes when the answer begins.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">Tool permissions</MudText>
            <MudSpacer />
            <MudTabs @bind-ActivePanelIndex="_tierIndex" Rounded="true" Color="Color.Primary">
                <MudTabPanel Text="Project" />
                <MudTabPanel Text="Global" />
            </MudTabs>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Project overrides Global. Unset (<em>inherit</em>) falls through to Global, then to the tool's default.
            @if (_tierIndex == 0)
            {
                <text>Stored in </text>
                <MudTooltip Text="@Keys.ProjectKey" Placement="Placement.Top"><code>@ShortKey(Keys.ProjectKey)</code></MudTooltip><text>.</text>
            }
            else { <text>Stored in <code>@Keys.GlobalKey</code>.</text> }
        </MudText>

        <MudTable Items="Tools.GetSettingsTools()" Hover="true" Dense="true" Class="mud-table-bordered">
            <HeaderContent>
                <MudTh>Tool</MudTh>
                <MudTh>Permission</MudTh>
                <MudTh>Restrict to workspace</MudTh>
                <MudTh>Effective</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudTooltip Text="@context.Description" Placement="Placement.Right">
                        <MudText Typo="Typo.body2"><b>@ToolDisplayName(context.Name)</b></MudText>
                    </MudTooltip>
                </MudTd>
                <MudTd>
                    @{
                        var entry = CurrentMap.Get(context.Name);
                        var selected = entry?.Permission;
                    }
                    <MudSelect T="PermissionLevel?" Value="selected"
                               ValueChanged="@((PermissionLevel? p) => SetPermission(context.Name, p))"
                               Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)null)">inherit</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Allow)">Allow</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Ask)">Ask</MudSelectItem>
                        <MudSelectItem T="PermissionLevel?" Value="@((PermissionLevel?)PermissionLevel.Deny)">Deny</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd>
                    @if (context.SupportsWorkspaceRestriction)
                    {
                        var restrict = CurrentMap.Get(context.Name)?.RestrictToWorkspace;
                        <MudSelect T="bool?" Value="restrict"
                                   ValueChanged="@((bool? b) => SetRestrict(context.Name, b))"
                                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                            <MudSelectItem T="bool?" Value="@((bool?)null)">inherit</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)true)">On</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)false)">Off</MudSelectItem>
                        </MudSelect>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">n/a</MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@PermColor(Resolver.Resolve(context.Name))">
                        @Resolver.Resolve(context.Name)
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">Instruction files</MudText>
            <MudSpacer />
            <MudTabs @bind-ActivePanelIndex="_instrTierIndex" Rounded="true" Color="Color.Primary">
                <MudTabPanel Text="Project" />
                <MudTabPanel Text="Global" />
            </MudTabs>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Files read from the current workspace and added to the chat context as additional system messages at session start. Each entry is a bare filename or a relative path; absolute paths are not allowed. Missing files are silently skipped.
            @if (_instrTierIndex == 0)
            {
                <text> Stored in </text>
                <MudTooltip Text="@Keys.ProjectKey" Placement="Placement.Top"><code>@ShortKey(Keys.ProjectKey)</code></MudTooltip><text>.</text>
            }
            else { <text> Stored in <code>@Keys.GlobalKey</code>.</text> }
        </MudText>

        @if (_instrTierIndex == 0)
        {
            <MudSwitch T="bool" Value="Session.ProjectInheritsGlobalInstructions"
                       ValueChanged="@((bool v) => Session.SetProjectInheritsGlobalInstructions(v))"
                       Color="Color.Primary" Class="mb-2"
                       Label="Inherit Global instruction files" />
        }

        @{
            var rows = CurrentRows;
        }

        @if (rows.Count == 0)
        {
            <div class="mb-2">
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                    No instruction files configured.
                </MudText>
            </div>
        }
        else
        {
            <div class="mb-2">
                @foreach (var row in rows)
                {
                    <div @key="row.Id" class="d-flex align-center mb-1" style="gap: 4px;">
                        <MudTextField T="string" Value="@row.Path"
                                      ValueChanged="@((string v) => OnRowPathChanged(row, v))"
                                      Immediate="false"
                                      DebounceInterval="400"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Placeholder="AGENTS.md or docs/style.md" />
                        <MudTooltip Text="Browse workspace">
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           OnClick="@(() => OpenInstructionPicker(row))"
                                           aria-label="Browse workspace" />
                        </MudTooltip>
                        @if (!string.IsNullOrWhiteSpace(row.Path) && !InstructionFileExists(row.Path))
                        {
                            <MudTooltip Text="File not found under the workspace. It will be skipped at session start.">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                            </MudTooltip>
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => RemoveRow(row))"
                                       aria-label="Remove" />
                    </div>
                }
            </div>
        }

        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddInstructionPath" Class="mt-2">
            Add file
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">Registered scripts</MudText>
            <MudSpacer />
            <MudTabs @bind-ActivePanelIndex="_scriptTierIndex" Rounded="true" Color="Color.Primary">
                <MudTabPanel Text="Project" />
                <MudTabPanel Text="Global" />
            </MudTabs>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Scripts the LLM may run via <code>execute_script</code> without prompting. Each path is workspace-relative. Files inside a registered directory count as registered. Descriptions are optional but are shown to the LLM at session start so it can pick the right entry.
            @if (_scriptTierIndex == 0)
            {
                <text> Stored in </text>
                <MudTooltip Text="@Keys.ProjectKey" Placement="Placement.Top"><code>@ShortKey(Keys.ProjectKey)</code></MudTooltip><text>.</text>
            }
            else { <text> Stored in <code>@Keys.GlobalKey</code>.</text> }
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Files</MudText>
        @{ var fileRows = CurrentScriptFileRows; }
        @if (fileRows.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)" Class="mb-1">No registered script files.</MudText>
        }
        else
        {
            <div class="mb-2">
                @foreach (var row in fileRows)
                {
                    <div @key="row.Id" class="d-flex align-center mb-1" style="gap: 4px;">
                        <MudTextField T="string" Value="@row.Path"
                                      ValueChanged="@((string v) => OnScriptPathChanged(row, v, isDirectory: false))"
                                      DebounceInterval="400"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Placeholder="build.ps1" />
                        <MudTextField T="string" Value="@(row.Description ?? string.Empty)"
                                      ValueChanged="@((string v) => OnScriptDescriptionChanged(row, v, isDirectory: false))"
                                      DebounceInterval="400"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Placeholder="Description (optional)" />
                        @if (!string.IsNullOrWhiteSpace(row.Path) && !ScriptFileExists(row.Path))
                        {
                            <MudTooltip Text="File not found under the workspace.">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                            </MudTooltip>
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => RemoveScriptRow(row, isDirectory: false))"
                                       aria-label="Remove" />
                    </div>
                }
            </div>
        }
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => AddScriptRow(isDirectory: false))">
            Add file
        </MudButton>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1">Directories</MudText>
        @{ var dirRows = CurrentScriptDirectoryRows; }
        @if (dirRows.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)" Class="mb-1">No registered script directories.</MudText>
        }
        else
        {
            <div class="mb-2">
                @foreach (var row in dirRows)
                {
                    <div @key="row.Id" class="d-flex align-center mb-1" style="gap: 4px;">
                        <MudTextField T="string" Value="@row.Path"
                                      ValueChanged="@((string v) => OnScriptPathChanged(row, v, isDirectory: true))"
                                      DebounceInterval="400"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Placeholder=".scripts" />
                        <MudTextField T="string" Value="@(row.Description ?? string.Empty)"
                                      ValueChanged="@((string v) => OnScriptDescriptionChanged(row, v, isDirectory: true))"
                                      DebounceInterval="400"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Placeholder="Description (optional)" />
                        @if (!string.IsNullOrWhiteSpace(row.Path) && !ScriptDirectoryExists(row.Path))
                        {
                            <MudTooltip Text="Directory not found under the workspace.">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                            </MudTooltip>
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => RemoveScriptRow(row, isDirectory: true))"
                                       aria-label="Remove" />
                    </div>
                }
            </div>
        }
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CreateNewFolder"
                   OnClick="@(() => AddScriptRow(isDirectory: true))">
            Add directory
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">MCP servers</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenMcpAddDialog">
                Add server
            </MudButton>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Model Context Protocol servers contribute additional tools to the agent. Tools appear as
            <code>mcp__&lt;id&gt;__&lt;tool&gt;</code> and are deferred — the LLM calls <code>load_tool</code>
            before using one. Stored in <code>@McpConfigStore.StorageKey</code>; shared by every chat
            session in this Yamca process.
        </MudText>

        @{
            var mcpConfigs = McpStore.Configs;
            var serversById = McpRegistry.Servers.ToDictionary(s => s.Config.Id, StringComparer.Ordinal);
        }

        @if (mcpConfigs.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                No servers configured. Paste the JSON snippet from a server's README to add one.
            </MudText>
        }
        else
        {
            <MudTable Items="mcpConfigs" Hover="true" Dense="true" Class="mud-table-bordered">
                <HeaderContent>
                    <MudTh>Server</MudTh>
                    <MudTh>Transport</MudTh>
                    <MudTh>Target</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Tools</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        serversById.TryGetValue(context.Id, out var conn);
                        var status = conn?.Status ?? (context.Enabled ? McpServerStatus.Connecting : McpServerStatus.Disabled);
                        var failure = conn?.FailureMessage;
                        var toolCount = conn?.Adapters.Count ?? 0;
                        var isStdio = context.TransportKind == McpTransportKind.Stdio;
                    }
                    <MudTd>
                        <MudSwitch T="bool" Value="context.Enabled"
                                   ValueChanged="@((bool v) => OnMcpToggle(context.Id, v))"
                                   Color="Color.Primary" />
                        <code>@context.Id</code>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                            @(isStdio ? "stdio" : "http")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="@FormatMcpTooltip(context)" Placement="Placement.Top">
                            <code>@FormatMcpTarget(context)</code>
                        </MudTooltip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@McpStatusColor(status)">@status</MudChip>
                        @if (!string.IsNullOrEmpty(failure))
                        {
                            <MudTooltip Text="@failure" Placement="Placement.Right">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd>@toolCount</MudTd>
                    <MudTd>
                        <MudTooltip Text="Test connection (restart this server)">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                           OnClick="@(() => TestMcpConnection(context.Id))"
                                           aria-label="Test connection" />
                        </MudTooltip>
                        @if (isStdio)
                        {
                            <MudTooltip Text="Run the command with --version to triage launch failures">
                                <MudIconButton Icon="@Icons.Material.Filled.MedicalServices" Size="Size.Small"
                                               OnClick="@(() => RunMcpDiagnostics(context.Id))"
                                               aria-label="Diagnostics" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Edit configuration">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenMcpEditDialog(context.Id))"
                                           aria-label="Edit server" />
                        </MudTooltip>
                        @if (conn is not null)
                        {
                            <MudTooltip Text="Show log">
                                <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small"
                                               OnClick="@(() => OpenMcpLogDialog(context.Id))"
                                               aria-label="Show log" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Remove">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           OnClick="@(() => RemoveMcpServer(context.Id))"
                                           aria-label="Remove server" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <MudDialog @bind-Visible="_mcpAddOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>@(_mcpEditOriginalId is null ? "Add MCP server" : $"Edit MCP server — {_mcpEditOriginalId}")</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2">
                Paste the JSON snippet from the server's README. Either the wrapped form
                (<code>{ "id": ..., "config": { ... } }</code>) or the bare <code>mcp.json</code>
                shape works. Supply <code>command</code>/<code>args</code> for stdio, or
                <code>url</code>/<code>headers</code> for streamable HTTP / SSE.
                Optional <code>timeoutSeconds</code> overrides the 30s per-call default.
            </MudText>
            <MudTextField T="string" @bind-Value="_mcpAddId"
                          Label="Id (slug)"
                          HelperText="ASCII letters, digits, hyphen, or underscore. Leave empty if the pasted JSON already has an &quot;id&quot; field."
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Placeholder="filesystem" />
            <MudTextField T="string" @bind-Value="_mcpAddJson"
                          Label="Config JSON"
                          Variant="Variant.Outlined" Lines="12"
                          Placeholder="@McpJsonPlaceholder" />
            @if (!string.IsNullOrEmpty(_mcpAddError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_mcpAddError</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpAddOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmMcpDialog">
                @(_mcpEditOriginalId is null ? "Add" : "Save")
            </MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_mcpDiagOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>Diagnostics — <code>@_mcpDiagServerId</code></TitleContent>
        <DialogContent>
            @if (_mcpDiagRunning)
            {
                <div class="d-flex align-center" style="gap: 8px;">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    <MudText Typo="Typo.body2">Running probe&hellip;</MudText>
                </div>
            }
            else if (_mcpDiagResult is { } d)
            {
                <MudAlert Severity="@(d.Success ? Severity.Success : Severity.Warning)" Dense="true" Class="mb-2">
                    @(d.Success
                        ? $"Command exited 0 in {d.Elapsed.TotalMilliseconds:F0}ms."
                        : (d.Error ?? $"Command exited {d.ExitCode?.ToString() ?? "?"}."))
                </MudAlert>
                <MudText Typo="Typo.caption">Resolved command</MudText>
                <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem;">@d.ResolvedCommand --version</pre>
                @if (!string.IsNullOrEmpty(d.Stdout))
                {
                    <MudText Typo="Typo.caption">stdout</MudText>
                    <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem; max-height:160px; overflow:auto;">@d.Stdout</pre>
                }
                @if (!string.IsNullOrEmpty(d.Stderr))
                {
                    <MudText Typo="Typo.caption">stderr</MudText>
                    <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem; max-height:160px; overflow:auto;">@d.Stderr</pre>
                }
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpDiagOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_mcpLogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>MCP server log — <code>@_mcpLogServerId</code></TitleContent>
        <DialogContent>
            @{
                var conn = _mcpLogServerId is null ? null : McpRegistry.Servers.FirstOrDefault(s => s.Config.Id == _mcpLogServerId);
                var entries = conn?.Log.Snapshot() ?? Array.Empty<McpServerLogBuffer.LogEntry>();
            }
            @if (entries.Count == 0)
            {
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                    No log entries yet.
                </MudText>
            }
            else
            {
                <pre class="mud-paper-outlined pa-2" style="overflow:auto; max-height: 360px; font-size: 0.78rem;">@string.Join('\n', entries.Select(e => $"{e.Timestamp:HH:mm:ss}  [{e.Source}] {e.Line}"))</pre>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpLogOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Backup</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">
            Export your Global settings to a JSON file, or restore them from one. Project settings (stored per workspace in <code>@ShortKey(Keys.ProjectKey)</code>) are not included.
        </MudText>
        <div class="d-flex align-center" style="gap: 8px;">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="OpenExportDialog">
                Export Global settings&hellip;
            </MudButton>
            <MudFileUpload T="IBrowserFile" Accept=".json,application/json" FilesChanged="OnImportFileChanged">
                <CustomContent Context="fileUpload">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileUpload"
                               OnClick="@(() => fileUpload.OpenFilePickerAsync())">
                        Import Global settings&hellip;
                    </MudButton>
                </CustomContent>
                <SelectedTemplate></SelectedTemplate>
            </MudFileUpload>
        </div>
    </MudPaper>

    <MudDialog @bind-Visible="_exportDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Export Global settings</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="mb-2">
                Includes endpoint, system prompt, Markdown toggle, tool permissions, and global instruction files.
            </MudText>
            <MudCheckBox T="bool" Value="_exportIncludeApiKey"
                         ValueChanged="@((bool v) => _exportIncludeApiKey = v)"
                         Color="Color.Primary"
                         Label="Include API key (sensitive)" />
            @if (_exportIncludeApiKey)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                    The exported file will contain your API key in plaintext.
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _exportDialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="DownloadExport">Download</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_importDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Replace Global settings?</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2">
                Replace your Global settings with the contents of <code>@_importFileName</code>? This overwrites your endpoint, system prompt, tool permissions, and instruction files. Project settings are unaffected.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelImport">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmImport">Replace</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_pickerOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            Choose instruction file
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.caption" Class="mb-2">
                Workspace: <code>@Workspace.RootPath</code>
            </MudText>
            <div class="d-flex align-center mb-2" style="gap: 4px;">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                               Disabled="@string.IsNullOrEmpty(_pickerDir)"
                               OnClick="PickerNavigateUp"
                               aria-label="Up" />
                <MudText Typo="Typo.body2">
                    /@(_pickerDir)
                </MudText>
            </div>
            @if (_pickerListing is null || _pickerListing.Entries.Count == 0)
            {
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                    Empty directory.
                </MudText>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var entry in _pickerListing.Entries)
                    {
                        <MudListItem T="string"
                                     Icon="@(entry.IsDirectory ? Icons.Material.Filled.Folder : Icons.Material.Filled.Description)"
                                     OnClick="@(() => PickerSelect(entry))">
                            @entry.Name
                        </MudListItem>
                    }
                </MudList>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _pickerOpen = false)">Cancel</MudButton>
        </DialogActions>
    </MudDialog>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private IToolRegistry Tools { get; set; } = default!;
    [Inject] private IPermissionResolver Resolver { get; set; } = default!;
    [Inject] private WorkspaceKey Keys { get; set; } = default!;
    [Inject] private EndpointHealthService HealthService { get; set; } = default!;
    [Inject] private IWorkspace Workspace { get; set; } = default!;
    [Inject] private WorkspaceBrowser Browser { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private McpConfigStore McpStore { get; set; } = default!;
    [Inject] private IMcpRegistry McpRegistry { get; set; } = default!;

    private static string ToolDisplayName(string name) => name switch
    {
        "execute_registered_script" => "execute_script (registered)",
        "execute_discovered_script" => "execute_script (discovered)",
        _ => name,
    };

    private bool _hydrated;
    private int _tierIndex; // 0 = Project, 1 = Global
    private int _instrTierIndex; // 0 = Project, 1 = Global

    private bool _pickerOpen;
    private InstructionRow? _pickerRow;
    private string _pickerDir = string.Empty;
    private WorkspaceBrowser.Listing? _pickerListing;

    private sealed class InstructionRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Path { get; set; } = string.Empty;
    }

    private readonly List<InstructionRow> _projectRows = new();
    private readonly List<InstructionRow> _globalRows = new();
    private List<InstructionRow> CurrentRows => _instrTierIndex == 0 ? _projectRows : _globalRows;

    private int _scriptTierIndex; // 0 = Project, 1 = Global

    private sealed class ScriptRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Path { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    private readonly List<ScriptRow> _projectScriptFiles = new();
    private readonly List<ScriptRow> _projectScriptDirs = new();
    private readonly List<ScriptRow> _globalScriptFiles = new();
    private readonly List<ScriptRow> _globalScriptDirs = new();

    private List<ScriptRow> CurrentScriptFileRows => _scriptTierIndex == 0 ? _projectScriptFiles : _globalScriptFiles;
    private List<ScriptRow> CurrentScriptDirectoryRows => _scriptTierIndex == 0 ? _projectScriptDirs : _globalScriptDirs;
    private SettingsTier CurrentScriptTier => _scriptTierIndex == 0 ? SettingsTier.Project : SettingsTier.Global;

    private bool _modelPickerOpen;
    private bool _modelsLoading;
    private string? _modelsError;
    private IReadOnlyList<string> _models = Array.Empty<string>();

    private bool _modelValidating;
    private bool? _modelValid;
    private string? _modelValidationError;
    private CancellationTokenSource? _validateCts;

    private static string ShortKey(string key)
    {
        const string prefix = "yamca.project.";
        if (key.StartsWith(prefix, StringComparison.Ordinal) && key.Length > prefix.Length + 8)
        {
            return $"{prefix}{key.AsSpan(prefix.Length, 8)}…";
        }
        return key;
    }

    private SettingsTier CurrentTier => _tierIndex == 0 ? SettingsTier.Project : SettingsTier.Global;
    private ToolSettingsMap CurrentMap => CurrentTier == SettingsTier.Project ? Session.Project : Session.Global;

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
        McpRegistry.Changed += OnMcpChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        if (!McpStore.Hydrated)
        {
            try { await McpStore.HydrateAsync(); }
            catch (Exception ex) { Snackbar.Add($"MCP hydrate failed: {ex.Message}", Severity.Warning); }
        }
        SyncRowsFromSession();
        _hydrated = true;
        StateHasChanged();
        _ = ValidateModelAsync();
    }

    private void OnMcpChanged() => InvokeAsync(StateHasChanged);

    private bool _mcpAddOpen;
    private string _mcpAddId = string.Empty;
    private string _mcpAddJson = string.Empty;
    private string? _mcpAddError;
    private string? _mcpEditOriginalId;

    private bool _mcpLogOpen;
    private string? _mcpLogServerId;

    private bool _mcpDiagOpen;
    private bool _mcpDiagRunning;
    private string? _mcpDiagServerId;
    private McpDiagnostics.DiagnosticsResult? _mcpDiagResult;

    private const string McpJsonPlaceholder = @"{
  ""command"": ""npx"",
  ""args"": [""-y"", ""@modelcontextprotocol/server-filesystem"", "".""],
  ""timeoutSeconds"": 30
}

// or for HTTP:
// { ""url"": ""https://example.com/mcp"", ""headers"": { ""Authorization"": ""Bearer ..."" } }";

    private void OpenMcpAddDialog()
    {
        _mcpEditOriginalId = null;
        _mcpAddId = string.Empty;
        _mcpAddJson = string.Empty;
        _mcpAddError = null;
        _mcpAddOpen = true;
    }

    private void OpenMcpEditDialog(string id)
    {
        var existing = McpStore.Configs.FirstOrDefault(c => string.Equals(c.Id, id, StringComparison.Ordinal));
        if (existing is null) return;
        _mcpEditOriginalId = id;
        _mcpAddId = id;
        _mcpAddJson = McpServerConfigJson.SerializeSingle(existing);
        _mcpAddError = null;
        _mcpAddOpen = true;
    }

    private async Task ConfirmMcpDialog()
    {
        McpConfigParseResult result;
        if (_mcpEditOriginalId is { } original)
        {
            result = await McpStore.ReplaceAsync(original, _mcpAddId, _mcpAddJson);
        }
        else
        {
            result = await McpStore.AddAsync(_mcpAddId, _mcpAddJson);
        }
        if (result.Config is null)
        {
            _mcpAddError = result.Error ?? "Could not parse config.";
            return;
        }
        _mcpAddOpen = false;
        var verb = _mcpEditOriginalId is null ? "added" : "saved";
        _mcpEditOriginalId = null;
        Snackbar.Add($"MCP server '{result.Config.Id}' {verb}.", Severity.Success);
    }

    private async Task RemoveMcpServer(string id)
    {
        await McpStore.RemoveAsync(id);
        Snackbar.Add($"MCP server '{id}' removed.", Severity.Info);
    }

    private async Task OnMcpToggle(string id, bool enabled) => await McpStore.SetEnabledAsync(id, enabled);

    private async Task TestMcpConnection(string id)
    {
        var ok = await McpRegistry.RestartAsync(id);
        Snackbar.Add(
            ok ? $"Restarting MCP server '{id}'…" : $"No active server '{id}' to restart.",
            ok ? Severity.Info : Severity.Warning);
    }

    private async Task RunMcpDiagnostics(string id)
    {
        var cfg = McpStore.Configs.FirstOrDefault(c => string.Equals(c.Id, id, StringComparison.Ordinal));
        if (cfg?.Stdio is null) return;

        _mcpDiagServerId = id;
        _mcpDiagResult = null;
        _mcpDiagRunning = true;
        _mcpDiagOpen = true;
        StateHasChanged();

        var result = await McpDiagnostics.ProbeStdioAsync(cfg.Stdio);
        _mcpDiagResult = result;
        _mcpDiagRunning = false;
        StateHasChanged();
    }

    private void OpenMcpLogDialog(string id)
    {
        _mcpLogServerId = id;
        _mcpLogOpen = true;
    }

    private static Color McpStatusColor(McpServerStatus status) => status switch
    {
        McpServerStatus.Ready => Color.Success,
        McpServerStatus.Failed => Color.Error,
        McpServerStatus.Connecting => Color.Warning,
        _ => Color.Default,
    };

    private static string FormatMcpTarget(McpServerConfig config) =>
        config.TransportKind == McpTransportKind.Http
            ? config.Http!.Url
            : config.Stdio!.Command;

    private static string FormatMcpTooltip(McpServerConfig config)
    {
        if (config.TransportKind == McpTransportKind.Http)
        {
            var headers = config.Http?.Headers is { Count: > 0 } h
                ? " (+ " + h.Count + " header" + (h.Count == 1 ? ")" : "s)")
                : string.Empty;
            return config.Http!.Url + headers;
        }
        var stdio = config.Stdio!;
        var args = stdio.Args.Count == 0 ? "" : " " + string.Join(' ', stdio.Args);
        var cwd = string.IsNullOrEmpty(stdio.WorkingDirectory) ? "" : $"\ncwd: {stdio.WorkingDirectory}";
        return $"{stdio.Command}{args}{cwd}";
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private void UpdateEndpoint(EndpointSettings ep) => Session.SetEndpoint(ep);

    private void OnModelChanged(string value)
    {
        UpdateEndpoint(Session.Endpoint with { Model = value });
        _ = ValidateModelAsync();
    }

    private async Task ValidateModelAsync()
    {
        _validateCts?.Cancel();
        var cts = new CancellationTokenSource();
        _validateCts = cts;

        var endpoint = Session.Endpoint;
        if (string.IsNullOrWhiteSpace(endpoint.Model))
        {
            _modelValid = null;
            _modelValidating = false;
            _modelValidationError = null;
            StateHasChanged();
            return;
        }

        _modelValidating = true;
        _modelValid = null;
        _modelValidationError = null;
        StateHasChanged();

        var result = await HealthService.ListModelsAsync(endpoint, cts.Token);
        if (cts.IsCancellationRequested) return;

        _modelValidating = false;
        if (!result.Success)
        {
            _modelValid = false;
            _modelValidationError = result.ErrorMessage;
        }
        else
        {
            var match = result.Models.Any(id => string.Equals(id, endpoint.Model, StringComparison.OrdinalIgnoreCase));
            _modelValid = match;
            _modelValidationError = match ? null : $"\"{endpoint.Model}\" is not in the {result.Models.Count}-model list returned by the endpoint.";
        }
        StateHasChanged();
    }

    private async Task OpenModelPicker()
    {
        _modelPickerOpen = true;
        _modelsLoading = true;
        _modelsError = null;
        _models = Array.Empty<string>();
        StateHasChanged();

        var result = await HealthService.ListModelsAsync(Session.Endpoint);
        _modelsLoading = false;
        if (result.Success)
        {
            _models = result.Models;
        }
        else
        {
            _modelsError = result.ErrorMessage;
        }
        StateHasChanged();
    }

    private void SelectModel(string id)
    {
        UpdateEndpoint(Session.Endpoint with { Model = id });
        _modelPickerOpen = false;
        _modelValid = true;
        _modelValidationError = null;
    }

    private void UpdateSystemPrompt(string value) => Session.SetSystemPrompt(value);

    private void SetPermission(string toolName, PermissionLevel? perm)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { Permission = perm };
        ApplyEntry(toolName, next);
    }

    private void SetRestrict(string toolName, bool? restrict)
    {
        var existing = CurrentMap.Get(toolName) ?? new ToolPermissionSettings();
        var next = existing with { RestrictToWorkspace = restrict };
        ApplyEntry(toolName, next);
    }

    private void ApplyEntry(string toolName, ToolPermissionSettings entry)
    {
        // Drop the entry entirely if nothing is set, so the JSON stays clean.
        var collapsed = (entry.Permission is null && entry.RestrictToWorkspace is null) ? null : entry;
        Session.SetToolEntry(CurrentTier, toolName, collapsed);
    }

    private static Color PermColor(PermissionLevel level) => level switch
    {
        PermissionLevel.Allow => Color.Success,
        PermissionLevel.Deny  => Color.Error,
        _                     => Color.Warning,
    };

    private SettingsTier CurrentInstructionTier => _instrTierIndex == 0 ? SettingsTier.Project : SettingsTier.Global;

    private void SyncRowsFromSession()
    {
        _projectRows.Clear();
        foreach (var p in Session.ProjectInstructionFiles)
            _projectRows.Add(new InstructionRow { Path = p });
        _globalRows.Clear();
        foreach (var p in Session.GlobalInstructionFiles)
            _globalRows.Add(new InstructionRow { Path = p });

        SyncScriptRows(Session.ProjectScripts, _projectScriptFiles, _projectScriptDirs);
        SyncScriptRows(Session.GlobalScripts, _globalScriptFiles, _globalScriptDirs);
    }

    private static void SyncScriptRows(ScriptRegistry registry, List<ScriptRow> files, List<ScriptRow> dirs)
    {
        files.Clear();
        foreach (var e in registry.Registered)
            files.Add(new ScriptRow { Path = e.Path, Description = e.Description });
        dirs.Clear();
        foreach (var d in registry.Directories)
            dirs.Add(new ScriptRow { Path = d.Path, Description = d.Description });
    }

    private void PersistScripts()
    {
        var files = CurrentScriptFileRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScript(NormalizeScriptPath(r.Path), NullIfBlank(r.Description)))
            .ToList();
        var dirs = CurrentScriptDirectoryRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Path))
            .Select(r => new RegisteredScriptDirectory(NormalizeScriptPath(r.Path), NullIfBlank(r.Description)))
            .ToList();
        Session.SetScripts(CurrentScriptTier, new ScriptRegistry(files, dirs));
    }

    private void AddScriptRow(bool isDirectory)
    {
        (isDirectory ? CurrentScriptDirectoryRows : CurrentScriptFileRows).Add(new ScriptRow());
        // Empty rows are filtered out on persist, so don't write yet — wait for the user to type a path.
    }

    private void RemoveScriptRow(ScriptRow row, bool isDirectory)
    {
        (isDirectory ? CurrentScriptDirectoryRows : CurrentScriptFileRows).Remove(row);
        PersistScripts();
    }

    private void OnScriptPathChanged(ScriptRow row, string value, bool isDirectory)
    {
        var normalized = NormalizeScriptPath(value ?? string.Empty);
        if (Path.IsPathRooted(normalized)) normalized = string.Empty;
        if (row.Path == normalized) return;
        row.Path = normalized;
        PersistScripts();
    }

    private void OnScriptDescriptionChanged(ScriptRow row, string value, bool isDirectory)
    {
        var trimmed = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (string.Equals(row.Description, trimmed, StringComparison.Ordinal)) return;
        row.Description = trimmed;
        PersistScripts();
    }

    private bool ScriptFileExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true;
        try { return File.Exists(Workspace.Resolve(relative)); }
        catch { return false; }
    }

    private bool ScriptDirectoryExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true;
        try { return Directory.Exists(Workspace.Resolve(relative)); }
        catch { return false; }
    }

    private static string NormalizeScriptPath(string raw) => raw.Trim().Replace('\\', '/');
    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s;

    private void PersistCurrentTier()
    {
        Session.SetInstructionFiles(CurrentInstructionTier, CurrentRows.Select(r => r.Path).ToList());
    }

    private void AddInstructionPath()
    {
        CurrentRows.Add(new InstructionRow());
        PersistCurrentTier();
    }

    private void RemoveRow(InstructionRow row)
    {
        CurrentRows.Remove(row);
        PersistCurrentTier();
    }

    private void OnRowPathChanged(InstructionRow row, string value)
    {
        var normalized = (value ?? string.Empty).Trim().Replace('\\', '/');
        if (Path.IsPathRooted(normalized)) normalized = string.Empty;
        if (row.Path == normalized) return;
        row.Path = normalized;
        PersistCurrentTier();
    }

    private void SetRowPath(InstructionRow row, string value)
    {
        row.Path = value ?? string.Empty;
        PersistCurrentTier();
    }

    private bool InstructionFileExists(string relative)
    {
        if (string.IsNullOrWhiteSpace(relative)) return true; // empty rows show no warning
        try
        {
            var resolved = Workspace.Resolve(relative);
            return File.Exists(resolved);
        }
        catch
        {
            return false;
        }
    }

    private void OpenInstructionPicker(InstructionRow row)
    {
        _pickerRow = row;
        _pickerDir = string.Empty;
        _pickerListing = Browser.List(_pickerDir);
        _pickerOpen = true;
    }

    private void PickerNavigateUp()
    {
        var parent = WorkspaceBrowser.Parent(_pickerDir);
        if (parent is null) return;
        _pickerDir = parent;
        _pickerListing = Browser.List(_pickerDir);
    }

    private void PickerSelect(WorkspaceBrowser.Entry entry)
    {
        if (entry.IsDirectory)
        {
            _pickerDir = entry.RelativePath;
            _pickerListing = Browser.List(_pickerDir);
            return;
        }

        if (_pickerRow is not null)
            SetRowPath(_pickerRow, entry.RelativePath);

        _pickerOpen = false;
        _pickerRow = null;
    }

    private bool _exportDialogOpen;
    private bool _exportIncludeApiKey;

    private bool _importDialogOpen;
    private string? _importFileName;
    private string? _importJson;

    private const long MaxImportBytes = 256 * 1024;

    private void OpenExportDialog()
    {
        _exportIncludeApiKey = false;
        _exportDialogOpen = true;
    }

    private async Task DownloadExport()
    {
        var json = Session.ExportGlobal(_exportIncludeApiKey);
        var filename = $"yamca-settings-{DateTime.Now:yyyyMMdd-HHmm}.json";
        _exportDialogOpen = false;
        try
        {
            await JS.InvokeAsync<bool>("yamcaStorage.downloadText", filename, json, "application/json");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnImportFileChanged(IBrowserFile? file)
    {
        if (file is null) return;
        if (file.Size > MaxImportBytes)
        {
            Snackbar.Add($"File is too large (max {MaxImportBytes / 1024} KB).", Severity.Error);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxImportBytes);
            using var reader = new StreamReader(stream);
            _importJson = await reader.ReadToEndAsync();
            _importFileName = file.Name;
            _importDialogOpen = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
        }
    }

    private void CancelImport()
    {
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;
    }

    private void ConfirmImport()
    {
        if (_importJson is null) { _importDialogOpen = false; return; }

        var result = Session.ImportGlobal(_importJson);
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;

        if (result.Success)
        {
            SyncRowsFromSession();
            Snackbar.Add("Global settings imported.", Severity.Success);
            _ = ValidateModelAsync();
        }
        else
        {
            Snackbar.Add($"Import failed: {result.Error}", Severity.Error);
        }
    }

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
        McpRegistry.Changed -= OnMcpChanged;
    }
}
