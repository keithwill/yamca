@page "/backup"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Backup — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading settings&hellip;</MudText>
}
else
{
    <SettingsSection Title="Backup">
        <Description>
            Export your User settings to a JSON file, restore them from one, or reset them to their
            original defaults. Project settings (stored per workspace on disk in <code>@Keys.ProjectFile</code>)
            are not included, and a reset leaves your configured endpoints (and any API keys) alone.
        </Description>
        <Actions>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="@(() => _resetDialogOpen = true)">
                Reset Defaults&hellip;
            </MudButton>
            <MudFileUpload T="IBrowserFile" Accept=".json,application/json" FilesChanged="OnImportFileChanged">
                <CustomContent Context="fileUpload">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileUpload"
                               OnClick="@(() => fileUpload.OpenFilePickerAsync())">
                        Import&hellip;
                    </MudButton>
                </CustomContent>
                <SelectedTemplate></SelectedTemplate>
            </MudFileUpload>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="OpenExportDialog">
                Export&hellip;
            </MudButton>
        </Actions>
    </SettingsSection>

    <MudDialog @bind-Visible="_resetDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Reset User settings to defaults?</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2">
                This restores your system prompt, Markdown and reasoning preferences, auto-compaction, tool permissions,
                instruction files, registered scripts, and subagents to the values they're seeded with on first run.
                Your configured endpoints and API keys are not changed. This cannot be undone.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _resetDialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ConfirmReset">Reset Defaults</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_exportDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Export User settings</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="mb-2">
                Includes endpoint, system prompt, Markdown toggle, tool permissions, and user instruction files.
            </MudText>
            <MudCheckBox T="bool" Value="_exportIncludeApiKey"
                         ValueChanged="@((bool v) => _exportIncludeApiKey = v)"
                         Color="Color.Primary"
                         Label="Include API key (sensitive)" />
            @if (_exportIncludeApiKey)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                    The exported file will contain your API key in plaintext.
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _exportDialogOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="DownloadExport">Download</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_importDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>Replace User settings?</TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2">
                Replace your User settings with the contents of <code>@_importFileName</code>? This overwrites your endpoint, system prompt, tool permissions, and instruction files. Project settings are unaffected.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelImport">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmImport">Replace</MudButton>
        </DialogActions>
    </MudDialog>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private IToolRegistry ToolRegistry { get; set; } = default!;
    [Inject] private SettingsLocation Keys { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private bool _hydrated;

    private bool _exportDialogOpen;
    private bool _exportIncludeApiKey;

    private bool _importDialogOpen;
    private string? _importFileName;
    private string? _importJson;

    private bool _resetDialogOpen;

    private const long MaxImportBytes = 256 * 1024;

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        _hydrated = true;
        StateHasChanged();
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private void OpenExportDialog()
    {
        _exportIncludeApiKey = false;
        _exportDialogOpen = true;
    }

    private async Task DownloadExport()
    {
        var json = Session.ExportUser(_exportIncludeApiKey);
        var filename = $"yamca-settings-{DateTime.Now:yyyyMMdd-HHmm}.json";
        _exportDialogOpen = false;
        try
        {
            await JS.InvokeAsync<bool>("yamcaStorage.downloadText", filename, json, "application/json");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnImportFileChanged(IBrowserFile? file)
    {
        if (file is null) return;
        if (file.Size > MaxImportBytes)
        {
            Snackbar.Add($"File is too large (max {MaxImportBytes / 1024} KB).", Severity.Error);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxImportBytes);
            using var reader = new StreamReader(stream);
            _importJson = await reader.ReadToEndAsync();
            _importFileName = file.Name;
            _importDialogOpen = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
        }
    }

    private void CancelImport()
    {
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;
    }

    private void ConfirmImport()
    {
        if (_importJson is null) { _importDialogOpen = false; return; }

        var result = Session.ImportUser(_importJson);
        _importDialogOpen = false;
        _importJson = null;
        _importFileName = null;

        if (result.Success)
        {
            Snackbar.Add("User settings imported.", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Import failed: {result.Error}", Severity.Error);
        }
    }

    private void ConfirmReset()
    {
        _resetDialogOpen = false;
        Session.ResetUserToDefaults(ToolRegistry.GetSettingsTools());
        Snackbar.Add("User settings reset to defaults.", Severity.Success);
    }

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
    }
}
