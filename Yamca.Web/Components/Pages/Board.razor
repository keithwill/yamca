@page "/board"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Board
@using Yamca.Agent.Git
@using Yamca.Agent.Workspace
@using Yamca.Web.Components.Board
@using Yamca.Web.Components.Branching
@using Yamca.Web.Components.Chat
@using Yamca.Web.Services
@using WorkspaceImpl = Yamca.Agent.Workspace.Workspace
@inject IWorkspace Workspace
@inject BoardService BoardSvc
@inject GitService Git
@inject IDialogService Dialogs
@inject ChatSessionManager Manager
@inject BoardStepLauncher Launcher
@inject ISessionSettings Session
@inject SettingsHydrator Hydrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Yamca - Dev Board</PageTitle>

@if (!_hydrated)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
        <MudProgressCircular Indeterminate="true" />
        <MudText Class="ml-2 d-inline" Typo="Typo.body2">Loading…</MudText>
    </MudContainer>
}
else if (_snapshot.Columns.Count == 0)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8">
        <MudText Typo="Typo.h6" GutterBottom="true">No dev board yet</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            Create a <code>.yamca/board</code> directory with numeric-prefixed column folders.
            A folder whose <code>instructions.md</code> has content is a work step run in chat; an
            empty <code>instructions.md</code> marks a resting column whose cards are just promoted
            onward. Initialize it with the default idea → analyze → implement → verify → done columns?
        </MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.ViewKanban" OnClick="InitializeBoardAsync">
            Initialize board
        </MudButton>
    </MudContainer>
}
else
{
    <div class="yamca-board">
        @foreach (var column in _snapshot.Columns)
        {
            <div class="yamca-board-lane">
                <div class="yamca-board-lane-header">
                    <span class="flex-grow-1">@column.DisplayName</span>
                    @if (column.Order == _snapshot.Columns[0].Order)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                       OnClick="@(() => AddCardAsync(column))" aria-label="New card" />
                    }
                </div>
                <div class="yamca-board-lane-cards @(_dragOverColumn == column.DirectoryName ? "yamca-board-lane-cards--dragover" : "")"
                     @ondragover:preventDefault="true"
                     @ondragenter="@(() => OnDragEnter(column))"
                     @ondrop:preventDefault="true"
                     @ondrop="@(() => OnDropAsync(column))">
                    @if (column.Cards.Count == 0)
                    {
                        <div class="yamca-board-empty">No cards</div>
                    }
                    else
                    {
                        @foreach (var card in column.Cards)
                        {
                            var c = card;
                            var done = c.Subtasks.Count(s => s.Done);
                            var total = c.Subtasks.Count;
                            <MudPaper Class="yamca-board-card" Elevation="3"
                                      draggable="true"
                                      @ondragstart="@(() => OnDragStart(c, column))"
                                      @ondragend="OnDragEnd"
                                      @onclick="@(() => OpenCardAsync(c, column))">
                                <div class="yamca-board-card-title">@c.Title</div>
                                <div class="yamca-board-card-meta">
                                    <span>#@c.Id</span>
                                    @if (total > 0)
                                    {
                                        <span>@done/@total subtasks</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(c.Branch))
                                    {
                                        <span>⎇ @c.Branch</span>
                                    }
                                </div>
                            </MudPaper>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _hydrated;
    private BoardSnapshot _snapshot = BoardSnapshot.Empty;

    // Branch name → worktree root path, from the last refresh's `git worktree list`. This is the
    // same signal ReadForDisplay uses to overlay a card's worktree board: a card whose branch is a
    // key here has a *live* binding; a card with a `branch:` attribute but no entry here is bound in
    // intent only (branch never started, merged, or deleted) and effectively lives on the parent
    // board — so its dialog offers promote/run-fresh, not merge/open-chat against a dead worktree.
    private IReadOnlyDictionary<string, string> _branchWorktrees =
        new Dictionary<string, string>(StringComparer.Ordinal);

    // In-flight drag state for moving a card between columns. The card and the column it was picked
    // up from are captured on dragstart; _dragOverColumn drives the drop-target highlight and is keyed
    // on DirectoryName (the same key MoveCardAsync compares to short-circuit a same-column drop).
    private BoardCard? _draggedCard;
    private BoardColumn? _draggedFromColumn;
    private string? _dragOverColumn;

    protected override void OnInitialized() => Manager.Changed += OnSessionsChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Hydrator.HydrateAsync();   // load endpoints/settings for the step-run modal
            await RefreshAsync();
            _hydrated = true;
            StateHasChanged();
        }
    }

    private void OnSessionsChanged() => InvokeAsync(StateHasChanged);

    // A branch-bound card lives and moves inside its branch's worktree board, so overlay each such
    // card with its worktree copy; the status falls back to the root board once the branch (and its
    // worktree) is merged away. Worktrees are repo-scoped, so we enumerate them from the repo root.
    private async Task RefreshAsync()
    {
        var repoRoot = Workspace.RepositoryRoot;
        var worktrees = await Git.ListWorktreesAsync(repoRoot, CancellationToken.None);
        var branchWorktrees = new Dictionary<string, string>(StringComparer.Ordinal);
        foreach (var (path, branch) in worktrees)
            if (!string.IsNullOrEmpty(branch))
                branchWorktrees[branch!] = path;
        _branchWorktrees = branchWorktrees;
        _snapshot = BoardSvc.ReadForDisplay(repoRoot, branchWorktrees);
    }

    private static DialogOptions Small() => new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private async Task InitializeBoardAsync()
    {
        var boardDir = BoardService.BoardDirectory(Workspace.RepositoryRoot);
        foreach (var (dir, instr) in DefaultColumns)
        {
            try
            {
                var d = Path.Combine(boardDir, dir);
                Directory.CreateDirectory(d);
                // Every column gets an instructions.md, even resting columns (written empty): it both
                // marks the column resting and keeps its directory tracked, since git ignores empty dirs.
                var instrPath = Path.Combine(d, BoardService.InstructionsFileName);
                if (!File.Exists(instrPath)) await File.WriteAllTextAsync(instrPath, instr ?? "");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Could not initialize board: {ex.Message}", Severity.Error);
                return;
            }
        }
        await RefreshAsync();
        Snackbar.Add("Board initialized under .yamca/board.", Severity.Success);
    }

    private async Task AddCardAsync(BoardColumn column)
    {
        var dialog = await Dialogs.ShowAsync<NewCardDialog>("New card", Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not NewCardDialog.Result data) return;

        var id = BoardSvc.NextCardId(Workspace.RepositoryRoot);
        var path = Path.Combine(column.AbsolutePath, BoardService.CardFileName(id, data.Title));
        var content = $"---\nid: {id}\ntitle: \"{data.Title.Replace("\"", "'")}\"\n---\n\n{data.Body}\n";
        try
        {
            await File.WriteAllTextAsync(path, content);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not create card: {ex.Message}", Severity.Error);
            return;
        }
        await RefreshAsync();
        StateHasChanged();
    }

    private async Task OpenCardAsync(BoardCard card, BoardColumn column)
    {
        // Branch field defaults / existing branches are gathered up front so the dialog can
        // offer them inline (combobox + endpoint dropdown) instead of chaining more modals.
        var existingBranches = await Git.ListBranchesAsync(Workspace.RepositoryRoot, CancellationToken.None);
        var next = _snapshot.NextColumn(column);
        var parameters = new DialogParameters
        {
            ["Card"] = card,
            ["WorkspaceRoot"] = Workspace.RepositoryRoot,
            ["ColumnDisplayName"] = column.DisplayName,
            ["IsWorkColumn"] = BoardSvc.HasInstructions(Workspace.RepositoryRoot, column.DirectoryName),
            ["NextColumnDisplayName"] = next?.DisplayName,
            ["CanRunStep"] = Manager.CanCreate,
            ["Endpoints"] = Session.Endpoints.Items,
            ["DefaultEndpointId"] = Session.Endpoints.DefaultId,
            ["ExistingBranches"] = existingBranches,
            ["PresumptiveBranch"] = BoardService.PresumptiveBranch(card.Id, card.Title),
            // A binding is live only when the card's branch has a worktree in this refresh's map —
            // the same test ReadForDisplay uses to decide whether to overlay the worktree board.
            ["BranchWorktreeLive"] = !string.IsNullOrWhiteSpace(card.Branch)
                                     && _branchWorktrees.ContainsKey(card.Branch!),
            ["Columns"] = _snapshot.Columns
                .Select(c => new CardDetailDialog.ColumnOption(c.DirectoryName, c.DisplayName)).ToList(),
            ["CurrentColumnDirectory"] = column.DirectoryName,
        };
        var dialog = await Dialogs.ShowAsync<CardDetailDialog>($"#{card.Id} {card.Title}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is CardDetailDialog.Result run)
            await RunStepAsync(card, column, run);
        else if (result.Data is CardDetailDialog.Promotion && next is not null)
            await PromoteCardAsync(card, column, next);
        else if (result.Data is CardDetailDialog.MergeRequest)
            await MergeCardAsync(card);
        else if (result.Data is CardDetailDialog.OpenChatRequest)
            await OpenCardChatAsync(card);
        else if (result.Data is CardDetailDialog.MoveRequest move)
        {
            var target = _snapshot.FindColumn(move.ToColumnDirectory);
            if (target is not null) await MoveCardAsync(card, column, target);
        }
    }

    // Merge a branch-bound card's branch back into the base branch by reusing the same merge dialog
    // the chat panel uses. The merge itself runs against the repository's base checkout, so the
    // WorktreeInfo anchors BasePath at the repository root (not the sandbox RootPath the chat flow
    // uses as a session key). The branch's worktree path is only needed for the optional post-merge
    // cleanup; if it has already been removed, fall back to its conventional path so the cleanup's
    // worktree removal is a harmless no-op rather than a crash.
    private async Task MergeCardAsync(BoardCard card)
    {
        if (string.IsNullOrWhiteSpace(card.Branch)) return;
        var ct = CancellationToken.None;
        var repoRoot = Workspace.RepositoryRoot;
        var branch = card.Branch!;
        var baseBranch = await Git.GetCurrentBranchAsync(repoRoot, ct) ?? "";

        var worktrees = await Git.ListWorktreesAsync(repoRoot, ct);
        var match = worktrees.FirstOrDefault(w => string.Equals(w.Branch, branch, StringComparison.Ordinal));
        var worktreePath = match.Path ?? Path.Combine(repoRoot, ".yamca", "worktrees", Sanitize(branch));

        var info = new WorktreeInfo(branch, baseBranch, worktreePath, repoRoot);
        var dialog = await Dialogs.ShowAsync<BranchMergeDialog>("Merge branch",
            new DialogParameters { ["Info"] = info }, Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        // On a successful merge the worktree overlay is gone, so the card falls back to its
        // root-board position (and loses its branch chip) on refresh.
        await RefreshAsync();
        StateHasChanged();
    }

    // Open an interactive chat session on the card's branch worktree (creating the worktree if it
    // was deleted/merged away), for conflict resolution or follow-up work. This mirrors how a step
    // session is bound, so BasePath stays the sandbox RootPath that keys the session back together.
    private async Task OpenCardChatAsync(BoardCard card)
    {
        if (string.IsNullOrWhiteSpace(card.Branch)) return;
        if (!Manager.CanCreate)
        {
            Snackbar.Add("All 4 chat slots are in use — close one to open a chat.", Severity.Warning);
            return;
        }

        var worktree = await ResolveWorktreeForBranchAsync(card.Branch!);
        if (worktree is null) return; // error already surfaced

        try
        {
            var vm = Manager.CreateForWorktree(new WorkspaceImpl(worktree.WorktreePath), worktree);
            Nav.NavigateTo($"chat/{vm.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not open chat on '{card.Branch}': {ex.Message}", Severity.Error);
        }
    }

    // Promote a card out of a resting column (one with no instructions.md, e.g. the idea scratchpad)
    // into the next column, without a chat run. The card file is relocated and the move committed to
    // the current branch in isolation — mirroring how LockCardToBranchAsync commits a single card
    // pathspec — so the board's git history stays clean and the working tree isn't left dirty.
    private async Task PromoteCardAsync(BoardCard card, BoardColumn from, BoardColumn to)
    {
        var ct = CancellationToken.None;
        var repoRoot = Workspace.RepositoryRoot;
        var src = Path.GetFullPath(card.AbsolutePath);
        var dest = Path.GetFullPath(Path.Combine(to.AbsolutePath, card.FileName));

        if (File.Exists(dest))
        {
            Snackbar.Add($"A card file named '{card.FileName}' already exists in '{to.DisplayName}'.", Severity.Error);
            return;
        }

        try { Directory.CreateDirectory(to.AbsolutePath); }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not create column directory: {ex.Message}", Severity.Error);
            return;
        }

        // Move the card file (git mv for a tracked card, filesystem-move + stage fallback for an
        // untracked one). The relocation is staged but not committed; we then commit just those
        // staged paths in isolation so unrelated in-flight work stays out of the board commit. The
        // commit must NOT re-run `git add`: a git-mv'd source is gone from the index and re-adding it
        // would fatal with "pathspec did not match" — CommitStagedPathsAsync commits the staged paths
        // as-is (both sides of a rename, or the destination only for an untracked move).
        var moved = await Git.MoveWithUntrackedFallbackAsync(repoRoot, src, dest, ct);
        if (!moved.Ok)
        {
            Snackbar.Add($"Could not move card #{card.Id}: {moved.Error}", Severity.Error);
            return;
        }

        var commit = await Git.CommitStagedPathsAsync(repoRoot, $"board: move #{card.Id} to {to.DisplayName}", moved.CommitPaths, ct);
        if (!commit.Ok)
            Snackbar.Add($"Card #{card.Id} moved to '{to.DisplayName}', but the commit failed: {commit.Stderr.Trim()}", Severity.Warning);
        else
            Snackbar.Add($"Moved card #{card.Id} to '{to.DisplayName}'.", Severity.Success);

        await RefreshAsync();
        StateHasChanged();
    }

    private void OnDragStart(BoardCard card, BoardColumn from)
    {
        _draggedCard = card;
        _draggedFromColumn = from;
    }

    // Clears drag state whether the drop landed on a lane or was abandoned outside the board, so a
    // cancelled drag never leaves a stale highlight or a dangling captured card.
    private void OnDragEnd()
    {
        _draggedCard = null;
        _draggedFromColumn = null;
        _dragOverColumn = null;
    }

    // Highlight the lane under the cursor. dragenter bubbles from child cards too, but re-setting the
    // same column is idempotent, and moving to another lane simply switches the highlight — so no
    // dragleave bookkeeping is needed; OnDragEnd/OnDropAsync clear it.
    private void OnDragEnter(BoardColumn column) => _dragOverColumn = column.DirectoryName;

    // Drop a dragged card onto a column. Snapshot and clear the drag state up front (the move triggers
    // a refresh + re-render), then delegate to MoveCardAsync, which no-ops a same-column drop and
    // handles both the root-board and live-bound-worktree cases.
    private async Task OnDropAsync(BoardColumn target)
    {
        var card = _draggedCard;
        var from = _draggedFromColumn;
        _draggedCard = null;
        _draggedFromColumn = null;
        _dragOverColumn = null;
        if (card is null || from is null) return;
        await MoveCardAsync(card, from, target);
    }

    // Move a card to an arbitrary column from the UI, committing the relocation so the working tree is
    // never left dirty — the trap of moving card files by hand, which skips the two-sided commit. Two
    // cases, split on binding liveness (the same split the display overlay uses):
    //   • not-live (no branch, or a branch whose worktree is gone): the card lives on the root board,
    //     so move + commit the root copy on the current branch — PromoteCardAsync generalized to any
    //     column, forward or backward.
    //   • live-bound: the canonical card lives in the branch's worktree board (the root board shows
    //     only an overlay), so move + commit the worktree copy on the card's branch. The root copy
    //     stays put and is reconciled at merge, matching the existing overlay model. This commits
    //     directly onto the branch even if a chat session is mid-turn on it; concurrency guarding is
    //     deferred (a future board-action lock for cards with an in-flight chat turn).
    private async Task MoveCardAsync(BoardCard card, BoardColumn from, BoardColumn target)
    {
        if (string.Equals(from.DirectoryName, target.DirectoryName, StringComparison.Ordinal)) return;

        var ct = CancellationToken.None;
        var repoRoot = Workspace.RepositoryRoot;

        string? worktreePath = null;
        var live = !string.IsNullOrWhiteSpace(card.Branch)
                   && _branchWorktrees.TryGetValue(card.Branch!, out worktreePath);

        // Resolve the git root the move/commit runs against, plus the source file and its name. For a
        // live-bound card we re-read the worktree board to get the card's real worktree path, since the
        // snapshot's effective card carries the root file path (the overlay rewrites AbsolutePath).
        string gitRoot, src, fileName;
        if (live)
        {
            gitRoot = worktreePath!;
            var wtCard = BoardSvc.Read(worktreePath!).FindCard(card.Id);
            if (wtCard is null)
            {
                Snackbar.Add($"Could not find card #{card.Id} in the worktree for '{card.Branch}'.", Severity.Error);
                return;
            }
            src = Path.GetFullPath(wtCard.AbsolutePath);
            fileName = wtCard.FileName;
        }
        else
        {
            gitRoot = repoRoot;
            src = Path.GetFullPath(card.AbsolutePath);
            fileName = card.FileName;
        }

        var destColumnDir = Path.Combine(BoardService.BoardDirectory(gitRoot), target.DirectoryName);
        var dest = Path.GetFullPath(Path.Combine(destColumnDir, fileName));

        if (File.Exists(dest))
        {
            Snackbar.Add($"A card file named '{fileName}' already exists in '{target.DisplayName}'.", Severity.Error);
            return;
        }

        try { Directory.CreateDirectory(destColumnDir); }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not create column directory: {ex.Message}", Severity.Error);
            return;
        }

        var moved = await Git.MoveWithUntrackedFallbackAsync(gitRoot, src, dest, ct);
        if (!moved.Ok)
        {
            Snackbar.Add($"Could not move card #{card.Id}: {moved.Error}", Severity.Error);
            return;
        }

        var commit = await Git.CommitStagedPathsAsync(gitRoot, $"board: move #{card.Id} to {target.DisplayName}", moved.CommitPaths, ct);
        if (!commit.Ok)
            Snackbar.Add($"Card #{card.Id} moved to '{target.DisplayName}', but the commit failed: {commit.Stderr.Trim()}", Severity.Warning);
        else
            Snackbar.Add($"Moved card #{card.Id} to '{target.DisplayName}'.", Severity.Success);

        await RefreshAsync();
        StateHasChanged();
    }

    private async Task RunStepAsync(BoardCard card, BoardColumn column, CardDetailDialog.Result run)
    {
        if (!Manager.CanCreate)
        {
            Snackbar.Add("All 4 chat slots are in use — close one to run a step.", Severity.Warning);
            return;
        }

        // 1. Bind the card to its branch and commit the card file (carrying the binding) to the
        //    current outer branch in isolation, BEFORE forking the worktree. Without this,
        //    `git worktree add -b` forks from a HEAD that lacks the not-yet-committed card and the
        //    step's agent can't see the card it is meant to work. We (re)bind both for a card that
        //    has never had a branch and for one whose stale `branch:` attribute differs from the
        //    branch chosen now (e.g. an idea reworked onto a fresh branch after the old one was
        //    deleted) — so the frontmatter never lies about which branch the card lives on.
        if (!string.Equals(card.Branch, run.Branch, StringComparison.Ordinal))
        {
            if (!await LockCardToBranchAsync(card, run.Branch)) return; // error already surfaced
            card = card with { Branch = run.Branch };
        }

        // 2. Resolve (or create) the branch worktree. This covers a fresh branch for a just-bound
        //    card, and a bound card whose branch/worktree was since deleted or merged (e.g. from the
        //    chat merge/delete buttons) — both are recreated as needed.
        var worktree = await ResolveWorktreeForBranchAsync(run.Branch);
        if (worktree is null) return; // error already surfaced

        // 3. Column instructions + next column.
        var instructions = BoardSvc.ReadInstructions(Workspace.RepositoryRoot, column.DirectoryName);
        var next = _snapshot.NextColumn(column);

        // 4. Provision the seeded session and navigate to it (composer pre-filled, not sent).
        try
        {
            var vm = Launcher.ProvisionStepSession(
                new StepRunRequest(card, column, next, run.EndpointId, worktree, instructions));
            Nav.NavigateTo($"chat/{vm.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not start step: {ex.Message}", Severity.Error);
        }
    }

    // Resolve a usable worktree for a branch, creating whatever is missing:
    //   • a live worktree already checked out on the branch → reuse it;
    //   • the branch exists but has no worktree → add one;
    //   • neither exists (deleted/merged, or a brand-new card branch) → create the branch + worktree.
    private async Task<WorktreeInfo?> ResolveWorktreeForBranchAsync(string branch)
    {
        var ct = CancellationToken.None;
        // Worktrees and git operations are repo-scoped, so they anchor at the repository root.
        // BasePath, however, stays the session's sandbox root: it doubles as the key that ties a
        // worktree back to the base chat session (see ChatSessionPanel.IsBranchOpBusy).
        var repoRoot = Workspace.RepositoryRoot;
        var baseBranch = await Git.GetCurrentBranchAsync(repoRoot, ct) ?? "";

        var worktrees = await Git.ListWorktreesAsync(repoRoot, ct);
        var match = worktrees.FirstOrDefault(w => string.Equals(w.Branch, branch, StringComparison.Ordinal));
        if (match.Path is not null)
            return new WorktreeInfo(branch, baseBranch, match.Path, Workspace.RootPath);

        var path = Path.Combine(repoRoot, ".yamca", "worktrees", Sanitize(branch));
        if (!Directory.Exists(path))
        {
            var branches = await Git.ListBranchesAsync(repoRoot, ct);
            var branchExists = branches.Any(b => string.Equals(b, branch, StringComparison.Ordinal));
            var r = await Git.CreateWorktreeAsync(repoRoot, path, branch, isNewBranch: !branchExists, ct);
            if (!r.Ok)
            {
                Snackbar.Add($"Could not open worktree for '{branch}': {r.Stderr.Trim()}", Severity.Error);
                return null;
            }
        }
        return new WorktreeInfo(branch, baseBranch, path, Workspace.RootPath);
    }

    // Bind a card to its branch (writing the `branch:` frontmatter) and commit just the card file
    // to the current branch in isolation, so the worktree fork starts from a HEAD that already
    // contains the card and its binding. The commit is scoped to the card's pathspec, so any other
    // in-flight changes in the outer working tree are left untouched. Returns false (after surfacing
    // an error) when the write or commit fails.
    private async Task<bool> LockCardToBranchAsync(BoardCard card, string branch)
    {
        var ct = CancellationToken.None;
        try
        {
            var raw = await File.ReadAllTextAsync(card.AbsolutePath);
            await File.WriteAllTextAsync(card.AbsolutePath, BoardService.WithBranch(raw, branch));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not bind card to '{branch}': {ex.Message}", Severity.Error);
            return false;
        }

        var repoRoot = Workspace.RepositoryRoot;
        var rel = Path.GetRelativePath(repoRoot, card.AbsolutePath);
        if (await Git.HasUncommittedChangesAsync(repoRoot, rel, ct))
        {
            var outerBranch = await Git.GetCurrentBranchAsync(repoRoot, ct) ?? "the current branch";
            var commit = await Git.CommitPathsAsync(
                repoRoot, $"board: bind #{card.Id} to {branch}", new[] { rel }, ct);
            if (!commit.Ok)
            {
                Snackbar.Add($"Could not commit card #{card.Id} before branching: {commit.Stderr.Trim()}", Severity.Error);
                return false;
            }
            Snackbar.Add($"Committed card #{card.Id} to '{outerBranch}' before starting branch '{branch}'.", Severity.Info);
        }

        await RefreshAsync();
        return true;
    }

    private static string Sanitize(string branch) => branch.Replace('/', '-').Replace('\\', '-');

    public void Dispose() => Manager.Changed -= OnSessionsChanged;

    // A column with instructions is a work step (run in chat); a column with null instructions is a
    // resting column whose cards are simply promoted to the next column. Idea is a scratchpad and
    // Done is terminal, so neither carries a step.
    private static readonly (string Dir, string? Instr)[] DefaultColumns =
    {
        ("10-idea", null),
        ("20-analyze", "# Analyze\n\nInvestigate the codebase, identify the files and patterns involved, and write a concrete implementation plan into the card. Break the work into a `- [ ]` subtask checklist where useful.\n"),
        ("30-implement", "# Implement\n\nDo the work described in the card. Tick subtasks as you complete them. When the implementation is done, stage your code changes together with the card move (and ticked subtasks) into a single commit.\n"),
        ("40-verify", "# Verify\n\nBuild, run tests, and confirm the change works end to end. Fix anything that fails. Note verification results on the card before moving it on.\n"),
        ("50-done", null),
    };
}
