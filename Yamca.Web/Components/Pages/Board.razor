@page "/board"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Board
@using Yamca.Agent.Git
@using Yamca.Agent.Orchestration
@using Yamca.Agent.Workspace
@using Yamca.Web.Components.Board
@using Yamca.Web.Components.Branching
@using Yamca.Web.Components.Chat
@using Yamca.Web.Components.Orchestration
@using Yamca.Web.Services
@using Yamca.Web.Services.Orchestration
@using WorkspaceImpl = Yamca.Agent.Workspace.Workspace
@inject IWorkspace Workspace
@inject BoardStore BoardStore
@inject GitService Git
@inject CardWorktreeProvisioner Provisioner
@inject OrchestratorService Orchestrator
@inject OrchestratorRunRegistry OrchRegistry
@inject IDialogService Dialogs
@inject ChatSessionManager Manager
@inject BoardStepLauncher Launcher
@inject ISessionSettings Session
@inject SettingsHydrator Hydrator
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Yamca - Dev Board</PageTitle>

@if (!_hydrated)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
        <MudProgressCircular Indeterminate="true" />
        <MudText Class="ml-2 d-inline" Typo="Typo.body2">Loading…</MudText>
    </MudContainer>
}
else if (_snapshot.Columns.Count == 0)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-8">
        <MudText Typo="Typo.h6" GutterBottom="true">No dev board yet</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            The board is a personal scratchpad stored locally in <code>.yamca/yamca.db</code> —
            uncommitted, never shared. A column with step instructions is a work step run in chat; a
            column without them is a resting column whose cards are just promoted onward. Initialize it
            with the default idea → analyze → implement → verify → done columns?
        </MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.ViewKanban" OnClick="InitializeBoardAsync">
            Initialize board
        </MudButton>
    </MudContainer>
}
else
{
    <div class="yamca-board-root">
        <div class="yamca-board-toolbar">
            <div class="yamca-board-toolbar-start">
                <MudTooltip Text="@(HasFilter ? "Edit filter" : "Filter cards")" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   Size="Size.Small"
                                   Color="@(HasFilter ? Color.Primary : Color.Inherit)"
                                   OnClick="OpenSearchAsync"
                                   aria-label="Filter cards" />
                </MudTooltip>
            </div>
            @if (HasFilter)
            {
                <div class="yamca-board-filter-chip">
                    <span class="yamca-board-filter-chip-text">
                        @(_filterStartsWith ? "starts with" : "contains") "@_filterQuery"
                    </span>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Class="yamca-board-filter-chip-clear"
                                   OnClick="ClearFilter"
                                   aria-label="Clear filter" />
                </div>
            }
            <div class="d-flex align-center" style="margin-left:auto; gap: 4px;">
                @if (Orchestrator.LastValidationError is { } orchError)
                {
                    <MudTooltip Text="@orchError">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                                 Color="@(Orchestrator.IsEnabled ? Color.Error : Color.Warning)" />
                    </MudTooltip>
                }
                @if (Orchestrator.IsEnabled)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             OnClick="@(() => OpenOrchestratorRunsAsync(null))">
                        orchestrating · @Orchestrator.RunningCount running
                    </MudChip>
                }
                <MudTooltip Text="@(Orchestrator.IsEnabled ? "Stop autonomous card runs" : "Start working enabled columns autonomously")">
                    <MudSwitch T="bool" Value="@Orchestrator.IsEnabled" ValueChanged="OnOrchestrationToggled"
                               Color="Color.Success" Size="Size.Small" Class="ma-0" />
                </MudTooltip>
                <MudTooltip Text="Orchestrator settings">
                    <MudIconButton Icon="@Icons.Material.Filled.PrecisionManufacturing" Size="Size.Small"
                                   Href="orchestrator" aria-label="Orchestrator settings" />
                </MudTooltip>
            </div>
        </div>
        <div class="yamca-board">
            @foreach (var column in _snapshot.Columns)
            {
                <div class="yamca-board-lane">
                    <div class="yamca-board-lane-header">
                        @if (_isWorkColumn.GetValueOrDefault(column.Id))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Small"
                                     Class="yamca-board-ai-indicator" Title="AI work step" />
                        }
                        <span class="flex-grow-1">@column.DisplayName</span>
                        @if (column.Order == _snapshot.Columns[0].Order)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                           OnClick="@(() => AddCardAsync(column))" aria-label="New card" />
                        }
                        <MudIconButton Icon="@Icons.Material.Outlined.Settings" Size="Size.Small"
                                       Class="yamca-board-column-edit"
                                       OnClick="@(() => OpenColumnSettingsAsync(column))"
                                       aria-label="Edit column" />
                    </div>
                    <div class="yamca-board-lane-cards @(_dragOverColumn == column.Id ? "yamca-board-lane-cards--dragover" : "")"
                         @ondragover:preventDefault="true"
                         @ondragenter="@(() => OnDragEnter(column))"
                         @ondrop:preventDefault="true"
                         @ondrop="@(() => OnDropAsync(column))">
                        @{ var visibleCards = FilteredCards(column); }
                        @if (visibleCards.Count == 0)
                        {
                            <div class="yamca-board-empty">@(HasFilter ? "No matching cards" : "No cards")</div>
                        }
                        else
                        {
                            @foreach (var card in visibleCards)
                            {
                                var c = card;
                                var done = c.Subtasks.Count(s => s.Done);
                                var total = c.Subtasks.Count;
                                <MudPaper Class="@($"yamca-board-card{(_busyCards.Contains(c.Id) ? " yamca-board-card--busy" : "")}")"
                                          Elevation="3"
                                          draggable="true"
                                          @ondragstart="@(() => OnDragStart(c, column))"
                                          @ondragend="OnDragEnd"
                                          @onclick="@(() => OpenCardAsync(c, column))">
                                    <div class="yamca-board-card-title">@c.Title</div>
                                    @if (c.Priority == CardPriority.High)
                                    {
                                        <div class="yamca-board-card-priority--high">↑ high</div>
                                    }
                                    else if (c.Priority == CardPriority.Low)
                                    {
                                        <div class="yamca-board-card-priority--low">↓ low</div>
                                    }
                                    <div class="yamca-board-card-meta">
                                        <span>#@c.Id</span>
                                        @if (total > 0)
                                        {
                                            <span>@done/@total subtasks</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(c.Branch))
                                        {
                                            <span>⎇ @c.Branch</span>
                                        }
                                        @if (Orchestrator.CardStates.TryGetValue(c.Id.ToString(), out var orch))
                                        {
                                            <span class="yamca-board-card-orch" title="@OrchTooltip(orch)"
                                                  @onclick:stopPropagation="true"
                                                  @onclick="@(() => OpenOrchestratorRunsAsync(c.Id.ToString()))">
                                                @switch (orch.Status)
                                                {
                                                    case CardRunStatus.Queued:
                                                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Style="font-size:0.9rem;" Color="Color.Info" />
                                                        <text>queued</text>
                                                        break;
                                                    case CardRunStatus.Running:
                                                        <MudProgressCircular Indeterminate="true" Color="Color.Info" Style="width:12px;height:12px;" />
                                                        <text>running</text>
                                                        break;
                                                    case CardRunStatus.Retrying:
                                                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Style="font-size:0.9rem;" Color="Color.Warning" />
                                                        <text>retrying</text>
                                                        break;
                                                    case CardRunStatus.Parked:
                                                        <MudIcon Icon="@Icons.Material.Filled.PauseCircle" Style="font-size:0.9rem;" Color="Color.Error" />
                                                        <text>parked</text>
                                                        break;
                                                }
                                            </span>
                                            @if (orch.Status is CardRunStatus.Parked or CardRunStatus.Retrying)
                                            {
                                                <span class="yamca-board-card-orch" title="Retry this card now"
                                                      @onclick:stopPropagation="true"
                                                      @onclick="@(() => Orchestrator.RetryNow(c.Id.ToString()))">
                                                    <MudIcon Icon="@Icons.Material.Filled.Replay" Style="font-size:0.9rem;" />
                                                </span>
                                            }
                                        }
                                    </div>
                                    @if (_busyCards.Contains(c.Id))
                                    {
                                        <div class="yamca-board-card-busy-overlay">
                                            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                                        </div>
                                    }
                                    @if (_isWorkColumn.GetValueOrDefault(column.Id) && Session.Endpoints.Items.Count > 0)
                                    {
                                        <button type="button"
                                                class="yamca-board-card-play"
                                                disabled="@(_busyCards.Contains(c.Id))"
                                                @onclick:stopPropagation="true"
                                                @onclick="@(() => QuickRunAsync(c, column))"
                                                aria-label="Run step">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                        </button>
                                    }
                                </MudPaper>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _hydrated;
    private BoardSnapshot _snapshot = BoardSnapshot.Empty;
    private readonly HashSet<int> _busyCards = new();
    private IReadOnlyDictionary<string, bool> _isWorkColumn = new Dictionary<string, bool>();

    // Code-branch name → worktree root path, from the last refresh's `git worktree list`. The board
    // no longer lives on these branches (it is its own worktree), so this only drives code-branch
    // liveness affordances: a card whose `branch:` has a live worktree here offers merge / open-chat;
    // one whose branch never started or was merged/deleted offers run-fresh instead.
    private IReadOnlyDictionary<string, string> _branchWorktrees =
        new Dictionary<string, string>(StringComparer.Ordinal);

    private string? _filterQuery;
    private bool _filterStartsWith;
    private bool _filterFullCard;
    private bool HasFilter => !string.IsNullOrWhiteSpace(_filterQuery);

    // In-flight drag state for moving a card between columns. The card and the column it was picked
    // up from are captured on dragstart; _dragOverColumn drives the drop-target highlight and is keyed
    // on DirectoryName (the same key MoveCardAsync compares to short-circuit a same-column drop).
    private BoardCard? _draggedCard;
    private BoardColumn? _draggedFromColumn;
    private string? _dragOverColumn;

    protected override void OnInitialized()
    {
        Manager.Changed += OnSessionsChanged;
        Orchestrator.StateChanged += OnOrchestratorChanged;
        OrchRegistry.Changed += OnOrchestratorChanged;
    }

    private void OnOrchestratorChanged() => InvokeAsync(StateHasChanged);

    private void OnOrchestrationToggled(bool enabled)
    {
        if (enabled) Orchestrator.Enable();
        else Orchestrator.Disable();
    }

    private static string OrchTooltip(CardOrchestrationState orch) => orch.Status switch
    {
        CardRunStatus.Queued => "Claimed by the orchestrator — starting shortly.",
        CardRunStatus.Running => "The orchestrator is working this card. Click to watch the run.",
        CardRunStatus.Retrying =>
            $"Attempt {orch.Attempts} failed: {orch.FailureReason} — retrying at {orch.NextAttemptUtc?.ToLocalTime():HH:mm:ss}.",
        CardRunStatus.Parked =>
            $"Parked after {orch.Attempts} attempts: {orch.FailureReason}. Move or edit the card, use retry, or re-enable the orchestrator.",
        _ => orch.FailureReason ?? orch.Status.ToString(),
    };

    private async Task OpenOrchestratorRunsAsync(string? cardId)
    {
        var parameters = new DialogParameters { ["CardId"] = cardId };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await Dialogs.ShowAsync<OrchestratorRunsDialog>("Orchestrator runs", parameters, options);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Hydrator.HydrateAsync();   // load endpoints/settings for the step-run modal
            await RefreshAsync();
            _hydrated = true;
            StateHasChanged();
        }
    }

    private void OnSessionsChanged() => InvokeAsync(StateHasChanged);

    // The board is read from its own directory under the repository root, independent of any code
    // branch — so there is no overlay. We still enumerate code-branch worktrees, but only to drive
    // the dialog's merge / open-chat affordances. Worktrees are repo-scoped (enumerated from the
    // repo root); the board snapshot comes from the board directory.
    private async Task RefreshAsync()
    {
        var ct = CancellationToken.None;
        _snapshot = await BoardStore.ReadAsync(ct);

        var worktrees = await Git.ListWorktreesAsync(Workspace.RepositoryRoot, ct);
        var branchWorktrees = new Dictionary<string, string>(StringComparer.Ordinal);
        foreach (var (path, branch) in worktrees)
            if (!string.IsNullOrEmpty(branch))
                branchWorktrees[branch!] = path;
        _branchWorktrees = branchWorktrees;

        var workCols = new Dictionary<string, bool>(StringComparer.Ordinal);
        foreach (var col in _snapshot.Columns)
            workCols[col.Id] = !string.IsNullOrWhiteSpace(col.Instructions);
        _isWorkColumn = workCols;
    }

    private static DialogOptions Small() => new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private async Task OpenSearchAsync()
    {
        var parameters = new DialogParameters
        {
            ["InitialQuery"] = _filterQuery ?? "",
            ["InitialStartsWith"] = _filterStartsWith,
            ["InitialFullCard"] = _filterFullCard,
        };
        var dialog = await Dialogs.ShowAsync<BoardSearchDialog>("Filter cards", parameters, Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not BoardSearchDialog.Result data) return;
        _filterQuery = data.Query;
        _filterStartsWith = data.StartsWithMode;
        _filterFullCard = data.FullCard;
    }

    private void ClearFilter() => _filterQuery = null;

    private IReadOnlyList<BoardCard> FilteredCards(BoardColumn column)
    {
        if (!HasFilter) return column.Cards;
        return column.Cards.Where(MatchesFilter).ToList();
    }

    private bool MatchesFilter(BoardCard card)
    {
        var query = _filterQuery!.ToLowerInvariant();
        var text = _filterFullCard
            ? $"{card.Title} {card.Body ?? ""}".ToLowerInvariant()
            : card.Title.ToLowerInvariant();
        return _filterStartsWith ? text.StartsWith(query) : text.Contains(query);
    }

    // Bootstrap the board (seeds default columns in the store on first use).
    // Normally unreachable — RefreshAsync ensures the board on first navigation, so the empty-board
    // view rarely shows — but kept as an explicit affordance.
    private async Task InitializeBoardAsync()
    {
        try { await BoardStore.EnsureSeededAsync(CancellationToken.None); }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not initialize board: {ex.Message}", Severity.Error);
            return;
        }
        await RefreshAsync();
        Snackbar.Add("Board initialized.", Severity.Success);
    }

    private async Task OpenColumnSettingsAsync(BoardColumn column)
    {
        var currentInstructions = column.Instructions;

        var parameters = new DialogParameters { ["Instructions"] = currentInstructions };
        var dialog = await Dialogs.ShowAsync<ColumnInstructionsDialog>(
            $"Edit column: {column.DisplayName}", parameters, Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not ColumnInstructionsDialog.Result data) return;

        // Skip the mutation entirely when nothing actually changed.
        var oldNorm = string.IsNullOrWhiteSpace(currentInstructions) ? null : currentInstructions.Trim();
        var newNorm = string.IsNullOrWhiteSpace(data.Instructions) ? null : data.Instructions.Trim();
        if (string.Equals(oldNorm, newNorm, StringComparison.Ordinal)) return;

        try
        {
            await BoardStore.SetColumnInstructionsAsync(column.Id, data.Instructions, CancellationToken.None);
            Snackbar.Add($"Column '{column.DisplayName}' updated.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not save instructions: {ex.Message}", Severity.Error);
        }

        await RefreshAsync();
        StateHasChanged();
    }

    private async Task AddCardAsync(BoardColumn column)
    {
        // Preview the id the card will take so the dialog can seed an id-prefixed default branch
        // (matching PresumptiveBranch). The id is recomputed atomically inside AddCardAsync below; on a
        // local single-user board the two agree, and the branch the user accepted is stored verbatim
        // regardless, so any drift only affects the cosmetic id prefix of the default branch.
        var nextId = await BoardStore.NextCardIdAsync(CancellationToken.None);

        var parameters = new DialogParameters { ["NextId"] = nextId };
        var dialog = await Dialogs.ShowAsync<NewCardDialog>("New card", parameters, Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not NewCardDialog.Result data) return;

        // Persist the new card. Every card is born with a `branch:` so its branch is already decided;
        // the worktree is only created later, the first time a chat is opened or a step is run on it.
        try
        {
            await BoardStore.AddCardAsync(column.Id, data.Title, data.Body, data.Branch, data.Priority, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not create card: {ex.Message}", Severity.Error);
        }

        await RefreshAsync();
        StateHasChanged();
    }

    private async Task OpenCardAsync(BoardCard card, BoardColumn column)
    {
        // Branch field defaults / existing branches are gathered up front so the dialog can
        // offer them inline (combobox + endpoint dropdown) instead of chaining more modals.
        var existingBranches = await Git.ListBranchesAsync(Workspace.RepositoryRoot, CancellationToken.None);
        var next = _snapshot.NextColumn(column);

        // When the card's branch has a live code worktree, hand the dialog its path and the repo's
        // base branch so the Changes tab can diff that worktree against the branch's fork point.
        var worktreePath = !string.IsNullOrWhiteSpace(card.Branch)
                           && _branchWorktrees.TryGetValue(card.Branch!, out var wp) ? wp : null;
        var baseBranch = worktreePath is null
            ? ""
            : await Git.GetCurrentBranchAsync(Workspace.RepositoryRoot, CancellationToken.None) ?? "";
        var parameters = new DialogParameters
        {
            ["Card"] = card,
            ["ColumnDisplayName"] = column.DisplayName,
            ["IsWorkColumn"] = !string.IsNullOrWhiteSpace(column.Instructions),
            ["NextColumnDisplayName"] = next?.DisplayName,
            ["Endpoints"] = Session.Endpoints.Items,
            ["DefaultEndpointId"] = Session.Endpoints.DefaultId,
            ["ExistingBranches"] = existingBranches,
            ["PresumptiveBranch"] = BoardService.PresumptiveBranch(card.Id, card.Title),
            // A binding is live only when the card's branch has a code worktree in this refresh's
            // map — which decides whether the dialog offers merge / open-chat vs. run-fresh.
            ["BranchWorktreeLive"] = !string.IsNullOrWhiteSpace(card.Branch)
                                     && _branchWorktrees.ContainsKey(card.Branch!),
            ["Columns"] = _snapshot.Columns
                .Select(c => new CardDetailDialog.ColumnOption(c.Id, c.DisplayName)).ToList(),
            ["CurrentColumnId"] = column.Id,
            ["WorktreePath"] = worktreePath,
            ["BaseBranch"] = baseBranch,
        };
        var dialog = await Dialogs.ShowAsync<CardDetailDialog>($"#{card.Id} {card.Title}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is CardDetailDialog.Result run)
            await RunStepAsync(card, column, run);
        else if (result.Data is CardDetailDialog.Promotion && next is not null)
            await MoveCardAsync(card, column, next);
        else if (result.Data is CardDetailDialog.MergeRequest)
            await MergeCardAsync(card);
        else if (result.Data is CardDetailDialog.OpenChatRequest)
            await OpenCardChatAsync(card);
        else if (result.Data is CardDetailDialog.MoveRequest move)
        {
            var target = _snapshot.FindColumn(move.ToColumnId);
            if (target is not null) await MoveCardAsync(card, column, target);
        }
        else if (result.Data is CardDetailDialog.DeleteRequest)
            await DeleteCardAsync(card);
        else if (result.Data is CardDetailDialog.PriorityUpdate pu)
            await UpdateCardPriorityAsync(card, pu.Priority);
        else if (result.Data is CardDetailDialog.BodyUpdate bu)
            await UpdateCardBodyAsync(card, bu.Title, bu.Body);
        else if (result.Data is CardDetailDialog.BranchUpdate br)
            await UpdateCardBranchAsync(card, br.Branch);
    }

    // Persist a branch chosen in the card dialog by setting the card's branch (no worktree —
    // that waits for the first run/chat). Reuses LockCardToBranchAsync, which writes and refreshes;
    // the busy overlay just gives the card the same in-flight feedback as the other edits.
    private async Task UpdateCardBranchAsync(BoardCard card, string branch)
    {
        if (string.Equals(card.Branch, branch, StringComparison.Ordinal)) return;
        _busyCards.Add(card.Id);
        StateHasChanged();
        await LockCardToBranchAsync(card, branch);
        await InvokeAsync(() =>
        {
            _busyCards.Remove(card.Id);
            StateHasChanged();
        });
    }

    // Merge a branch-bound card's branch back into the base branch by reusing the same merge dialog
    // the chat panel uses. The merge itself runs against the repository's base checkout, so the
    // WorktreeInfo anchors BasePath at the repository root (not the sandbox RootPath the chat flow
    // uses as a session key). The branch's worktree path is only needed for the optional post-merge
    // cleanup; if it has already been removed, fall back to its conventional path so the cleanup's
    // worktree removal is a harmless no-op rather than a crash.
    private async Task MergeCardAsync(BoardCard card)
    {
        if (string.IsNullOrWhiteSpace(card.Branch)) return;
        var ct = CancellationToken.None;
        var repoRoot = Workspace.RepositoryRoot;
        var branch = card.Branch!;
        var baseBranch = await Git.GetCurrentBranchAsync(repoRoot, ct) ?? "";

        var worktrees = await Git.ListWorktreesAsync(repoRoot, ct);
        var match = worktrees.FirstOrDefault(w => string.Equals(w.Branch, branch, StringComparison.Ordinal));
        var worktreePath = match.Path ?? CardWorktreeProvisioner.WorktreePathForBranch(repoRoot, branch);

        var info = new WorktreeInfo(branch, baseBranch, worktreePath, repoRoot);
        var dialog = await Dialogs.ShowAsync<BranchMergeDialog>("Merge branch",
            new DialogParameters { ["Info"] = info }, Small());
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        // The merge only affects code branches; the board (its own worktree) is unchanged. Refresh
        // so the card's branch-liveness affordances reflect the now-merged/removed worktree.
        await RefreshAsync();
        StateHasChanged();
    }

    // Open an interactive chat session on the card's branch worktree (creating the worktree if it
    // was deleted/merged away), for conflict resolution or follow-up work. This mirrors how a step
    // session is bound, so BasePath stays the sandbox RootPath that keys the session back together.
    private async Task OpenCardChatAsync(BoardCard card)
    {
        if (string.IsNullOrWhiteSpace(card.Branch)) return;

        var worktree = await ResolveWorktreeForBranchAsync(card.Branch!);
        if (worktree is null) return; // error already surfaced

        try
        {
            // CreateForWorktree shows the new session in a pane; jump to the chat view.
            Manager.CreateForWorktree(new WorkspaceImpl(worktree.WorktreePath), worktree);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not open chat on '{card.Branch}': {ex.Message}", Severity.Error);
        }
    }

    private void OnDragStart(BoardCard card, BoardColumn from)
    {
        _draggedCard = card;
        _draggedFromColumn = from;
    }

    // Clears drag state whether the drop landed on a lane or was abandoned outside the board, so a
    // cancelled drag never leaves a stale highlight or a dangling captured card.
    private void OnDragEnd()
    {
        _draggedCard = null;
        _draggedFromColumn = null;
        _dragOverColumn = null;
    }

    // Highlight the lane under the cursor. dragenter bubbles from child cards too, but re-setting the
    // same column is idempotent, and moving to another lane simply switches the highlight — so no
    // dragleave bookkeeping is needed; OnDragEnd/OnDropAsync clear it.
    private void OnDragEnter(BoardColumn column) => _dragOverColumn = column.Id;

    // Drop a dragged card onto a column. Snapshot and clear the drag state up front (the move triggers
    // a refresh + re-render), then delegate to MoveCardAsync, which no-ops a same-column drop.
    private async Task OnDropAsync(BoardColumn target)
    {
        var card = _draggedCard;
        var from = _draggedFromColumn;
        _draggedCard = null;
        _draggedFromColumn = null;
        _dragOverColumn = null;
        if (card is null || from is null) return;
        await MoveCardAsync(card, from, target);
    }

    // Move a card to an arbitrary column. The snapshot is updated optimistically so the card appears
    // in the target column immediately; the file move runs in the background under the board lock.
    // The busy overlay stays on the card until the background work finishes. Refresh is deferred
    // until all in-flight mutations drain so concurrent moves don't stomp each other's optimistic state.
    private Task MoveCardAsync(BoardCard card, BoardColumn from, BoardColumn target)
    {
        if (string.Equals(from.Id, target.Id, StringComparison.Ordinal))
            return Task.CompletedTask;
        _snapshot = WithCardMoved(_snapshot, card, from, target);
        _busyCards.Add(card.Id);
        _ = BackgroundMoveAsync(card, from, target);
        return Task.CompletedTask;
    }

    private async Task BackgroundMoveAsync(BoardCard card, BoardColumn from, BoardColumn target)
    {
        var ct = CancellationToken.None;
        try
        {
            await BoardStore.MoveCardAsync(card.Id, target.Id, ct);
        }
        catch (Exception ex)
        {
            await InvokeAsync(() => Snackbar.Add($"Move failed: {ex.Message}", Severity.Error));
        }
        finally
        {
            await InvokeAsync(() => FinishMutationAsync(card.Id));
        }
    }

    private Task DeleteCardAsync(BoardCard card)
    {
        _snapshot = WithCardDeleted(_snapshot, card);
        _busyCards.Add(card.Id); // keeps refresh deferred if a move is also in flight
        _ = BackgroundDeleteAsync(card);
        return Task.CompletedTask;
    }

    private async Task BackgroundDeleteAsync(BoardCard card)
    {
        var ct = CancellationToken.None;
        try
        {
            await BoardStore.DeleteCardAsync(card.Id, ct);
        }
        catch (Exception ex)
        {
            await InvokeAsync(() => Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error));
        }
        finally
        {
            await InvokeAsync(() => FinishMutationAsync(card.Id));
        }
    }

    // Remove the card from _busyCards and refresh once all in-flight mutations have settled.
    // Deferring the refresh until the set drains prevents concurrent optimistic moves from
    // briefly reverting each other while their writes are still queued under the board lock.
    private async Task FinishMutationAsync(int cardId)
    {
        _busyCards.Remove(cardId);
        if (_busyCards.Count == 0)
            await RefreshAsync();
        StateHasChanged();
    }

    private static BoardSnapshot WithCardMoved(BoardSnapshot snapshot, BoardCard card, BoardColumn from, BoardColumn to)
    {
        var moved = card with { ColumnId = to.Id };
        return new BoardSnapshot(snapshot.Columns.Select(col =>
            col.Id == from.Id ? col with { Cards = col.Cards.Where(c => c.Id != card.Id).ToList() } :
            col.Id == to.Id   ? col with { Cards = col.Cards.Append(moved).ToList() } :
            col).ToList());
    }

    private static BoardSnapshot WithCardDeleted(BoardSnapshot snapshot, BoardCard card) =>
        new BoardSnapshot(snapshot.Columns.Select(col =>
            col.Id == card.ColumnId
                ? col with { Cards = col.Cards.Where(c => c.Id != card.Id).ToList() }
                : col).ToList());

    private async Task RunStepAsync(BoardCard card, BoardColumn column, CardDetailDialog.Result run)
    {
        // 1. Bind the card to its branch by setting the card's branch in the store. The board is
        //    separate from the code worktree, so this is just a store write. We (re)bind both for a
        //    card that has never had a branch and for one whose stale branch differs from the branch
        //    chosen now (e.g. an idea reworked onto a fresh branch) — so the card never lies about
        //    which branch it lives on.
        if (!string.Equals(card.Branch, run.Branch, StringComparison.Ordinal))
        {
            if (!await LockCardToBranchAsync(card, run.Branch)) return; // error already surfaced
            card = card with { Branch = run.Branch };
        }

        // 2. Resolve (or create) the code worktree — a plain fork off the base branch. This covers a
        //    fresh branch for a just-bound card, and a bound card whose branch/worktree was since
        //    deleted or merged (e.g. from the chat merge/delete buttons) — both are recreated as needed.
        var worktree = await ResolveWorktreeForBranchAsync(run.Branch);
        if (worktree is null) return; // error already surfaced

        // 3. Column instructions + next column.
        var instructions = column.Instructions;
        var next = _snapshot.NextColumn(column);

        // 4. Provision the seeded session (shown in a pane) and jump to the chat view
        //    (composer pre-filled, not sent).
        try
        {
            Launcher.ProvisionStepSession(
                new StepRunRequest(card, column, next, run.EndpointId, worktree, instructions));
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not start step: {ex.Message}", Severity.Error);
        }
    }

    private async Task QuickRunAsync(BoardCard card, BoardColumn column)
    {
        if (_busyCards.Contains(card.Id) || Session.Endpoints.Items.Count == 0) return;
        var branch = !string.IsNullOrWhiteSpace(card.Branch)
            ? card.Branch
            : BoardService.PresumptiveBranch(card.Id, card.Title);
        await RunStepAsync(card, column, new CardDetailDialog.Result(Session.Endpoints.DefaultId, branch));
    }

    // Resolve a usable worktree for a branch via the shared provisioner (also used by the
    // orchestrator's headless dispatch), surfacing any error as a snackbar.
    private async Task<WorktreeInfo?> ResolveWorktreeForBranchAsync(string branch)
    {
        var result = await Provisioner.ResolveWorktreeForBranchAsync(branch, CancellationToken.None);
        if (result.Error is not null)
            Snackbar.Add(result.Error, Severity.Error);
        return result.Worktree;
    }

    // Bind a card to its branch by setting the card's branch. Returns false (after
    // surfacing an error) when the write fails.
    private async Task<bool> LockCardToBranchAsync(BoardCard card, string branch)
    {
        var error = await Provisioner.LockCardToBranchAsync(card, branch, CancellationToken.None);
        if (error is not null)
        {
            Snackbar.Add(error, Severity.Error);
            return false;
        }
        await RefreshAsync();
        return true;
    }

    private async Task UpdateCardPriorityAsync(BoardCard card, CardPriority priority)
    {
        _busyCards.Add(card.Id);
        StateHasChanged();

        try { await BoardStore.SetPriorityAsync(card.Id, priority, CancellationToken.None); }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not update card #{card.Id}: {ex.Message}", Severity.Error);
        }

        await InvokeAsync(async () =>
        {
            _busyCards.Remove(card.Id);
            await RefreshAsync();
            StateHasChanged();
        });
    }

    // Mark the card busy, write the edited title and markdown body (whose `- [ ]` lines become the
    // card's subtasks) into the store, then refresh and clear the spinner.
    private async Task UpdateCardBodyAsync(BoardCard card, string title, string body)
    {
        _busyCards.Add(card.Id);
        StateHasChanged();

        try { await BoardStore.UpdateCardBodyAsync(card.Id, title, body, CancellationToken.None); }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not update card #{card.Id}: {ex.Message}", Severity.Error);
        }

        await InvokeAsync(async () =>
        {
            _busyCards.Remove(card.Id);
            await RefreshAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Manager.Changed -= OnSessionsChanged;
        Orchestrator.StateChanged -= OnOrchestratorChanged;
        OrchRegistry.Changed -= OnOrchestratorChanged;
    }
}
