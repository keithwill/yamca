@page "/preferences"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Chat
@using Yamca.Agent.Tools.ShellExecution

<PageTitle>Preferences — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading settings&hellip;</MudText>
}
else
{
    <SettingsSection Title="Chat" HelpDoc="settings-and-backup">
        <ChildContent>
        <MudSwitch T="bool" Value="Session.MarkdownEnabled"
                   ValueChanged="@((bool v) => Session.SetMarkdownEnabled(v))"
                   Color="Color.Primary"
                   Label="Markdown rendering" />
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            A capability hint is appended to the system prompt either way: when on, the model is told its replies are rendered as Markdown; when off, it's told to reply in plain text.
        </MudText>

        <MudSelect T="ReasoningDisplay" Value="Session.ReasoningDisplay"
                   ValueChanged="@((ReasoningDisplay v) => Session.SetReasoningDisplay(v))"
                   Label="Reasoning blocks"
                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                   Class="mt-3">
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Hidden">Hidden</MudSelectItem>
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Collapsed">Collapsed (default)</MudSelectItem>
            <MudSelectItem T="ReasoningDisplay" Value="ReasoningDisplay.Expanded">Expanded</MudSelectItem>
        </MudSelect>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            How to display chain-of-thought emitted by reasoning models inside <code>&lt;think&gt;</code>, <code>&lt;thinking&gt;</code>, or <code>&lt;reasoning&gt;</code> tags (Qwen3, QwQ, DeepSeek-R1, etc.). Collapsed mode shows it live while streaming and auto-closes when the answer begins.
        </MudText>

        <MudSelect T="PromptDockPosition" Value="Session.PromptDockPosition"
                   ValueChanged="@((PromptDockPosition v) => Session.SetPromptDockPosition(v))"
                   Label="Prompt position"
                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                   Class="mt-3">
            <MudSelectItem T="PromptDockPosition" Value="PromptDockPosition.Top">Top (default)</MudSelectItem>
            <MudSelectItem T="PromptDockPosition" Value="PromptDockPosition.Bottom">Bottom</MudSelectItem>
        </MudSelect>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            Whether the prompt composer sits above or below the message log in each chat pane. Also toggleable from the button in the composer toolbar.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1">Context</MudText>
        <MudSwitch T="bool" Value="Session.AutoCompactionEnabled"
                   ValueChanged="@((bool v) => Session.SetAutoCompactionEnabled(v))"
                   Color="Color.Primary"
                   Label="Auto-compaction" />
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            When the chat exceeds the threshold percentage of the endpoint's context window, summarize older turns into the system message and keep only the most recent N turns verbatim. Requires the backend to report its context size.
        </MudText>

        <div class="d-flex mt-2" style="gap: 12px;">
            <MudNumericField T="int" Value="Session.AutoCompactionThresholdPercent"
                             ValueChanged="@((int v) => Session.SetAutoCompactionThresholdPercent(v))"
                             Label="Trigger at (%)"
                             Min="1" Max="95" Step="5"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             Disabled="@(!Session.AutoCompactionEnabled)" />
            <MudNumericField T="int" Value="Session.AutoCompactionKeepRecentTurns"
                             ValueChanged="@((int v) => Session.SetAutoCompactionKeepRecentTurns(v))"
                             Label="Keep recent turns"
                             Min="1" Max="50" Step="1"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             Disabled="@(!Session.AutoCompactionEnabled)" />
        </div>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1">Tools</MudText>
        <MudNumericField T="int" Value="Session.MaxToolIterations"
                         ValueChanged="@((int v) => Session.SetMaxToolIterations(v))"
                         Label="Max tool call iterations"
                         Min="1" Max="100" Step="1"
                         Variant="Variant.Outlined" Margin="Margin.Dense"
                         Style="max-width: 220px;" />
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            The most LLM round-trips allowed in a single turn before the agent stops. Each round-trip is one model response; a turn keeps looping while the model requests tool calls. Raise this for long autonomous tasks; lower it to cap runaway tool-calling.
        </MudText>

        <MudSelect T="ShellPreference" Value="Session.ShellPreference"
                   ValueChanged="@((ShellPreference v) => Session.SetShellPreference(v))"
                   Label="Command shell"
                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                   Class="mt-3" Style="max-width: 360px;">
            <MudSelectItem T="ShellPreference" Value="ShellPreference.Auto">Auto-detect (default)</MudSelectItem>
            @foreach (var pref in _availableShells)
            {
                <MudSelectItem T="ShellPreference" Value="pref">@ShellLabel(pref)</MudSelectItem>
            }
            @* Keep a previously-saved choice visible even if that shell is no longer installed,
               so the selection isn't silently swapped out from under the user. *@
            @if (Session.ShellPreference != ShellPreference.Auto && !_availableShells.Contains(Session.ShellPreference))
            {
                <MudSelectItem T="ShellPreference" Value="Session.ShellPreference">@ShellLabel(Session.ShellPreference) (not detected)</MudSelectItem>
            }
        </MudSelect>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            Which shell the <code>execute_command</code> tool and registered inline scripts run through. Only shells detected on this machine are listed; auto-detect picks pwsh → Windows PowerShell → cmd.exe on Windows, and bash → sh elsewhere.
            @if (_resolvedShell is not null)
            {
                <br />
                <span>Currently resolves to: <strong>@_resolvedShell.Shell.DisplayName</strong> at <code>@_resolvedShell.Shell.ExecutablePath</code>@(_resolvedShell.FellBack ? " (configured shell unavailable — fell back to auto-detect)" : "")</span>
            }
        </MudText>
        </ChildContent>
    </SettingsSection>
}

</MudContainer>

@code {
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private ShellResolver Shells { get; set; } = default!;

    private bool _hydrated;
    private ShellResolution? _resolvedShell;
    private IReadOnlyList<ShellPreference> _availableShells = System.Array.Empty<ShellPreference>();

    protected override void OnInitialized()
    {
        Session.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        _hydrated = true;
        _availableShells = Shells.AvailablePreferences();
        _resolvedShell = Shells.ResolveDetailed(Session.ShellPreference);
        StateHasChanged();
    }

    private void OnSettingsChanged(SettingsTier _)
    {
        _resolvedShell = Shells.ResolveDetailed(Session.ShellPreference);
        InvokeAsync(StateHasChanged);
    }

    private static string ShellLabel(ShellPreference preference) => preference switch
    {
        ShellPreference.Auto => "Auto-detect (default)",
        ShellPreference.Pwsh => "PowerShell 7+ (pwsh)",
        ShellPreference.WindowsPowerShell => "Windows PowerShell 5.1",
        ShellPreference.Cmd => "Command Prompt (cmd.exe)",
        ShellPreference.GitBash => "Git Bash",
        ShellPreference.Bash => "Bash",
        ShellPreference.Sh => "POSIX sh",
        _ => preference.ToString(),
    };

    public void Dispose()
    {
        Session.Changed -= OnSettingsChanged;
    }
}
