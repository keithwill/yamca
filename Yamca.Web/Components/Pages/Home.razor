@page "/"
@page "/chat/{Id:int}"
@rendermode InteractiveServer
@using Yamca.Web.Components.Chat

<PageTitle>Yamca - @System.IO.Path.GetFileName(Workspace.RootPath.TrimEnd('\\', '/'))</PageTitle>

@if (!_hydrated || Chat is null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
        <MudProgressCircular Indeterminate="true" />
        <MudText Class="ml-2 d-inline" Typo="Typo.body2">Loading…</MudText>
    </MudContainer>
}
else
{
    <ChatSessionPanel Chat="Chat" @key="Chat.Id" />
}

@code {
    [Inject] private IWorkspace Workspace { get; set; } = default!;
    [Inject] private ChatSessionManager Manager { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private McpConfigStore McpStore { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [Parameter] public int? Id { get; set; }

    private ChatViewModel? Chat => Id is int id ? Manager.Get(id) : null;
    private bool _hydrated;

    protected override void OnParametersSet()
    {
        if (Id is null)
        {
            var target = Manager.Sessions.FirstOrDefault() ?? (Manager.CanCreate ? Manager.Create() : null);
            if (target is not null)
            {
                Nav.NavigateTo($"chat/{target.Id}", replace: true);
            }
            return;
        }

        if (Manager.Get(Id.Value) is null)
        {
            var fallback = Manager.Sessions.FirstOrDefault();
            if (fallback is not null)
                Nav.NavigateTo($"chat/{fallback.Id}", replace: true);
            else
                Nav.NavigateTo("/", replace: true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Hydrator.HydrateAsync();
            // MCP registry is process-wide, but config lives per-origin in
            // localStorage — hydrate from there on the first circuit so a
            // restart of yamca picks up the user's servers.
            if (!McpStore.Hydrated)
            {
                try { await McpStore.HydrateAsync(); }
                catch { /* a bad config blob shouldn't prevent the chat UI from loading */ }
            }
            _hydrated = true;
            StateHasChanged();
        }
    }
}
