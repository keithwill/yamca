@page "/"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.JSInterop

<PageTitle>Yamca - @System.IO.Path.GetFileName(Workspace.RootPath.TrimEnd('\\', '/'))</PageTitle>

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Class="ml-2 d-inline" Typo="Typo.body2">Loading settings…</MudText>
}
else
{

    @foreach (var turn in Chat.Turns)
    {
        <ChatTurnView Turn="turn" />
    }

    @foreach (var approval in Chat.Approvals.ToList())
    {
        <ApprovalPrompt Approval="approval"
                        OnResolve="@(d => Chat.ResolveApproval(approval, d.Approved, d.Persistence))" />
    }

    @if (Chat.Error is not null && (Chat.Turns.Count == 0 || Chat.Turns[^1].Error is null))
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@Chat.Error</MudAlert>
    }

    <div class="yamca-input-dock">
        <MudPaper Class="pa-2" Elevation="0" Outlined="true">
            <MudTextField @bind-Value="_prompt" T="string" Placeholder="Enter a prompt..."
                          Lines="3" Variant="Variant.Text" Immediate="true"
                          OnKeyDown="OnKeyDown" Disabled="Chat.IsRunning" />
            <div class="d-flex mt-2">
                <MudSpacer />
                @if (Chat.IsRunning)
                {
                    <MudButton Color="Color.Warning" Variant="Variant.Outlined" OnClick="OnCancel"
                               StartIcon="@Icons.Material.Filled.Stop">Cancel</MudButton>
                }
                else
                {
                    <MudButtonGroup OverrideStyles="false" Variant="Variant.Filled">
                        <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="OnClear"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   Disabled="Chat.IsRunning">New</MudButton>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnSend"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   Disabled="@(string.IsNullOrWhiteSpace(_prompt))">Send</MudButton>
                    </MudButtonGroup>
                }
            </div>
        </MudPaper>
    </div>

    <div @ref="_scrollAnchor"></div>
}

@code {
    [Inject] private IWorkspace Workspace { get; set; } = default!;
    [Inject] private ChatViewModel Chat { get; set; } = default!;
    [Inject] private SessionSettings Session { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private IDialogService Dialogs { get; set; } = default!;

    private bool _hydrated;
    private string _prompt = "";
    private ElementReference _scrollAnchor;

    protected override void OnInitialized()
    {
        Chat.Changed += OnChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Hydrator.HydrateAsync();
            await SafeInvokeAsync("yamcaChat.init");
            _hydrated = true;
            StateHasChanged();
            return;
        }

        await SafeInvokeAsync("yamcaChat.scrollIfSticky", _scrollAnchor);
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task OnSend()
    {
        if (string.IsNullOrWhiteSpace(_prompt) || Chat.IsRunning) return;
        var p = _prompt;
        _prompt = "";
        await Chat.SendAsync(p);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await OnSend();
        }
    }

    private void OnCancel() => Chat.Cancel();

    private async Task OnClear()
    {
        if (Chat.Turns.Count == 0 && Chat.Approvals.Count == 0)
        {
            Chat.Clear();
            _ = SafeInvokeAsync("yamcaChat.reset");
            return;
        }

        var confirmed = await Dialogs.ShowMessageBoxAsync(
            title: "Start a new chat?",
            message: "This will clear the current conversation. Continue?",
            yesText: "New chat",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            Chat.Clear();
            _ = SafeInvokeAsync("yamcaChat.reset");
        }
    }

    private async Task SafeInvokeAsync(string identifier, params object?[] args)
    {
        try
        {
            await JS.InvokeVoidAsync(identifier, args);
        }
        catch (JSDisconnectedException) { /* circuit gone */ }
        catch (TaskCanceledException)   { /* tab closing */ }
    }

    public void Dispose()
    {
        Chat.Changed -= OnChanged;
    }
}
