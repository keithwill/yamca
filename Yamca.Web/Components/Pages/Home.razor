@page "/"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Web.Components.Chat

<PageTitle>Yamca - @System.IO.Path.GetFileName(Workspace.RootPath.TrimEnd('\\', '/'))</PageTitle>

@if (!_hydrated || Manager.Visible.Count == 0)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
        <MudProgressCircular Indeterminate="true" />
        <MudText Class="ml-2 d-inline" Typo="Typo.body2">Loading…</MudText>
    </MudContainer>
}
else
{
    <div class="yamca-split yamca-split-@Manager.Visible.Count">
        @foreach (var s in Manager.Visible)
        {
            <ChatSessionPanel Chat="s" ShowHeader="true"
                              OnClose="@(() => Manager.Hide(s.Id))"
                              @key="s.Id" />
        }
    </div>
}

@code {
    [Inject] private IWorkspace Workspace { get; set; } = default!;
    [Inject] private ChatSessionManager Manager { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private McpConfigStore McpStore { get; set; } = default!;

    private bool _hydrated;

    protected override void OnInitialized()
    {
        Manager.Changed += OnSessionsChanged;
    }

    protected override void OnParametersSet()
    {
        EnsureAtLeastOneVisible();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Hydrator.HydrateAsync();
            // MCP registry is process-wide, but config lives on disk in
            // mcp.json — hydrate from there on the first circuit so a
            // restart of yamca picks up the user's servers.
            if (!McpStore.Hydrated)
            {
                try { await McpStore.HydrateAsync(); }
                catch { /* a bad config blob shouldn't prevent the chat UI from loading */ }
            }
            _hydrated = true;
            StateHasChanged();
        }
    }

    private void OnSessionsChanged()
    {
        EnsureAtLeastOneVisible();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>The grid is never empty: show the most-recently-active loaded chat, or
    /// create a fresh one when nothing is loaded.</summary>
    private void EnsureAtLeastOneVisible()
    {
        if (Manager.Visible.Count > 0) return;

        var mostRecent = Manager.Sessions
            .OrderByDescending(s => s.LastActivityUtc)
            .FirstOrDefault();
        if (mostRecent is not null)
            Manager.Show(mostRecent.Id);
        else
            Manager.Create();
    }

    public void Dispose()
    {
        Manager.Changed -= OnSessionsChanged;
    }
}
