@page "/mcp"
@rendermode InteractiveServer
@implements IDisposable
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>MCP — yamca</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

@if (!_hydrated)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body2" Class="ml-2 d-inline">Loading from localStorage&hellip;</MudText>
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
        <div class="d-flex align-center mb-2">
            <MudText Typo="Typo.h6">MCP servers</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenMcpAddDialog">
                Add server
            </MudButton>
        </div>
        <MudText Typo="Typo.caption" Class="mb-3">
            Model Context Protocol servers contribute additional tools to the agent. Tools appear as
            <code>mcp__&lt;id&gt;__&lt;tool&gt;</code> and are deferred — the LLM calls <code>load_tool</code>
            before using one. Stored on disk in <code>@McpStore.FilePath</code>; shared by every chat
            session in this Yamca process.
        </MudText>

        @{
            var mcpConfigs = McpStore.Configs;
            var serversById = McpRegistry.Servers.ToDictionary(s => s.Config.Id, StringComparer.Ordinal);
        }

        @if (mcpConfigs.Count == 0)
        {
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                No servers configured. Paste the JSON snippet from a server's README to add one.
            </MudText>
        }
        else
        {
            <MudTable Items="mcpConfigs" Hover="true" Dense="true" Class="mud-table-bordered">
                <HeaderContent>
                    <MudTh>Server</MudTh>
                    <MudTh>Transport</MudTh>
                    <MudTh>Target</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Tools</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        serversById.TryGetValue(context.Id, out var conn);
                        var status = conn?.Status ?? (context.Enabled ? McpServerStatus.Connecting : McpServerStatus.Disabled);
                        var failure = conn?.FailureMessage;
                        var toolCount = conn?.Adapters.Count ?? 0;
                        var isStdio = context.TransportKind == McpTransportKind.Stdio;
                    }
                    <MudTd>
                        <MudSwitch T="bool" Value="context.Enabled"
                                   ValueChanged="@((bool v) => OnMcpToggle(context.Id, v))"
                                   Color="Color.Primary" />
                        <code>@context.Id</code>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                            @(isStdio ? "stdio" : "http")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="@FormatMcpTooltip(context)" Placement="Placement.Top">
                            <code>@FormatMcpTarget(context)</code>
                        </MudTooltip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@McpStatusColor(status)">@status</MudChip>
                        @if (!string.IsNullOrEmpty(failure))
                        {
                            <MudTooltip Text="@failure" Placement="Placement.Right">
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Warning" />
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd>@toolCount</MudTd>
                    <MudTd>
                        <MudTooltip Text="Test connection (restart this server)">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                           OnClick="@(() => TestMcpConnection(context.Id))"
                                           aria-label="Test connection" />
                        </MudTooltip>
                        @if (isStdio)
                        {
                            <MudTooltip Text="Run the command with --version to triage launch failures">
                                <MudIconButton Icon="@Icons.Material.Filled.MedicalServices" Size="Size.Small"
                                               OnClick="@(() => RunMcpDiagnostics(context.Id))"
                                               aria-label="Diagnostics" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Edit configuration">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenMcpEditDialog(context.Id))"
                                           aria-label="Edit server" />
                        </MudTooltip>
                        @if (conn is not null)
                        {
                            <MudTooltip Text="Show log">
                                <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small"
                                               OnClick="@(() => OpenMcpLogDialog(context.Id))"
                                               aria-label="Show log" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Remove">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           OnClick="@(() => RemoveMcpServer(context.Id))"
                                           aria-label="Remove server" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <MudDialog @bind-Visible="_mcpAddOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>@(_mcpEditOriginalId is null ? "Add MCP server" : $"Edit MCP server — {_mcpEditOriginalId}")</TitleContent>
        <DialogContent>
            <MudTextField T="string" @bind-Value="_mcpAddId"
                          Label="Id (slug)"
                          HelperText="ASCII letters, digits, hyphen, or underscore. Used in tool names."
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                          Placeholder="filesystem" />

            @if (_mcpEditOriginalId is null)
            {
                <MudSelect T="McpAddType" Value="_mcpAddType"
                           ValueChanged="@((McpAddType v) => _mcpAddType = v)"
                           Label="Type"
                           Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Class="mb-3">
                    <MudSelectItem T="McpAddType" Value="McpAddType.Command">Command (stdio)</MudSelectItem>
                    <MudSelectItem T="McpAddType" Value="McpAddType.Url">URL (streamable HTTP / SSE)</MudSelectItem>
                    <MudSelectItem T="McpAddType" Value="McpAddType.Json">JSON (paste from README)</MudSelectItem>
                </MudSelect>
            }

            @if (_mcpAddType != McpAddType.Json)
            {
                <MudSelect T="Availability" Value="_mcpFormDefaultAvailability"
                           ValueChanged="@((Availability v) => _mcpFormDefaultAvailability = v)"
                           Label="Default tool availability"
                           HelperText="Initial visibility for every tool this server exposes. Individual tools can still be overridden on the Tools page. Deferred is the safe default for chatty servers."
                           Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Class="mb-3">
                    <MudSelectItem T="Availability" Value="Availability.Deferred">Deferred</MudSelectItem>
                    <MudSelectItem T="Availability" Value="Availability.Eager">Eager</MudSelectItem>
                    <MudSelectItem T="Availability" Value="Availability.Hidden">Hidden</MudSelectItem>
                </MudSelect>
            }

            @switch (_mcpAddType)
            {
                case McpAddType.Command:
                    <MudTextField T="string" @bind-Value="_mcpFormCommand"
                                  Label="Command" Required="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                  Placeholder="npx" />
                    <MudTextField T="string" @bind-Value="_mcpFormArgs"
                                  Label="Args (optional)"
                                  HelperText="One argument per line. Empty lines are ignored."
                                  Variant="Variant.Outlined" Lines="4" Class="mb-2"
                                  Placeholder="@McpArgsPlaceholder" />
                    <MudTextField T="string" @bind-Value="_mcpFormCwd"
                                  Label="Working directory (optional)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />

                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Environment variables (optional)</MudText>
                    @if (_mcpFormEnv.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)" Class="mb-1">
                            None.
                        </MudText>
                    }
                    else
                    {
                        <div class="mb-1">
                            @foreach (var row in _mcpFormEnv)
                            {
                                <div @key="row.Id" class="d-flex align-center mb-1" style="gap: 4px;">
                                    <MudTextField T="string" @bind-Value="row.Key"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="flex-grow-1" Placeholder="NAME" />
                                    <MudTextField T="string" @bind-Value="row.Value"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="flex-grow-1" Placeholder="value" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(() => RemoveMcpEnvRow(row))"
                                                   aria-label="Remove variable" />
                                </div>
                            }
                        </div>
                    }
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddMcpEnvRow" Size="Size.Small" Class="mb-3">
                        Add variable
                    </MudButton>

                    <MudNumericField T="int?" @bind-Value="_mcpFormTimeoutSeconds"
                                     Label="Call timeout (seconds, optional)"
                                     HelperText="Overrides the 30s per-call default. 1–3600."
                                     Min="1" Max="3600"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-1" />
                    break;

                case McpAddType.Url:
                    <MudTextField T="string" @bind-Value="_mcpFormUrl"
                                  Label="URL" Required="true"
                                  HelperText="Absolute http:// or https:// URL."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                  Placeholder="https://example.com/mcp" />

                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Headers (optional)</MudText>
                    @if (_mcpFormHeaders.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)" Class="mb-1">
                            None.
                        </MudText>
                    }
                    else
                    {
                        <div class="mb-1">
                            @foreach (var row in _mcpFormHeaders)
                            {
                                <div @key="row.Id" class="d-flex align-center mb-1" style="gap: 4px;">
                                    <MudTextField T="string" @bind-Value="row.Key"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="flex-grow-1" Placeholder="Authorization" />
                                    <MudTextField T="string" @bind-Value="row.Value"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="flex-grow-1" Placeholder="Bearer ..." />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(() => RemoveMcpHeaderRow(row))"
                                                   aria-label="Remove header" />
                                </div>
                            }
                        </div>
                    }
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddMcpHeaderRow" Size="Size.Small" Class="mb-3">
                        Add header
                    </MudButton>

                    <MudNumericField T="int?" @bind-Value="_mcpFormTimeoutSeconds"
                                     Label="Call timeout (seconds, optional)"
                                     HelperText="Overrides the 30s per-call default. 1–3600."
                                     Min="1" Max="3600"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-1" />
                    break;

                case McpAddType.Json:
                    <MudText Typo="Typo.caption" Class="mb-2">
                        Paste the JSON snippet from the server's README. Either the wrapped form
                        (<code>{ "id": ..., "config": { ... } }</code>) or the bare <code>mcp.json</code>
                        shape works. Supply <code>command</code>/<code>args</code> for stdio, or
                        <code>url</code>/<code>headers</code> for streamable HTTP / SSE.
                        Optional <code>timeoutSeconds</code> overrides the 30s per-call default.
                    </MudText>
                    <MudTextField T="string" @bind-Value="_mcpAddJson"
                                  Label="Config JSON"
                                  Variant="Variant.Outlined" Lines="12"
                                  Placeholder="@McpJsonPlaceholder" />
                    break;
            }

            @if (!string.IsNullOrEmpty(_mcpAddError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_mcpAddError</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpAddOpen = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="@(!CanSubmitMcpDialog())"
                       OnClick="ConfirmMcpDialog">
                @(_mcpEditOriginalId is null ? "Add" : "Save")
            </MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_mcpDiagOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>Diagnostics — <code>@_mcpDiagServerId</code></TitleContent>
        <DialogContent>
            @if (_mcpDiagRunning)
            {
                <div class="d-flex align-center" style="gap: 8px;">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    <MudText Typo="Typo.body2">Running probe&hellip;</MudText>
                </div>
            }
            else if (_mcpDiagResult is { } d)
            {
                <MudAlert Severity="@(d.Success ? Severity.Success : Severity.Warning)" Dense="true" Class="mb-2">
                    @(d.Success
                        ? $"Command exited 0 in {d.Elapsed.TotalMilliseconds:F0}ms."
                        : (d.Error ?? $"Command exited {d.ExitCode?.ToString() ?? "?"}."))
                </MudAlert>
                <MudText Typo="Typo.caption">Resolved command</MudText>
                <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem;">@d.ResolvedCommand --version</pre>
                @if (!string.IsNullOrEmpty(d.Stdout))
                {
                    <MudText Typo="Typo.caption">stdout</MudText>
                    <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem; max-height:160px; overflow:auto;">@d.Stdout</pre>
                }
                @if (!string.IsNullOrEmpty(d.Stderr))
                {
                    <MudText Typo="Typo.caption">stderr</MudText>
                    <pre class="mud-paper-outlined pa-2 mb-2" style="font-size:0.78rem; max-height:160px; overflow:auto;">@d.Stderr</pre>
                }
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpDiagOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_mcpLogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>MCP server log — <code>@_mcpLogServerId</code></TitleContent>
        <DialogContent>
            @{
                var conn = _mcpLogServerId is null ? null : McpRegistry.Servers.FirstOrDefault(s => s.Config.Id == _mcpLogServerId);
                var entries = conn?.Log.Snapshot() ?? Array.Empty<McpServerLogBuffer.LogEntry>();
            }
            @if (entries.Count == 0)
            {
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                    No log entries yet.
                </MudText>
            }
            else
            {
                <pre class="mud-paper-outlined pa-2" style="overflow:auto; max-height: 360px; font-size: 0.78rem;">@string.Join('\n', entries.Select(e => $"{e.Timestamp:HH:mm:ss}  [{e.Source}] {e.Line}"))</pre>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _mcpLogOpen = false)">Close</MudButton>
        </DialogActions>
    </MudDialog>
}

</MudContainer>

@code {
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private McpConfigStore McpStore { get; set; } = default!;
    [Inject] private IMcpRegistry McpRegistry { get; set; } = default!;

    private bool _hydrated;

    private bool _mcpAddOpen;
    private string _mcpAddId = string.Empty;
    private string _mcpAddJson = string.Empty;
    private string? _mcpAddError;
    private string? _mcpEditOriginalId;

    private enum McpAddType { Command, Url, Json }
    private McpAddType _mcpAddType = McpAddType.Command;

    private string _mcpFormCommand = string.Empty;
    private string _mcpFormArgs = string.Empty;
    private string _mcpFormCwd = string.Empty;
    private readonly List<KvRow> _mcpFormEnv = new();

    private string _mcpFormUrl = string.Empty;
    private readonly List<KvRow> _mcpFormHeaders = new();

    private int? _mcpFormTimeoutSeconds;
    private Availability _mcpFormDefaultAvailability = Availability.Deferred;

    private sealed class KvRow
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private static readonly JsonSerializerOptions s_mcpFormJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
        WriteIndented = false,
        Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) },
    };

    private bool _mcpLogOpen;
    private string? _mcpLogServerId;

    private bool _mcpDiagOpen;
    private bool _mcpDiagRunning;
    private string? _mcpDiagServerId;
    private McpDiagnostics.DiagnosticsResult? _mcpDiagResult;

    private const string McpArgsPlaceholder = "-y\n@modelcontextprotocol/server-filesystem\n.";

    private const string McpJsonPlaceholder = @"{
  ""command"": ""npx"",
  ""args"": [""-y"", ""@modelcontextprotocol/server-filesystem"", "".""],
  ""timeoutSeconds"": 30
}

// or for HTTP:
// { ""url"": ""https://example.com/mcp"", ""headers"": { ""Authorization"": ""Bearer ..."" } }";

    protected override void OnInitialized()
    {
        McpRegistry.Changed += OnMcpChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        if (!McpStore.Hydrated)
        {
            try { await McpStore.HydrateAsync(); }
            catch (Exception ex) { Snackbar.Add($"MCP hydrate failed: {ex.Message}", Severity.Warning); }
        }
        _hydrated = true;
        StateHasChanged();
    }

    private void OnMcpChanged() => InvokeAsync(StateHasChanged);

    private void OpenMcpAddDialog()
    {
        _mcpEditOriginalId = null;
        _mcpAddId = string.Empty;
        _mcpAddJson = string.Empty;
        _mcpAddError = null;
        _mcpAddType = McpAddType.Command;
        ResetMcpFormFields();
        _mcpAddOpen = true;
    }

    private void OpenMcpEditDialog(string id)
    {
        var existing = McpStore.Configs.FirstOrDefault(c => string.Equals(c.Id, id, StringComparison.Ordinal));
        if (existing is null) return;
        _mcpEditOriginalId = id;
        _mcpAddId = id;
        _mcpAddJson = string.Empty;
        _mcpAddError = null;

        ResetMcpFormFields();
        if (existing.Stdio is { } s)
        {
            _mcpAddType = McpAddType.Command;
            _mcpFormCommand = s.Command;
            _mcpFormArgs = string.Join('\n', s.Args);
            _mcpFormCwd = s.WorkingDirectory ?? string.Empty;
            if (s.Env is not null)
            {
                foreach (var kv in s.Env)
                    _mcpFormEnv.Add(new KvRow { Key = kv.Key, Value = kv.Value });
            }
        }
        else if (existing.Http is { } h)
        {
            _mcpAddType = McpAddType.Url;
            _mcpFormUrl = h.Url;
            if (h.Headers is not null)
            {
                foreach (var kv in h.Headers)
                    _mcpFormHeaders.Add(new KvRow { Key = kv.Key, Value = kv.Value });
            }
        }
        _mcpFormTimeoutSeconds = existing.CallTimeoutSeconds;
        _mcpFormDefaultAvailability = existing.DefaultToolAvailability;
        _mcpAddOpen = true;
    }

    private void ResetMcpFormFields()
    {
        _mcpFormCommand = string.Empty;
        _mcpFormArgs = string.Empty;
        _mcpFormCwd = string.Empty;
        _mcpFormEnv.Clear();
        _mcpFormUrl = string.Empty;
        _mcpFormHeaders.Clear();
        _mcpFormTimeoutSeconds = null;
        _mcpFormDefaultAvailability = Availability.Deferred;
    }

    private async Task ConfirmMcpDialog()
    {
        string json = _mcpAddType switch
        {
            McpAddType.Command => BuildCommandJson(),
            McpAddType.Url => BuildUrlJson(),
            _ => _mcpAddJson,
        };

        McpConfigParseResult result;
        if (_mcpEditOriginalId is { } original)
        {
            result = await McpStore.ReplaceAsync(original, _mcpAddId, json);
        }
        else
        {
            result = await McpStore.AddAsync(_mcpAddId, json);
        }
        if (result.Config is null)
        {
            _mcpAddError = result.Error ?? "Could not parse config.";
            return;
        }
        _mcpAddOpen = false;
        var verb = _mcpEditOriginalId is null ? "added" : "saved";
        _mcpEditOriginalId = null;
        Snackbar.Add($"MCP server '{result.Config.Id}' {verb}.", Severity.Success);
    }

    private string BuildCommandJson()
    {
        var config = new Dictionary<string, object?>(StringComparer.Ordinal)
        {
            ["command"] = (_mcpFormCommand ?? string.Empty).Trim(),
        };

        var args = (_mcpFormArgs ?? string.Empty)
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(a => a.TrimEnd('\r').Trim())
            .Where(a => a.Length > 0)
            .ToList();
        if (args.Count > 0) config["args"] = args;

        var env = _mcpFormEnv
            .Where(r => !string.IsNullOrWhiteSpace(r.Key))
            .ToDictionary(r => r.Key.Trim(), r => r.Value ?? string.Empty, StringComparer.Ordinal);
        if (env.Count > 0) config["env"] = env;

        if (!string.IsNullOrWhiteSpace(_mcpFormCwd)) config["cwd"] = _mcpFormCwd.Trim();
        if (_mcpFormTimeoutSeconds is { } t) config["timeoutSeconds"] = t;

        var wrapper = new Dictionary<string, object?>(StringComparer.Ordinal)
        {
            ["config"] = config,
            ["defaultToolAvailability"] = _mcpFormDefaultAvailability,
        };
        return JsonSerializer.Serialize(wrapper, s_mcpFormJsonOptions);
    }

    private string BuildUrlJson()
    {
        var config = new Dictionary<string, object?>(StringComparer.Ordinal)
        {
            ["url"] = (_mcpFormUrl ?? string.Empty).Trim(),
        };

        var headers = _mcpFormHeaders
            .Where(r => !string.IsNullOrWhiteSpace(r.Key))
            .ToDictionary(r => r.Key.Trim(), r => r.Value ?? string.Empty, StringComparer.Ordinal);
        if (headers.Count > 0) config["headers"] = headers;

        if (_mcpFormTimeoutSeconds is { } t) config["timeoutSeconds"] = t;

        var wrapper = new Dictionary<string, object?>(StringComparer.Ordinal)
        {
            ["config"] = config,
            ["defaultToolAvailability"] = _mcpFormDefaultAvailability,
        };
        return JsonSerializer.Serialize(wrapper, s_mcpFormJsonOptions);
    }

    private bool CanSubmitMcpDialog() => _mcpAddType switch
    {
        McpAddType.Command => !string.IsNullOrWhiteSpace(_mcpFormCommand),
        McpAddType.Url => !string.IsNullOrWhiteSpace(_mcpFormUrl),
        McpAddType.Json => !string.IsNullOrWhiteSpace(_mcpAddJson),
        _ => false,
    };

    private void AddMcpEnvRow() => _mcpFormEnv.Add(new KvRow());
    private void RemoveMcpEnvRow(KvRow row) => _mcpFormEnv.Remove(row);
    private void AddMcpHeaderRow() => _mcpFormHeaders.Add(new KvRow());
    private void RemoveMcpHeaderRow(KvRow row) => _mcpFormHeaders.Remove(row);

    private async Task RemoveMcpServer(string id)
    {
        await McpStore.RemoveAsync(id);
        Snackbar.Add($"MCP server '{id}' removed.", Severity.Info);
    }

    private async Task OnMcpToggle(string id, bool enabled) => await McpStore.SetEnabledAsync(id, enabled);

    private async Task TestMcpConnection(string id)
    {
        var ok = await McpRegistry.RestartAsync(id);
        Snackbar.Add(
            ok ? $"Restarting MCP server '{id}'…" : $"No active server '{id}' to restart.",
            ok ? Severity.Info : Severity.Warning);
    }

    private async Task RunMcpDiagnostics(string id)
    {
        var cfg = McpStore.Configs.FirstOrDefault(c => string.Equals(c.Id, id, StringComparison.Ordinal));
        if (cfg?.Stdio is null) return;

        _mcpDiagServerId = id;
        _mcpDiagResult = null;
        _mcpDiagRunning = true;
        _mcpDiagOpen = true;
        StateHasChanged();

        var result = await McpDiagnostics.ProbeStdioAsync(cfg.Stdio);
        _mcpDiagResult = result;
        _mcpDiagRunning = false;
        StateHasChanged();
    }

    private void OpenMcpLogDialog(string id)
    {
        _mcpLogServerId = id;
        _mcpLogOpen = true;
    }

    private static Color McpStatusColor(McpServerStatus status) => status switch
    {
        McpServerStatus.Ready => Color.Success,
        McpServerStatus.Failed => Color.Error,
        McpServerStatus.Connecting => Color.Warning,
        _ => Color.Default,
    };

    private static string FormatMcpTarget(McpServerConfig config) =>
        config.TransportKind == McpTransportKind.Http
            ? config.Http!.Url
            : config.Stdio!.Command;

    private static string FormatMcpTooltip(McpServerConfig config)
    {
        if (config.TransportKind == McpTransportKind.Http)
        {
            var headers = config.Http?.Headers is { Count: > 0 } h
                ? " (+ " + h.Count + " header" + (h.Count == 1 ? ")" : "s)")
                : string.Empty;
            return config.Http!.Url + headers;
        }
        var stdio = config.Stdio!;
        var args = stdio.Args.Count == 0 ? "" : " " + string.Join(' ', stdio.Args);
        var cwd = string.IsNullOrEmpty(stdio.WorkingDirectory) ? "" : $"\ncwd: {stdio.WorkingDirectory}";
        return $"{stdio.Command}{args}{cwd}";
    }

    public void Dispose()
    {
        McpRegistry.Changed -= OnMcpChanged;
    }
}
