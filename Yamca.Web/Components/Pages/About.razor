@page "/about"
@rendermode InteractiveServer
@implements IDisposable
@using Yamca.Agent.Chat

<PageTitle>About — yamca</PageTitle>

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6" Class="mb-2">Workspace</MudText>
    <MudText Typo="Typo.body2">Root: <code>@Workspace.RootPath</code></MudText>
    <MudText Typo="Typo.caption">localStorage key: <code>@Keys.ProjectKey</code></MudText>
</MudPaper>

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6" Class="mb-2">Endpoint health</MudText>
    <MudText Typo="Typo.body2" Class="mb-2">
        Configured: <code>@Settings.Endpoint.BaseUrl</code> (model <code>@Settings.Endpoint.Model</code>)
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CheckHealth"
               Disabled="_checking" StartIcon="@Icons.Material.Filled.Sync">
        @(_checking ? "Checking…" : "Check now")
    </MudButton>
    @if (_healthStatus is not null)
    {
        <MudAlert Severity="@_healthSeverity" Class="mt-3" Dense="true">
            @_healthStatus
        </MudAlert>
    }
</MudPaper>

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6" Class="mb-2">Resolved tool permissions</MudText>
    <MudText Typo="Typo.caption" Class="mb-3">
        Effective values after merging Project → Global → tool default.
    </MudText>
    <MudTable Items="Tools.Tools" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Tool</MudTh>
            <MudTh>Permission</MudTh>
            <MudTh>Sandboxed</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><code>@context.Name</code></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@PermColor(Resolver.Resolve(context.Name))">
                    @Resolver.Resolve(context.Name)
                </MudChip>
            </MudTd>
            <MudTd>
                @if (context.SupportsWorkspaceRestriction)
                {
                    @(Resolver.RestrictToWorkspace(context.Name) ? "yes" : "no")
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">n/a</MudText>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IWorkspace Workspace { get; set; } = default!;
    [Inject] private SessionSettings Settings { get; set; } = default!;
    [Inject] private SettingsHydrator Hydrator { get; set; } = default!;
    [Inject] private IToolRegistry Tools { get; set; } = default!;
    [Inject] private IPermissionResolver Resolver { get; set; } = default!;
    [Inject] private WorkspaceKey Keys { get; set; } = default!;
    [Inject] private EndpointHealthService HealthService { get; set; } = default!;

    private bool _checking;
    private string? _healthStatus;
    private Severity _healthSeverity = Severity.Info;

    protected override void OnInitialized()
    {
        Settings.Changed += OnSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Hydrator.HydrateAsync();
        StateHasChanged();
    }

    private void OnSettingsChanged(SettingsTier _) => InvokeAsync(StateHasChanged);

    private async Task CheckHealth()
    {
        _checking = true;
        _healthStatus = null;
        StateHasChanged();

        var result = await HealthService.CheckAsync(Settings.Endpoint);
        _healthStatus = result.Message;
        _healthSeverity = result.Healthy ? Severity.Success : Severity.Error;

        _checking = false;
        StateHasChanged();
    }

    private static Color PermColor(PermissionLevel level) => level switch
    {
        PermissionLevel.Allow => Color.Success,
        PermissionLevel.Deny  => Color.Error,
        _                     => Color.Warning,
    };

    public void Dispose()
    {
        Settings.Changed -= OnSettingsChanged;
    }
}
