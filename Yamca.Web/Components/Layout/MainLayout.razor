@inherits LayoutComponentBase
@implements IDisposable
@using Yamca.Agent.Tools.ProcessManagement
@using WorkspaceImpl = Yamca.Agent.Workspace.Workspace
@inject ChatSessionManager Sessions
@inject NavigationManager Nav
@inject ChatStore Store
@inject IDialogService Dialogs
@inject IBackgroundProcessManager Processes

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="true" Dense="true" Elevation="2" Class="yamca-appbar" Style="height: var(--yamca-appbar-h)">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       OnClick="ToggleDrawer" aria-label="Toggle chats" />
        <div class="yamca-brand" @onclick="ToggleDrawer" role="button" aria-label="Toggle chats">
            <img src="yamca.png" alt="yamca" height="32" width="32" style="border-radius: 4px" />
        </div>
        <MudTooltip Text="New Chat">
            <MudIconButton Icon="@Icons.Material.Filled.ChatBubbleOutline" Color="Color.Inherit"
                           OnClick="NewChat" aria-label="New Chat" />
        </MudTooltip>
        <MudSpacer />
        <MudTooltip Text="Dev Board">
            <MudIconButton Href="board" Icon="@Icons.Material.Filled.ViewKanban"
                           Color="@(IsActive("board") ? Color.Primary : Color.Inherit)" aria-label="Dev Board" />
        </MudTooltip>
        <MudTooltip Text="Workspace">
            <MudIconButton Href="workspace" Icon="@Icons.Material.Filled.FolderOpen"
                           Color="@(IsActive("workspace") ? Color.Primary : Color.Inherit)" aria-label="Workspace" />
        </MudTooltip>
        <MudTooltip Text="Processes">
            <MudIconButton Href="processes" Icon="@Icons.Material.Filled.Terminal"
                           Color="@(IsActive("processes") ? Color.Primary : Color.Inherit)" aria-label="Processes" />
        </MudTooltip>
        <MudTooltip Text="Settings">
            <MudMenu Icon="@Icons.Material.Filled.Settings"
                     Color="@(IsSettingsActive() ? Color.Primary : Color.Inherit)"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <MudMenuItem Href="endpoints" Icon="@Icons.Material.Filled.Cloud">Endpoints</MudMenuItem>
                <MudMenuItem Href="tools" Icon="@Icons.Material.Filled.Build">Tools</MudMenuItem>
                <MudMenuItem Href="scripts" Icon="@Icons.Material.Filled.FileOpen">Scripts</MudMenuItem>
                <MudMenuItem Href="commands" Icon="@Icons.Material.Filled.Terminal">Commands</MudMenuItem>
                <MudMenuItem Href="subagents" Icon="@Icons.Material.Filled.AccountTree">Subagents</MudMenuItem>
                <MudMenuItem Href="instructions" Icon="@Icons.Material.Filled.MenuBook">Instructions</MudMenuItem>
                <MudMenuItem Href="mcp" Icon="@Icons.Material.Filled.Extension">MCP</MudMenuItem>
                <MudMenuItem Href="preferences" Icon="@Icons.Material.Filled.Tune">Preferences</MudMenuItem>
                <MudMenuItem Href="backup" Icon="@Icons.Material.Filled.Backup">Backup</MudMenuItem>
            </MudMenu>
        </MudTooltip>
        <MudTooltip Text="Exit yamca">
            <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" Color="Color.Inherit"
                           OnClick="ExitApp" aria-label="Exit yamca" />
        </MudTooltip>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Temporary" Style="top: var(--yamca-appbar-h); height: calc(100vh - var(--yamca-appbar-h))">
        <MudNavMenu>
            @* Active chats — loaded in memory. Ordered most-recently-active first. The
               trailing "X" unloads (closes); its presence is what marks a row "active".
               A row shown in a split pane is highlighted via .yamca-visible. *@
            @foreach (var s in Sessions.Sessions.OrderByDescending(s => s.LastActivityUtc))
            {
                var sid = s.Id;
                var rowClass = Sessions.IsVisible(sid) ? "yamca-session-row yamca-visible" : "yamca-session-row";
                <div class="@rowClass" @onmouseup="@(e => OnRowMouseUp(e, sid))" @key="sid">
                    <MudNavLink Icon="@Icons.Material.Filled.Chat" OnClick="@(() => ShowChat(sid))">
                        @(string.IsNullOrWhiteSpace(s.Title) ? "New Chat" : s.Title)
                    </MudNavLink>
                    <MudIconButton Class="yamca-session-close"
                                   Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="@(() => CloseSession(sid))"
                                   aria-label="Close chat" />
                </div>
            }
            <MudNavLink Icon="@Icons.Material.Filled.ChatBubbleOutline" OnClick="NewChat">
                New Chat
            </MudNavLink>

            @{
                // Only chats not already loaded are "closed" — the rest are reachable
                // directly above. Deletion lives in the History dialog, so closed rows
                // carry no inline button (their lack of an "X" is what marks them closed).
                var recentClosed = _recent.Where(r => Sessions.FindByPersistentId(r.Id) is null).ToList();
                var recentShown = recentClosed.Take(RecentInSidebar).ToList();
            }
            @if (Store.IsEnabled)
            {
                <MudDivider DividerType="DividerType.Middle" Class="my-2" />
                <MudNavLink Icon="@Icons.Material.Filled.History" OnClick="OpenRecentModal">History</MudNavLink>
                @foreach (var item in recentShown)
                {
                    <div class="yamca-session-row" @key="item.Id">
                        <MudNavLink OnClick="@(() => LoadRecent(item.Id))">
                            @(string.IsNullOrWhiteSpace(item.Title) ? "(untitled chat)" : item.Title)
                        </MudNavLink>
                    </div>
                }
            }

        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = false;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    // The drawer overlays content, so dismiss it once the user has chosen a destination.
    private void CloseDrawer() => _drawerOpen = false;

    private const int RecentInSidebar = 8;
    private IReadOnlyList<ChatListItem> _recent = Array.Empty<ChatListItem>();

    // Pages reachable from the top app bar. Used to highlight the active destination.
    private static readonly string[] SettingsPaths =
        { "endpoints", "tools", "scripts", "commands", "subagents", "instructions", "mcp", "preferences", "backup" };

    protected override void OnInitialized()
    {
        Sessions.Changed += OnSessionsChanged;
        Nav.LocationChanged += OnLocationChanged;
        RefreshRecent();
    }

    // The app bar highlights whichever destination is current, so it has to re-render
    // when the route changes (page components re-render themselves, the layout does not).
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private bool IsActive(string href)
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        return string.Equals(uri, href, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsSettingsActive() => SettingsPaths.Any(IsActive);

    private void OnSessionsChanged()
    {
        // Closing/opening a chat changes which saved sessions count as "recent".
        RefreshRecent();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshRecent()
    {
        try { _recent = Store.List(); }
        catch { _recent = Array.Empty<ChatListItem>(); }
    }

    private void NewChat()
    {
        CloseDrawer();
        Sessions.Create(); // auto-shown in a pane; the single split view reflows
    }

    /// <summary>Bring an already-loaded chat into a split pane (replacing the last pane
    /// when the grid is full). Leaves the drawer open so the user can compose a layout.</summary>
    private void ShowChat(int id) => Sessions.Show(id);

    /// <summary>Fully unload a chat. The grid reflows on its own; an emptied grid is
    /// re-filled by the view's ensure-at-least-one-visible.</summary>
    private void CloseSession(int id) => Sessions.Close(id);

    private void OnRowMouseUp(MouseEventArgs e, int id)
    {
        if (e.Button == 1) CloseSession(id);
    }

    /// <summary>Reopen a saved chat. If it's already loaded, just show it in a pane.
    /// Otherwise load it and rehydrate into the appropriate workspace / read-only mode
    /// (Rehydrate shows it automatically).</summary>
    private void LoadRecent(Guid id)
    {
        var existing = Sessions.FindByPersistentId(id);
        if (existing is not null)
        {
            Sessions.Show(existing.Id);
            return;
        }

        var doc = Store.Load(id);
        if (doc is null)
        {
            // File vanished or unreadable — drop it from the list and move on.
            RefreshRecent();
            StateHasChanged();
            return;
        }

        var (workspace, readOnly) = ResolveWorkspace(doc);
        Sessions.Rehydrate(doc, workspace, readOnly);
        RefreshRecent();
    }

    /// <summary>Decide the workspace and read-only state for a saved chat. A chat bound to
    /// a worktree resumes against that worktree when it still exists; if the worktree is
    /// gone it opens as read-only history under the root workspace. Non-worktree chats use
    /// the root workspace (null = DI default).</summary>
    private static (IWorkspace?, bool) ResolveWorkspace(PersistedChat doc)
    {
        if (doc.Worktree is { } wt)
        {
            if (Directory.Exists(wt.WorktreePath))
                return (new WorkspaceImpl(wt.WorktreePath), false);
            return (null, true); // worktree gone → read-only history
        }
        return (null, false);
    }

    private static string SlotLabel(ChatViewModel s, int index) =>
        s.Turns.Count == 0 && s.WorktreeInfo is null ? $"Chat {index + 1}" : s.Title;

    private async Task OpenRecentModal()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<ChatHistoryDialog>("Chat history", options);
        var result = await dialog.Result;
        RefreshRecent();
        StateHasChanged();
        if (result is not null && !result.Canceled && result.Data is Guid id)
            LoadRecent(id);
    }

    /// <summary>Confirm, then shut the whole server down. Force-navigates to the static /goodbye
    /// endpoint (see Program.cs), which tears down this circuit cleanly and stops the host — so the
    /// terminal-launched process exits without the user hunting for the window that started it.</summary>
    private async Task ExitApp()
    {
        var chatNames = Sessions.Sessions.Select(SlotLabel).ToList();
        var processNames = Processes.Snapshot()
            .Where(p => p.Status == ProcessStatus.Running)
            .Select(p => p.Name)
            .ToList();

        var parameters = new DialogParameters
        {
            ["Chats"] = (IReadOnlyList<string>)chatNames,
            ["Processes"] = (IReadOnlyList<string>)processNames,
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<ExitConfirmationDialog>("Exit yamca?", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
            Nav.NavigateTo("goodbye", forceLoad: true);
    }

    public void Dispose()
    {
        Sessions.Changed -= OnSessionsChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
